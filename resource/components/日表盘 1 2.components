    {
      "id": "72ebb3ec-64ac-4074-b719-b75e494dca35",
      "type": "dataview",
      "titleAlign": "center",
      "tabTitle": "Dataview",
      "maxWidthRatio": -1,
      "showBorder": true,
      "showTitle": true,
      "showShadow": true,
      "createAt": "2025-11-01T12:24:16.724Z",
      "updateAt": "2026-02-07T03:51:30.985Z",
      "query": "// 获取当天日期并格式化文件名\nconst today = new Date();\nconst year = today.getFullYear();\nconst month = String(today.getMonth() + 1).padStart(2, '0');\nconst day = String(today.getDate()).padStart(2, '0');\n\n// 计算周数 (ISO周)\nfunction getISOWeek(date) {\n  const target = new Date(date.valueOf());\n  const dayNr = (date.getDay() + 6) % 7;\n  target.setDate(target.getDate() - dayNr + 3);\n  const firstThursday = target.valueOf();\n  target.setMonth(0, 1);\n  if (target.getDay() !== 4) {\n    target.setMonth(0, 1 + ((4 - target.getDay()) + 7) % 7);\n  }\n  return String(1 + Math.ceil((firstThursday - target) / 604800000)).padStart(2, '0');\n}\n\nconst week = getISOWeek(today);\nconst fileName = `${week}_${year}_${month}_${day}.md`;\n\n// 尝试获取当天文件\nlet targetFile;\ntry {\n  targetFile = app.vault.getMarkdownFiles().find(file => \n    file.name === fileName\n  );\n  \n  if (!targetFile) {\n    dv.paragraph(`未找到文件: ${fileName}`);\n    return;\n  }\n} catch (e) {\n  dv.paragraph(`查找文件时出错: ${e.message}`);\n  return;\n}\n\n// 获取目标文件内容\nlet content;\ntry {\n  content = await dv.io.load(targetFile.path);\n} catch (e) {\n  dv.paragraph(`读取文件内容时出错: ${e.message}`);\n  return;\n}\n\nlet lines = content.split('\\n');\n\n// 存储各标签时长（分钟）\nlet tagDurations = {};\n\n// 解析时间记录\nfor (let line of lines) {\n    let timeMatch = line.match(/(\\d{2}:\\d{2})-(\\d{2}:\\d{2}) (.+?) #(.+)/);\n    if (timeMatch) {\n        let startTime = timeMatch[1];\n        let endTime = timeMatch[2];\n        let activity = timeMatch[3];\n        let fullTagPath = timeMatch[4]; // 获取完整的标签路径\n        \n        // 过滤掉\"时间记录\"标签，但保留完整的层级结构\n        let tags = fullTagPath.split('/').filter(tag => tag.trim() !== '时间记录');\n        \n        // 计算时长（分钟）\n        let start = new Date(`2000-01-01 ${startTime}`);\n        let end = new Date(`2000-01-01 ${endTime}`);\n        let duration = (end - start) / (1000 * 60);\n        \n        // 为每个层级标签累加时长\n        // 同时保留完整的标签路径\n        let currentPath = \"\";\n        tags.forEach(tag => {\n            currentPath = currentPath ? `${currentPath}/${tag}` : tag;\n            \n            if (!tagDurations[currentPath]) {\n                tagDurations[currentPath] = 0;\n            }\n            tagDurations[currentPath] += duration;\n        });\n    }\n}\n\n// 转换为小时和分钟格式\nfunction formatDuration(minutes) {\n    let hours = Math.floor(minutes / 60);\n    let mins = Math.round(minutes % 60);\n    return `${hours}小时${mins > 0 ? mins + '分钟' : ''}`;\n}\n\n// 计算标签级别\nfunction getTagLevel(tagPath) {\n    return tagPath.split('/').length;\n}\n\n// 创建表格显示结果 - 按标签路径排序\nlet tableData = Object.entries(tagDurations)\n    .sort((a, b) => a[0].localeCompare(b[0])) // 按标签路径字母顺序排序\n    .map(([tag, minutes]) => [tag, formatDuration(minutes), `${Math.round(minutes)}分钟`, `${getTagLevel(tag)}级`]);\n\n//dv.paragraph(`文件: ${fileName}`);\ndv.table([\"标签路径\", \"总时长\", \"分钟数\", \"标签级别\"], tableData);\n",
      "queryType": "dataviewjs",
      "maxHeight": 400,
      "dynamicParamComponents": [],
      "title": "今 日 时 间 分 配"
    },
