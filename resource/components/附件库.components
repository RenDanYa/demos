    {
      "id": "3b33f168-4342-43d8-aacd-8d3a310e19dc",
      "type": "dataview",
      "titleAlign": "center",
      "query": "const firstInput = '{{1stInput}}'\nconst secondInput = '{{2ndInput}}'\nconst thirdInput = '{{3rdInput}}'\nconst maxResults = {{MaxNum}}\nlet firstField = 'file.name'\nlet secondField = 'author'\nlet thirdField = 'file.tags'\nlet query = `\ntable\n  file.tags as Tags,\n  dateformat(created_date, \"yyyy-MM-dd\") as CreatedDate\nfrom\n  !\"Resources\"\n`\nif (firstInput && !secondInput && !thirdInput) {\n  query += ` where (icontains(${firstField}, \"${firstInput}\"))`\n} else if (!firstInput && secondInput && !thirdInput) {\n  query += ` where (icontains(${secondField}, \"${secondInput}\"))`\n} else if (!firstInput && !secondInput && thirdInput) {\n  query += ` where (contains(${thirdField}, \"${thirdInput}\"))`\n} else if (firstInput && secondInput && !thirdInput) {\n  query += ` where (icontains(${firstField}, \"${firstInput}\") and icontains(${secondField}, \"${secondInput}\"))`\n} else if (firstInput && !secondInput && thirdInput) {\n  query += ` where (icontains(${firstField}, \"${firstInput}\") and contains(${thirdField}, \"${thirdInput}\"))`\n} else if (!firstInput && secondInput && thirdInput) {\n  query += ` where (icontains(${secondField}, \"${secondInput}\") and contains(${thirdField}, \"${thirdInput}\"))`\n} else if (firstInput && secondInput && thirdInput) {\n  query += ` where (icontains(${firstField}, \"${firstInput}\") and icontains(${secondField}, \"${secondInput}\") and contains(${thirdField}, \"${tag}\"))`\n} else {\n  query += ``\n}\nquery += ` limit ${maxResults} sort file.name asc`\nawait dv.execute(query)",
      "queryType": "dataviewjs",
      "backgroundStyle": "card",
      "maxHeight": -1,
      "contentAlign": "left",
      "dynamicParamComponents": [
