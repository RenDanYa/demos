        "compiledCode": "function App() {\n  const {\n    getData,\n    saveData\n  } = useDataStorage();\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const tags = data.tags || {};\n  const [newTag, setNewTag] = useState({\n    name: '',\n    color: '#3B82F6'\n  });\n  const [editingTag, setEditingTag] = useState(null);\n  const [editTagData, setEditTagData] = useState({\n    name: '',\n    color: '#3B82F6'\n  });\n\n  // 添加新标签\n  const addTag = () => {\n    if (!newTag.name.trim()) {\n      new Notice('请输入标签名称');\n      return;\n    }\n\n    // 检查标签是否已存在\n    if (tags[newTag.name]) {\n      new Notice('标签已存在');\n      return;\n    }\n    const updatedTags = {\n      ...tags,\n      [newTag.name]: {\n        color: newTag.color,\n        created: moment().format('YYYY-MM-DD HH:mm:ss')\n      }\n    };\n    saveData({\n      ...data,\n      tags: updatedTags\n    });\n    setNewTag({\n      name: '',\n      color: '#3B82F6'\n    });\n    new Notice('标签添加成功');\n  };\n\n  // 更新标签\n  const updateTag = oldName => {\n    if (!editTagData.name.trim()) {\n      new Notice('请输入标签名称');\n      return;\n    }\n    const updatedTags = {\n      ...tags\n    };\n\n    // 如果名称改变，需要删除旧标签并创建新标签\n    if (oldName !== editTagData.name) {\n      delete updatedTags[oldName];\n    }\n    updatedTags[editTagData.name] = {\n      color: editTagData.color,\n      created: tags[oldName]?.created || moment().format('YYYY-MM-DD HH:mm:ss'),\n      updated: moment().format('YYYY-MM-DD HH:mm:ss')\n    };\n\n    // 更新所有代码段中的标签引用\n    const metadata = data.metadata || {};\n    Object.keys(metadata).forEach(snippetName => {\n      if (metadata[snippetName].tags) {\n        const tagIndex = metadata[snippetName].tags.indexOf(oldName);\n        if (tagIndex !== -1) {\n          metadata[snippetName].tags[tagIndex] = editTagData.name;\n        }\n      }\n    });\n    saveData({\n      ...data,\n      tags: updatedTags,\n      metadata\n    });\n    setEditingTag(null);\n    setEditTagData({\n      name: '',\n      color: '#3B82F6'\n    });\n    new Notice('标签更新成功');\n  };\n\n  // 删除标签\n  const deleteTag = tagName => {\n    const updatedTags = {\n      ...tags\n    };\n    const metadata = data.metadata || {};\n\n    // 从所有代码段中移除该标签\n    Object.keys(metadata).forEach(snippetName => {\n      if (metadata[snippetName].tags) {\n        metadata[snippetName].tags = metadata[snippetName].tags.filter(tag => tag !== tagName);\n      }\n    });\n    delete updatedTags[tagName];\n    saveData({\n      ...data,\n      tags: updatedTags,\n      metadata\n    });\n    new Notice('标签已删除');\n  };\n\n  // 开始编辑标签\n  const startEditingTag = tagName => {\n    setEditingTag(tagName);\n    setEditTagData({\n      name: tagName,\n      color: tags[tagName]?.color || '#3B82F6'\n    });\n  };\n\n  // 取消编辑\n  const cancelEditing = () => {\n    setEditingTag(null);\n    setEditTagData({\n      name: '',\n      color: '#3B82F6'\n    });\n  };\n  return /*#__PURE__*/React.createElement(Settings, null, /*#__PURE__*/React.createElement(SettingTitle, null, \"CSS\\u4EE3\\u7801\\u6BB5\\u7BA1\\u7406\\u5668\\u8BBE\\u7F6E\"), /*#__PURE__*/React.createElement(SettingItem, {\n    label: \"\\u9ED8\\u8BA4\\u542F\\u7528\\u65B0\\u4EE3\\u7801\\u6BB5\"\n  }, /*#__PURE__*/React.createElement(SettingSwitch, {\n    value: settings.autoEnableNewSnippets || false,\n    onChange: value => saveData({\n      ...data,\n      settings: {\n        ...settings,\n        autoEnableNewSnippets: value\n      }\n    })\n  })), /*#__PURE__*/React.createElement(SettingItem, {\n    label: \"\\u81EA\\u52A8\\u4E3A\\u65B0\\u5EFA\\u4EE3\\u7801\\u6BB5\\u6DFB\\u52A0\\u9ED8\\u8BA4\\u6807\\u7B7E\"\n  }, /*#__PURE__*/React.createElement(SettingSwitch, {\n    value: settings.autoAddDefaultTags || false,\n    onChange: value => saveData({\n      ...data,\n      settings: {\n        ...settings,\n        autoAddDefaultTags: value\n      }\n    })\n  })), /*#__PURE__*/React.createElement(SettingItem, {\n   