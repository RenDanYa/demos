x) => {\n    const taskMatch = line.match(/^[-*] \\[(.)\\] (.+)$/);\n    if (taskMatch) {\n      const [, status, text] = taskMatch;\n      const parsed = parseTaskMetadata(text.trim());\n      tasks.push({\n        id: `task-${notePath}-${index}-${Date.now()}`,\n        text: parsed.text,\n        completed: status.toLowerCase() === 'x',\n        createdAt: new Date().toISOString(),\n        priority: parsed.priority || 'medium',\n        tags: parsed.tags || [],\n        notePath: notePath,\n        startTime: parsed.startTime || null,\n        dueTime: parsed.dueTime || null\n      });\n    }\n  });\n  return tasks;\n}\nfunction parseTaskMetadata(text) {\n  const result = {\n    text,\n    tags: []\n  };\n  const tagMatches = text.match(/#(\\w+)/g);\n  if (tagMatches) {\n    result.tags = tagMatches.map(tag => tag.slice(1));\n    result.text = result.text.replace(/#(\\w+)/g, '').trim();\n  }\n  const priorityMatch = text.match(/!(高|中|低)/);\n  if (priorityMatch) {\n    result.priority = priorityMatch[1] === '高' ? 'high' : priorityMatch[1] === '中' ? 'medium' : 'low';\n    result.text = result.text.replace(/!(高|中|低)/, '').trim();\n  }\n  const metadataMatch = text.match(/\\[([^\\]]+)\\]/);\n  if (metadataMatch) {\n    const metadataStr = metadataMatch[1];\n    result.text = result.text.replace(/\\[([^\\]]+)\\]/, '').trim();\n    const keyValuePairs = [];\n    const regex = /(\\w+):([\\d:]+)/g;\n    let match;\n    while ((match = regex.exec(metadataStr)) !== null) {\n      const key = match[1];\n      const value = match[2];\n      keyValuePairs.push({\n        key,\n        value\n      });\n    }\n    keyValuePairs.forEach(({\n      key,\n      value\n    }) => {\n      if (key === 'start') {\n        result.startTime = formatTimeToHHMM(value);\n      } else if (key === 'due') {\n        result.dueTime = formatTimeToHHMM(value);\n      }\n    });\n  }\n  return result;\n}\nfunction formatTimeToHHMM(timeStr) {\n  if (!timeStr) return '';\n  const cleanTime = timeStr.replace(/[^\\d]/g, '');\n  if (cleanTime.length === 4) {\n    return `${cleanTime.substring(0, 2)}:${cleanTime.substring(2, 4)}`;\n  } else if (cleanTime.length === 3) {\n    return `0${cleanTime.substring(0, 1)}:${cleanTime.substring(1, 3)}`;\n  } else if (cleanTime.length === 2) {\n    return `${cleanTime}:00`;\n  } else if (cleanTime.length === 1) {\n    return `0${cleanTime}:00`;\n  } else {\n    if (timeStr.includes(':')) {\n      const [hours, minutes] = timeStr.split(':');\n      return `${hours.padStart(2, '0')}:${(minutes || '00').padStart(2, '0')}`;\n    }\n    return timeStr;\n  }\n}\nfunction convertTasksToMarkdown(tasks) {\n  if (tasks.length === 0) {\n    return '暂无待办';\n  }\n  return tasks.map(task => {\n    let text = task.text;\n    if (task.tags && task.tags.length > 0) {\n      text += ' ' + task.tags.map(tag => `#${tag}`).join(' ');\n    }\n    if (task.priority === 'high') {\n      text += ' !高';\n    } else if (task.priority === 'low') {\n      text += ' !低';\n    }\n    const metadata = [];\n    if (task.startTime) {\n      metadata.push(`start:${task.startTime}`);\n    }\n    if (task.dueTime) {\n      metadata.push(`due:${task.dueTime}`);\n    }\n    if (metadata.length > 0) {\n      text += ` [${metadata.join(' ')}]`;\n    }\n    return `- [${task.completed ? 'x' : ' '}] ${text}`;\n  }).join('\\n');\n}",
