e: \"user-profile--modal-header\"\n    }, /*#__PURE__*/React.createElement(\"h3\", null, selectedDate, \" \\u7684\\u6587\\u4EF6 (\", selectedDateFiles.length, \")\"), /*#__PURE__*/React.createElement(\"button\", {\n      className: \"user-profile--modal-close\",\n      onClick: closeModal\n    }, \"\\xD7\")), /*#__PURE__*/React.createElement(\"div\", {\n      className: \"user-profile--modal-content\"\n    }, selectedDateFiles.length > 0 ? /*#__PURE__*/React.createElement(\"ul\", {\n      className: \"user-profile--file-list\"\n    }, selectedDateFiles.map((file, index) => /*#__PURE__*/React.createElement(\"li\", {\n      key: index,\n      className: \"user-profile--file-item\"\n    }, /*#__PURE__*/React.createElement(\"span\", {\n      className: \"user-profile--file-link\",\n      onClick: () => {\n        const tfile = app.vault.getAbstractFileByPath(file.path);\n        if (tfile) {\n          // 在新窗口中打开文件\n          app.workspace.getLeaf(true).openFile(tfile);\n          closeModal();\n        }\n      }\n    }, file.name)))) : /*#__PURE__*/React.createElement(\"p\", {\n      className: \"user-profile--no-files\"\n    }, \"\\u8BE5\\u65E5\\u671F\\u6CA1\\u6709\\u6587\\u4EF6\")))));\n  };\n  const handleAvatarClick = () => {\n    setLastRefresh(Date.now());\n  };\n  return /*#__PURE__*/React.createElement(\"div\", {\n    className: \"user-profile--container\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"user-profile--header\"\n  }, /*#__PURE__*/React.createElement(\"img\", {\n    src: getAvatarSrc(),\n    alt: \"User Avatar\",\n    className: \"user-profile--avatar user-profile--avatar-clickable\",\n    onClick: handleAvatarClick,\n    title: \"\\u70B9\\u51FB\\u5237\\u65B0\\u70ED\\u529B\\u56FE\"\n  }), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"user-profile--info\"\n  }, /*#__PURE__*/React.createElement(\"h2\", {\n    className: \"user-profile--username\"\n  }, username), /*#__PURE__*/React.createElement(\"p\", {\n    className: \"user-profile--description\"\n  }, description), birthday && /*#__PURE__*/React.createElement(\"p\", {\n    className: \"user-profile--age\"\n  }, calculateAge(birthday)))), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"user-profile--stats-section\"\n  }, renderObsidianStats()), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"user-profile--heatmap-container\"\n  }, renderCompactHeatmap()));\n}",
