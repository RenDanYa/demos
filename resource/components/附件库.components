            "timestamp": "2025-10-05T16:17:00.346Z",
            "pinned": false,
            "comments": [],
            "tags": [
              "身份"
            ],
            "type": "text"
          },
          {
            "id": "post_1759678081311_clorriz35",
            "content": "### 一、核心原则：三句话的“功能分工”\n1. **第一句：触发情境，露“初步特质”**  \n   先设定一个小冲突/日常场景（如被打断、遇到麻烦、别人求助），让人物的第一反应直接暴露性格倾向（比如急躁的人会立刻反驳，温和的人会先倾听）。  \n2. **第二句：深化行为，补“细节支撑”**  \n   用带“动作感”的对话（比如“把文件放我桌上，十分钟后要”而非“你快点交文件”），让性格从“倾向”变成“可感知的行为”。  \n3. **第三句：收尾态度，定“性格底色”**  \n   用一句话巩固核心性格，甚至带点“小延伸”（比如吝啬的人不仅讨价还价，还会蹭小便宜），让人物更立体。",
            "images": [],
            "timestamp": "2025-10-05T15:28:01.311Z",
            "pinned": false,
            "comments": [],
            "tags": [],
            "type": "text"
          }
        ]
      }
    },
    {
      "id": "39104af1-1895-4273-b7e4-c7f256961722",
      "type": "multi",
      "titleAlign": "center",
      "tabTitle": "命令搜索器1",
      "maxWidthRatio": -1,
      "showBorder": false,
      "showShadow": false,
      "createAt": "2025-08-14T14:38:41.601Z",
      "updateAt": "2026-01-10T02:31:31.549Z",
      "components": [
        {
          "componentId": "d538eca9-d0ee-4ea4-9584-701202813a65"
        }
      ],
      "layoutType": "column",
      "locked": true,
      "layoutOptions": {}
    },
    {
      "id": "d538eca9-d0ee-4ea4-9584-701202813a65",
      "type": "custom",
      "titleAlign": "center",
      "tabTitle": "custom",
      "maxWidthRatio": -1,
      "showBorder": false,
      "showShadow": false,
      "createAt": "2025-08-14T14:39:08.296Z",
      "updateAt": "2025-11-03T08:56:03.509Z",
      "viewCode": "function App() {\n  const app = useObsidianApp();\n  const { getData, saveData } = useDataStorage();\n\n  // 获取设置数据\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const pluginQuery = settings.pluginQuery || \"\";\n  const showAllWhenEmpty = settings.showAllWhenEmpty !== false; // 默认为 true\n\n  // 状态管理\n  const [searchTerm, setSearchTerm] = useState(pluginQuery);\n  const [commands, setCommands] = useState([]);\n  const [groupedCommands, setGroupedCommands] = useState({});\n  const [filteredGroupedCommands, setFilteredGroupedCommands] = useState({});\n  const [collapsedPlugins, setCollapsedPlugins] = useState(new Set());\n\n  // 复制到剪贴板的函数\n  const copyToClipboard = useCallback((text) => {\n    const el = document.createElement('textarea');\n    el.value = text;\n    document.body.appendChild(el);\n    el.select();\n    document.execCommand('copy');\n    document.body.removeChild(el);\n    \n    // 使用 Obsidian 的 Notice\n    new Obsidian.Notice(`已复制: ${text}`);\n  }, []);\n\n  // 获取命令数据\n  const getCommandData = useCallback(() => {\n    if (!app?.commands?.commands) return [];\n    \n    return Object.keys(app.commands.commands).map(commandId => {\n      const command = app.commands.commands[commandId];\n      const pluginName = commandId.split(':')[0];\n      return {\n        id: commandId,\n        name: command.name,\n        plugin: pluginName\n      };\n    });\n  }, [app]);\n\n  // 分组命令\n  const groupCommands = useCallback((commandList) => {\n    return commandList.reduce((acc, cmd) => {\n      if (!acc[cmd.plugin]) {\n        acc[cmd.plugin] = [];\n      }\n      acc[cmd.plugin].push(cmd);\n      return acc;\n    }, {});\n  }, []);\n\n  // 过滤命令\n  const filterCommands = useCallback((grouped, query) => {\n    if (!query) {\n      return showAllWhenEmpty ? grouped : {};\n    }\n    \n    const lowerQuery = query.toLowerCase();\n    const filtered = {};\n    \n    Object.entries(grouped).forEach(([plugin, cmds]) => {\n      // 检查插件名称是否匹配\n      const pluginMatches = plugin.toLowerCase().includes(lowerQuery);\n      \n      // 检查命令名称或ID是否匹配\n      const matchingCmds = cmds.filter(cmd => \n        cmd.name.toLowerCase().includes(lowerQuery) || \n        cmd.id.toLowerCase().includes(lowerQuery)\n      );\n      \n      // 如果插件名匹配，显示所有命令；否则只显示匹配的命令\n      if (pluginMatches) {\n        filtered[plugin] = cmds;\n      } else if (matchingCmds.length > 0) {\n        filtered[plugin] = matchingCmds;\n      }\n    });\n    \n    return filtered;\n  }, [showAllWhenEmpty]);\n\n  // 初始化数据\n  useEffect(() => {\n    const commandList = getCommandData();\n    const grouped = groupCommands(commandList);\n    setCommands(commandList);\n    setGroupedCommands(grouped);\n  }, [getCommandData, groupCommands]);\n\n  // 当搜索词或分组数据变化时更新过滤结果\n  useEffect(() => {\n    const filtered = filterCommands(groupedCommands, searchTerm);\n    setFilteredGroupedCommands(filtered);\n  }, [groupedCommands, searchTerm, filterCommands]);\n\n  // 搜索处理\n  const handleSearch = useCallback((value) => {\n    setSearchTerm(value);\n    saveData({\n      ...data,\n      settings: {\n        ...settings,\n        pluginQuery: value\n      }\n    });\n  }, [data, settings, saveData]);\n\n  // 创建可点击的文本元素\n  const createClickableText = useCallback((text) => {\n    return (\n      <span \n        className=\"command-search--clickable-text\"\n        onClick={() => copyToClipboard(text)}\n        title=\"点击复制到剪贴板\"\n      >\n        {text}\n      </span>\n    );\n  }, [copyToClipboard]);\n\n  // 渲染命令表格\n  const renderCommandTable = useCallback((commands) => {\n    return (\n      <div className=\"command-search--table-container\">\n        <table className=\"command-search--table\">\n          <thead>\n            <tr>\n              <th className=\"command-search--id-column\">命令ID</th>\n              <th className=\"command-search--name-column\">命令名称</th>\n            </tr>\n          </thead>\n          <tbody>\n            {commands.map((cmd, index) => (\n              <tr key={`${cmd.id}-${index}`}>\n                <td className=\"command-search--id-column\">{createClickableText(cmd.id)}</td>\n                <td className=\"command-search--name-column\">{createClickableText(cmd.name)}</td>\n              </tr>\n            ))}\n          </tbody>\n        </table>\n      </div>\n    );\n  }, [createClickableText]);\n\n  // 刷新命令数据\n  const refreshCommands = useCallback(() => {\n    const commandList = getCommandData();\n    const grouped = groupCommands(commandList);\n    setCommands(commandList);\n    setGroupedCommands(grouped);\n  }, [getCommandData, groupCommands]);\n\n  // 切换插件折叠状态\n  const togglePluginCollapse = useCallback((pluginName) => {\n    setCollapsedPlugins(prev => {\n      const newSet = new Set(prev);\n      if (newSet.has(pluginName)) {\n        newSet.delete(pluginName);\n      } else {\n        newSet.add(pluginName);\n      }\n      return newSet;\n    });\n  }, []);\n\n  // 全部展开/折叠\n  const toggleAllPlugins = useCallback((collapse = true) => {\n    if (collapse) {\n      setCollapsedPlugins(new Set(Object.keys(filteredGroupedCommands)));\n    } else {\n      setCollapsedPlugins(new Set());\n    }\n  }, [filteredGroupedCommands]);\n\n  return (\n    <div className=\"command-search--container\">\n      {/* 控制栏 */}\n      <div className=\"command-search--table-toolbar\">\n        <div className=\"command-search--toolbar-left\">\n          <div className=\"command-search--search-section\">\n            <div className=\"command-search--search-box\">\n              <input\n                type=\"text\"\n                placeholder=\"搜索插件名称、命令名称或命令ID...\"\n                value={searchTerm}\n                onChange={(e) => handleSearch(e.target.value)}\n                className=\"command-search--search-input\"\n              />\n              {searchTerm && (\n                <button\n                  onClick={() => handleSearch(\"\")}\n                  className=\"command-search--clear-button\"\n                  title=\"清空搜索\"\n                >\n                  ✕\n                </button>\n              )}\n            </div>\n          </div>\n        </div>\n\n        <div className=\"command-search--toolbar-right\">\n          {Object.keys(filteredGroupedCommands).length > 1 && (\n            <div className=\"command-search--collapse-controls\">\n              <button\n                onClick={() => toggleAllPlugins(false)}\n                className=\"command-search--expand-all-button\"\n                title=\"展开所有插件\"\n              >\n                📂 全部展开\n              </button>\n              <button\n                onClick={() => toggleAllPlugins(true)}\n                className=\"command-search--collapse-all-button\"\n                title=\"折叠所有插件\"\n              >\n                📁 全部折叠\n              </button>\n            </div>\n          )}\n          \n          <button\n            onClick={refreshCommands}\n            className=\"command-search--refresh-button\"\n            title=\"刷新命令列表\"\n          >\n            <span className=\"command-search--refresh-icon\">🔄</span>\n            刷新\n          </button>\n        </div>\n      </div>\n\n      {/* 统计信息 */}\n      <div className=\"command-search--table-header\">\n        <div className=\"command-search--stats-info\">\n          <span className=\"command-search--stats-text\">\n            <strong>{Object.keys(filteredGroupedCommands).length}</strong> 个插件，\n            共 <strong>{Object.values(filteredGroupedCommands).flat().length}</strong> 条命令\n          </span>\n        </div>\n      </div>\n\n      {/* 内容区域 */}\n      <div className=\"command-search--table-container\">\n        {Object.keys(filteredGroupedCommands).length > 0 ? (\n          Object.entries(filteredGroupedCommands).map(([plugin, cmds]) => {\n            const isCollapsed = collapsedPlugins.has(plugin);\n            return (\n              <div key={plugin} className=\"command-search--plugin-section\">\n                <div \n                  className=\"command-search--plugin-header\"\n                  onClick={() => togglePluginCollapse(plugin)}\n                  title={isCollapsed ? \"点击展开\" : \"点击折叠\"}\n                >\n                  <span className=\"command-search--collapse-icon\">\n                    {isCollapsed ? \"▶\" : \"▼\"}\n                  </span>\n                  <span className=\"command-search--plugin-name\">{plugin}</span>\n                  <span className=\"command-search--command-count\">\n                    {cmds.length} 条命令\n                  </span>\n                </div>\n                {!isCollapsed && renderCommandTable(cmds)}\n              </div>\n            );\n          })\n        ) : (\n          <div className=\"command-search--empty-state\">\n            <span className=\"command-search--empty-icon\">🔍</span>\n            <h3>未找到命令</h3>\n            <p>\n              {searchTerm ? \n                `未找到匹配的内容: \"${searchTerm}\"` : \n                (showAllWhenEmpty ? '正在加载命令...' : '输入关键词来搜索插件名称、命令名称或命令ID')\n              }\n            </p>\n            {searchTerm && (\n              <button\n                onClick={() => handleSearch(\"\")}\n                className=\"command-search--show-all-button\"\n              >\n                显示所有命令\n              </button>\n            )}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}",
      "settingsCode": "function App() {\n  const { getData, saveData } = useDataStorage();\n  const data = getData() || {};\n  const settings = data.settings || {};\n\n  // 更新设置\n  const updateSettings = (newSettings) => {\n    saveData({\n      ...data,\n      settings: {\n        ...settings,\n        ...newSettings,\n      },\n    });\n  };\n\n  // 重置所有设置\n  const resetSettings = () => {\n    saveData({\n      ...data,\n      settings: {\n        pluginQuery: \"\",\n        showAllWhenEmpty: true\n      },\n    });\n  };\n\n  return (\n    <Settings>\n      <SettingTitle>搜索设置</SettingTitle>\n      \n      <SettingInput\n        label=\"默认搜索关键词\"\n        type=\"text\"\n        value={settings.pluginQuery || \"\"}\n        placeholder=\"输入插件名称、命令名称或命令ID...\"\n        onChange={(e) => {\n          updateSettings({\n            pluginQuery: e.target.value,\n          });\n        }}\n      />\n      \n      <SettingDescription>\n        设置默认搜索关键词，可以是插件名称、命令名称或命令ID，留空则不预设搜索条件\n      </SettingDescription>\n\n      <SettingDivider />\n\n      <SettingTitle>显示设置</SettingTitle>\n\n      <SettingItem label=\"搜索为空时显示所有命令\">\n        <input\n          type=\"checkbox\"\n          checked={settings.showAllWhenEmpty !== false}\n          onChange={(e) => {\n            updateSettings({\n              showAllWhenEmpty: e.target.checked,\n            });\n          }}\n        />\n      </SettingItem>\n\n      <SettingDescription>\n        当搜索框为空时，是否显示所有插件的命令。关闭此选项可以提高大型库的性能。\n      </SettingDescription>\n\n      <SettingDivider />\n\n      <SettingTitle>操作</SettingTitle>\n\n      <SettingItem label=\"重置设置\">\n        <button\n          onClick={resetSettings}\n          className=\"RH__CommandManager__settings-reset-button\"\n        >\n          重置为默认值\n        </button>\n      </SettingItem>\n\n      <SettingDescription>\n        将所有设置重置为默认值\n      </SettingDescription>\n\n      <SettingDivider />\n\n      <SettingTitle>使用说明</SettingTitle>\n      \n      <div className=\"RH__CommandManager__settings-usage-guide\">\n        <div className=\"RH__CommandManager__settings-usage-section\">\n          <div className=\"RH__CommandManager__settings-usage-title\">功能说明</div>\n          <ul className=\"RH__CommandManager__settings-usage-list\">\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                支持搜索插件名称、命令名称或命令ID\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                点击命令ID或命令名称可直接复制到剪贴板\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                支持模糊搜索，不区分大小写\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                显示每个插件的命令数量统计\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                当搜索命令名称时，会显示包含匹配命令的插件\n              </span>\n            </li>\n          </ul>\n        </div>\n\n        <div className=\"RH__CommandManager__settings-usage-section\">\n          <div className=\"RH__CommandManager__settings-usage-title\">使用技巧</div>\n          <ul className=\"RH__CommandManager__settings-usage-list\">\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                清空搜索框显示所有插件命令\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                使用刷新按钮获取最新的命令列表\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                复制的命令可在其他地方直接使用\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                搜索特定功能时可以输入相关的英文关键词\n              </span>\n            </li>\n          </ul>\n        </div>\n      </div>\n    </Settings>\n  );\n}\n",
      "cssCode": "/* 命令搜索器样式 - 与 snippets 管理器风格一致 */\n.command-search--container {\n  padding: 16px;\n  width: 100%;\n  margin: 0 auto;\n  background: var(--background-primary);\n  height: 75vh;\n  display: flex;\n  flex-direction: column;\n  box-sizing: border-box;\n  gap: 0;\n  position: relative;\n}\n\n/* 表格工具栏 */\n.command-search--table-toolbar {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 16px 20px;\n  background: var(--background-secondary);\n  border-radius: 12px 12px 0 0;\n  border: 1px solid var(--background-modifier-border);\n  border-bottom: none;\n  gap: 16px;\n  flex-wrap: wrap;\n}\n\n.command-search--toolbar-left {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  flex: 1;\n  min-width: 300px;\n}\n\n.command-search--toolbar-right {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  flex-shrink: 0;\n}\n\n/* 搜索框样式 */\n.command-search--search-section {\n  flex: 1;\n  max-width: 100%;\n}\n\n.command-search--search-box {\n  position: relative;\n  display: flex;\n  align-items: center;\n  background: var(--background-primary);\n  border-radius: 8px;\n  border: 1px solid var(--background-modifier-border);\n  transition: all 0.3s ease;\n}\n\n.command-search--search-box:focus-within {\n  border-color: var(--interactive-accent);\n  box-shadow: 0 0 0 2px rgba(var(--interactive-accent-rgb), 0.1);\n}\n\n.command-search--search-input {\n  width: 100%;\n  padding: 10px 40px 10px 12px;\n  border: none;\n  background: transparent;\n  color: var(--text-normal);\n  font-size: 14px;\n  outline: none;\n  border-radius: 8px;\n}\n\n.command-search--search-input::placeholder {\n  color: var(--text-muted);\n}\n\n.command-search--clear-button {\n  position: absolute;\n  right: 8px;\n  top: 50%;\n  transform: translateY(-50%);\n  background: var(--background-modifier-hover);\n  border: none;\n  border-radius: 50%;\n  width: 20px;\n  height: 20px;\n  color: var(--text-muted);\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 12px;\n  transition: all 0.2s ease;\n  z-index: 1;\n}\n\n.command-search--clear-button:hover {\n  background-color: var(--background-modifier-error-hover);\n  color: var(--text-error);\n  transform: translateY(-50%) scale(1.1);\n}\n\n/* 折叠控制 */\n.command-search--collapse-controls {\n  display: flex;\n  gap: 8px;\n  align-items: center;\n}\n\n.command-search--expand-all-button,\n.command-search--collapse-all-button {\n  padding: 8px 12px;\n  border: 1px solid var(--background-modifier-border);\n  border-radius: 6px;\n  background: var(--background-primary);\n  color: var(--text-normal);\n  cursor: pointer;\n  font-size: 12px;\n  font-weight: 500;\n  transition: all 0.3s ease;\n  white-space: nowrap;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n\n.command-search--expand-all-button:hover,\n.command-search--collapse-all-button:hover {\n  background-color: var(--interactive-hover);\n  border-color: var(--interactive-accent);\n  transform: translateY(-1px);\n}\n\n/* 刷新按钮 */\n.command-search--refresh-button {\n  background: var(--interactive-accent);\n  color: white;\n  border: none;\n  padding: 8px 12px;\n  border-radius: 6px;\n  font-weight: 500;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  font-size: 12px;\n  white-space: nowrap;\n}\n\n.command-search--refresh-button:hover {\n  background: var(--interactive-accent-hover);\n  transform: translateY(-1px);\n}\n\n.command-search--refresh-icon {\n  font-size: 12px;\n}\n\n/* 表格头部 */\n.command-search--table-header {\n  background: var(--background-secondary-alt);\n  padding: 12px 20px;\n  border-left: 1px solid var(--background-modifier-border);\n  border-right: 1px solid var(--background-modifier-border);\n  border-bottom: 1px solid var(--background-modifier-border);\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  flex-wrap: wrap;\n  gap: 16px;\n}\n\n.command-search--stats-info {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  color: var(--text-muted);\n  font-size: 13px;\n  flex-wrap: wrap;\n}\n\n.command-search--stats-text {\n  color: var(--text-normal);\n  font-weight: 500;\n}\n\n.command-search--stats-text strong {\n  color: var(--text-accent);\n  font-size: 14px;\n}\n\n/* 表格容器 */\n.command-search--table-container {\n  flex: 1;\n  overflow: auto;\n  border: 1px solid var(--background-modifier-border);\n  border-top: none;\n  border-radius: 0 0 12px 12px;\n  background: var(--background-primary);\n}\n\n/* 插件分组样式 - 重新设计以消除割裂感 */\n.command-search--plugin-section {\n  border-bottom: 1px solid var(--background-modifier-border);\n  transition: all 0.3s ease;\n}\n\n.command-search--plugin-section:last-child {\n  border-bottom: none;\n}\n\n.command-search--plugin-header {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 16px 20px;\n  background: var(--background-secondary);\n  border-bottom: 1px solid var(--background-modifier-border);\n  cursor: pointer;\n  transition: all 0.2s ease;\n  user-select: none;\n}\n\n.command-search--plugin-header:hover {\n  background: var(--background-secondary-alt);\n}\n\n.command-search--collapse-icon {\n  font-size: 0.8em;\n  color: var(--text-muted);\n  transition: transform 0.2s ease;\n  min-width: 16px;\n  text-align: center;\n}\n\n.command-search--plugin-name {\n  flex: 1;\n  font-weight: 600;\n  color: var(--text-normal);\n  font-size: 14px;\n}\n\n.command-search--command-count {\n  font-size: 12px;\n  font-weight: 400;\n  color: var(--text-muted);\n  background: var(--background-modifier-border);\n  padding: 4px 8px;\n  border-radius: 12px;\n}\n\n/* 表格样式 */\n.command-search--table {\n  width: 100%;\n  border-collapse: collapse;\n  table-layout: fixed;\n  font-size: 13px;\n  background: var(--background-primary);\n}\n\n.command-search--table th {\n  background: var(--background-secondary);\n  padding: 12px 16px;\n  text-align: left;\n  font-weight: 600;\n 