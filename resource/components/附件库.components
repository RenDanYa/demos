    },
    {
      "id": "9fad1bc8-0268-430e-821f-3d73db85469f",
      "type": "multi",
      "titleAlign": "center",
      "tabTitle": "快捷键",
      "maxWidthRatio": -1,
      "showBorder": false,
      "showShadow": false,
      "createAt": "2025-08-14T14:38:41.601Z",
      "updateAt": "2026-01-10T02:31:31.545Z",
      "components": [
        {
          "componentId": "5816909b-4b2b-47af-b583-c9cdc34e3a8c"
        }
      ],
      "layoutType": "column",
      "locked": true,
      "layoutOptions": {}
    },
    {
      "id": "5816909b-4b2b-47af-b583-c9cdc34e3a8c",
      "type": "custom",
      "titleAlign": "center",
      "tabTitle": "custom",
      "maxWidthRatio": -1,
      "showBorder": false,
      "showShadow": false,
      "createAt": "2025-08-14T14:39:08.296Z",
      "updateAt": "2025-11-06T01:04:03.592Z",
      "viewCode": "function App() {\n  const app = useObsidianApp();\n  const { getData, saveData } = useDataStorage();\n\n  // 获取设置数据\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const pluginQuery = settings.pluginQuery || \"\";\n  const showAllWhenEmpty = settings.showAllWhenEmpty !== false;\n\n  // 状态管理\n  const [searchTerm, setSearchTerm] = useState(pluginQuery);\n  const [hotkeys, setHotkeys] = useState([]);\n  const [groupedHotkeys, setGroupedHotkeys] = useState({});\n  const [filteredGroupedHotkeys, setFilteredGroupedHotkeys] = useState({});\n  const [collapsedPlugins, setCollapsedPlugins] = useState(new Set());\n  const [showHotkeyOnly, setShowHotkeyOnly] = useState(false);\n\n  // 复制到剪贴板的函数\n  const copyToClipboard = useCallback((text) => {\n    const el = document.createElement('textarea');\n    el.value = text;\n    document.body.appendChild(el);\n    el.select();\n    document.execCommand('copy');\n    document.body.removeChild(el);\n    \n    new Obsidian.Notice(`已复制: ${text}`);\n  }, []);\n\n  // 获取完整的快捷键数据（修复版本）\n  const getHotkeyData = useCallback(() => {\n    if (!app?.hotkeyManager) return [];\n    \n    const hotkeyList = [];\n    \n    try {\n      // 从 hotkeyManager 获取所有快捷键\n      const hotkeyMap = app.hotkeyManager.getHotkeys();\n      \n      // 遍历所有命令获取快捷键\n      const commands = app.commands.commands;\n      \n      Object.keys(commands).forEach(commandId => {\n        const command = commands[commandId];\n        if (!command) return;\n        \n        const pluginName = commandId.split(':')[0];\n        \n        // 获取该命令的快捷键\n        let commandHotkeys = [];\n        let isCustom = false;\n        \n        // 首先检查是否有自定义快捷键\n        if (app.hotkeyManager.customKeys && app.hotkeyManager.customKeys[commandId]) {\n          isCustom = true;\n          const customHotkeys = app.hotkeyManager.customKeys[commandId];\n          commandHotkeys = Array.isArray(customHotkeys) ? customHotkeys : [customHotkeys];\n        } \n        // 如果没有自定义快捷键，检查默认快捷键\n        else if (hotkeyMap && hotkeyMap[commandId]) {\n          commandHotkeys = Array.isArray(hotkeyMap[commandId]) \n            ? hotkeyMap[commandId] \n            : [hotkeyMap[commandId]];\n        }\n        // 最后检查默认快捷键映射\n        else if (app.hotkeyManager.defaultKeys && app.hotkeyManager.defaultKeys[commandId]) {\n          const defaultHotkeys = app.hotkeyManager.defaultKeys[commandId];\n          commandHotkeys = Array.isArray(defaultHotkeys) ? defaultHotkeys : [defaultHotkeys];\n        }\n        \n        hotkeyList.push({\n          id: commandId,\n          name: command.name,\n          plugin: pluginName,\n          hotkeys: commandHotkeys,\n          isCustom: isCustom,\n          hasHotkey: commandHotkeys.length > 0\n        });\n      });\n      \n    } catch (error) {\n      console.error(\"获取快捷键数据时出错:\", error);\n    }\n    \n    return hotkeyList;\n  }, [app]);\n\n  // 分组快捷键\n  const groupHotkeys = useCallback((hotkeyList) => {\n    return hotkeyList.reduce((acc, hotkey) => {\n      if (!acc[hotkey.plugin]) {\n        acc[hotkey.plugin] = [];\n      }\n      acc[hotkey.plugin].push(hotkey);\n      return acc;\n    }, {});\n  }, []);\n\n  // 格式化快捷键显示\n  const formatHotkey = useCallback((hotkeyArray) => {\n    if (!hotkeyArray || hotkeyArray.length === 0) {\n      return \"未设置\";\n    }\n    \n    return hotkeyArray.map(hotkey => {\n      if (typeof hotkey === 'string') {\n        return hotkey;\n      }\n      \n      // 处理对象格式的快捷键\n      const modifiers = hotkey.modifiers || [];\n      const key = hotkey.key || '';\n      \n      if (modifiers.length === 0 && !key) {\n        return \"未设置\";\n      }\n      \n      return [...modifiers, key].join('+');\n    }).join(' | ');\n  }, []);\n\n  // 过滤快捷键（修复版本）\n  const filterHotkeys = useCallback((grouped, query, hotkeyOnly = false) => {\n    let filtered = {};\n    \n    Object.entries(grouped).forEach(([plugin, items]) => {\n      let filteredItems = items;\n      \n      // 如果有查询词，先根据查询词过滤\n      if (query) {\n        const lowerQuery = query.toLowerCase();\n        filteredItems = items.filter(item => \n          item.name.toLowerCase().includes(lowerQuery) || \n          item.id.toLowerCase().includes(lowerQuery) ||\n          formatHotkey(item.hotkeys).toLowerCase().includes(lowerQuery) ||\n          plugin.toLowerCase().includes(lowerQuery)\n        );\n      }\n      \n      // 然后根据是否有快捷键过滤\n      if (hotkeyOnly) {\n        filteredItems = filteredItems.filter(item => item.hasHotkey);\n      }\n      \n      // 如果有结果，添加到过滤后的列表\n      if (filteredItems.length > 0) {\n        filtered[plugin] = filteredItems;\n      }\n    });\n    \n    return filtered;\n  }, [formatHotkey]);\n\n  // 初始化数据\n  useEffect(() => {\n    const hotkeyList = getHotkeyData();\n    const grouped = groupHotkeys(hotkeyList);\n    setHotkeys(hotkeyList);\n    setGroupedHotkeys(grouped);\n  }, [getHotkeyData, groupHotkeys]);\n\n  // 当搜索词、分组数据或筛选条件变化时更新过滤结果\n  useEffect(() => {\n    const filtered = filterHotkeys(groupedHotkeys, searchTerm, showHotkeyOnly);\n    setFilteredGroupedHotkeys(filtered);\n  }, [groupedHotkeys, searchTerm, showHotkeyOnly, filterHotkeys]);\n\n  // 搜索处理\n  const handleSearch = useCallback((value) => {\n    setSearchTerm(value);\n    saveData({\n      ...data,\n      settings: {\n        ...settings,\n        pluginQuery: value\n      }\n    });\n  }, [data, settings, saveData]);\n\n  // 切换仅显示有快捷键的命令\n  const toggleShowHotkeyOnly = useCallback((checked) => {\n    setShowHotkeyOnly(checked);\n  }, []);\n\n  // 创建可点击的文本元素\n  const createClickableText = useCallback((text) => {\n    return (\n      <span \n        className=\"hotkey-manager--clickable-text\"\n        onClick={() => copyToClipboard(text)}\n        title=\"点击复制到剪贴板\"\n      >\n        {text}\n      </span>\n    );\n  }, [copyToClipboard]);\n\n  // 渲染快捷键表格\n  const renderHotkeyTable = useCallback((hotkeys) => {\n    return (\n      <div className=\"hotkey-manager--table-container\">\n        <table className=\"hotkey-manager--table\">\n          <thead>\n            <tr>\n              <th className=\"hotkey-manager--id-column\">命令ID</th>\n              <th className=\"hotkey-manager--name-column\">命令名称</th>\n              <th className=\"hotkey-manager--hotkey-column\">快捷键</th>\n            </tr>\n          </thead>\n          <tbody>\n            {hotkeys.map((item, index) => (\n              <tr key={`${item.id}-${index}`} className={item.hasHotkey ? 'hotkey-manager--row-with-hotkey' : 'hotkey-manager--row-no-hotkey'}>\n                <td className=\"hotkey-manager--id-column\">\n                  {createClickableText(item.id)}\n                </td>\n                <td className=\"hotkey-manager--name-column\">\n                  {createClickableText(item.name)}\n                </td>\n                <td className=\"hotkey-manager--hotkey-column\">\n                  <span \n                    className={`hotkey-manager--hotkey-display ${item.hasHotkey ? 'hotkey-manager--hotkey-set' : 'hotkey-manager--hotkey-empty'}`}\n                    onClick={() => copyToClipboard(formatHotkey(item.hotkeys))}\n                    title=\"点击复制快捷键\"\n                  >\n                    {formatHotkey(item.hotkeys)}\n                  </span>\n                </td>\n              </tr>\n            ))}\n          </tbody>\n        </table>\n      </div>\n    );\n  }, [createClickableText, formatHotkey, copyToClipboard]);\n\n  // 刷新快捷键数据\n  const refreshHotkeys = useCallback(() => {\n    const hotkeyList = getHotkeyData();\n    const grouped = groupHotkeys(hotkeyList);\n    setHotkeys(hotkeyList);\n    setGroupedHotkeys(grouped);\n  }, [getHotkeyData, groupHotkeys]);\n\n  // 切换插件折叠状态\n  const togglePluginCollapse = useCallback((pluginName) => {\n    setCollapsedPlugins(prev => {\n      const newSet = new Set(prev);\n      if (newSet.has(pluginName)) {\n        newSet.delete(pluginName);\n      } else {\n        newSet.add(pluginName);\n      }\n      return newSet;\n    });\n  }, []);\n\n  // 全部展开/折叠\n  const toggleAllPlugins = useCallback((collapse = true) => {\n    if (collapse) {\n      setCollapsedPlugins(new Set(Object.keys(filteredGroupedHotkeys)));\n    } else {\n      setCollapsedPlugins(new Set());\n    }\n  }, [filteredGroupedHotkeys]);\n\n  // 计算统计信息\n  const stats = useMemo(() => {\n    const allCommands = Object.values(groupedHotkeys).flat();\n    const filteredCommands = Object.values(filteredGroupedHotkeys).flat();\n    \n    const totalCommands = filteredCommands.length;\n    const commandsWithHotkeys = filteredCommands.filter(item => item.hasHotkey).length;\n    const customHotkeys = filteredCommands.filter(item => item.isCustom).length;\n    \n    // 计算所有命令的统计（用于显示过滤效果）\n    const allCommandsWithHotkeys = allCommands.filter(item => item.hasHotkey).length;\n    const allCustomHotkeys = allCommands.filter(item => item.isCustom).length;\n    \n    return {\n      totalPlugins: Object.keys(filteredGroupedHotkeys).length,\n      totalCommands,\n      commandsWithHotkeys,\n      customHotkeys,\n      allCommandsWithHotkeys,\n      allCustomHotkeys\n    };\n  }, [filteredGroupedHotkeys, groupedHotkeys]);\n\n  return (\n    <div className=\"hotkey-manager--container\">\n      {/* 控制栏 */}\n      <div className=\"hotkey-manager--table-toolbar\">\n        <div className=\"hotkey-manager--toolbar-left\">\n          <div className=\"hotkey-manager--search-section\">\n            <div className=\"hotkey-manager--search-box\">\n              <input\n                type=\"text\"\n                placeholder=\"搜索插件名称、命令名称、命令ID或快捷键...\"\n                value={searchTerm}\n                onChange={(e) => handleSearch(e.target.value)}\n                className=\"hotkey-manager--search-input\"\n              />\n              {searchTerm && (\n                <button\n                  onClick={() => handleSearch(\"\")}\n                  className=\"hotkey-manager--clear-button\"\n                  title=\"清空搜索\"\n                >\n                  ✕\n                </button>\n              )}\n            </div>\n          </div>\n\n          {/* 筛选选项 */}\n          <div className=\"hotkey-manager--filter-section\">\n            <label className=\"hotkey-manager--filter-checkbox\">\n              <input\n                type=\"checkbox\"\n                checked={showHotkeyOnly}\n                onChange={(e) => toggleShowHotkeyOnly(e.target.checked)}\n              />\n              <span className=\"hotkey-manager--filter-label\">仅显示有快捷键的命令</span>\n            </label>\n          </div>\n        </div>\n\n        <div className=\"hotkey-manager--toolbar-right\">\n          <div className=\"hotkey-manager--action-buttons\">\n            <button\n              onClick={refreshHotkeys}\n              className=\"hotkey-manager--refresh-button\"\n              title=\"刷新快捷键列表\"\n            >\n              <span className=\"hotkey-manager--refresh-icon\">🔄</span>\n              刷新\n            </button>\n            \n            {Object.keys(filteredGroupedHotkeys).length > 1 && (\n              <div className=\"hotkey-manager--collapse-controls\">\n                <button\n                  onClick={() => toggleAllPlugins(false)}\n                  className=\"hotkey-manager--expand-all-button\"\n                  title=\"展开所有插件\"\n                >\n                  全部展开\n                </button>\n                <button\n                  onClick={() => toggleAllPlugins(true)}\n                  className=\"hotkey-manager--collapse-all-button\"\n                  title=\"折叠所有插件\"\n                >\n                  全部折叠\n                </button>\n              </div>\n            )}\n          </div>\n        </div>\n      </div>\n\n      {/* 统计信息 */}\n      <div className=\"hotkey-manager--table-header\">\n        <div className=\"hotkey-manager--stats-info\">\n          <span className=\"hotkey-manager--stats-text\">\n            <strong>{stats.totalPlugins}</strong> 个插件，\n            共 <strong>{stats.totalCommands}</strong> 条命令\n            {showHotkeyOnly && (\n              <span className=\"hotkey-manager--filter-indicator\">\n                （过滤前: {Object.values(groupedHotkeys).flat().length} 条）\n              </span>\n            )}\n          </span>\n          <span className=\"hotkey-manager--custom-count\">\n            有快捷键的命令: <strong>{showHotkeyOnly ? stats.commandsWithHotkeys : stats.allCommandsWithHotkeys}</strong>\n            {stats.allCustomHotkeys > 0 && (\n              <span> | 自定义快捷键: <strong>{stats.allCustomHotkeys}</strong></span>\n            )}\n            {showHotkeyOnly && <span className=\"hotkey-manager--filter-active\"> (已过滤)</span>}\n          </span>\n        </div>\n      </div>\n\n      {/* 内容区域 */}\n      <div className=\"hotkey-manager--table-content\">\n        {Object.keys(filteredGroupedHotkeys).length > 0 ? (\n          Object.entries(filteredGroupedHotkeys).map(([plugin, items]) => {\n            const isCollapsed = collapsedPlugins.has(plugin);\n            const pluginHasHotkeys = items.some(item => item.hasHotkey);\n            const hotkeyCount = items.filter(item => item.hasHotkey).length;\n            \n            return (\n              <div key={plugin} className=\"hotkey-manager--plugin-section\">\n                <div \n                  className={`hotkey-manager--plugin-header ${pluginHasHotkeys ? 'hotkey-manager--plugin-has-hotkeys' : 'hotkey-manager--plugin-no-hotkeys'}`}\n                  onClick={() => togglePluginCollapse(plugin)}\n                  title={isCollapsed ? \"点击展开\" : \"点击折叠\"}\n                >\n                  <span className=\"hotkey-manager--collapse-icon\">\n                    {isCollapsed ? \"▶\" : \"▼\"}\n                  </span>\n                  <span className=\"hotkey-manager--plugin-name\">{plugin}</span>\n                  <span className=\"hotkey-manager--command-count\">\n                    {items.length} 条命令\n                    {hotkeyCount > 0 && (\n                      <span className=\"hotkey-manager--plugin-hotkey-count\">\n                        ({hotkeyCount} 个有快捷键)\n                      </span>\n                    )}\n                  </span>\n                </div>\n                {!isCollapsed && renderHotkeyTable(items)}\n              </div>\n            );\n          })\n        ) : (\n          <div className=\"hotkey-manager--empty-state\">\n            <span className=\"hotkey-manager--empty-icon\">⌨️</span>\n            <h3>未找到快捷键</h3>\n            <p>\n              {searchTerm || showHotkeyOnly ? \n                `未找到匹配的内容${searchTerm ? `: \"${searchTerm}\"` : ''}${showHotkeyOnly ? ' (已启用\"仅显示有快捷键的命令\")' : ''}` : \n                (showAllWhenEmpty ? '正在加载快捷键...' : '输入关键词来搜索插件名称、命令名称、命令ID或快捷键')\n              }\n            </p>\n            {(searchTerm || showHotkeyOnly) && (\n              <button\n                onClick={() => {\n                  handleSearch(\"\");\n                  setShowHotkeyOnly(false);\n                }}\n                className=\"hotkey-manager--show-all-button\"\n              >\n                显示所有命令\n              </button>\n            )}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}",
      "settingsCode": "function App() {\n  const { getData, saveData } = useDataStorage();\n  const data = getData() || {};\n  const settings = data.settings || {};\n\n  // 更新设置\n  const updateSettings = (newSettings) => {\n    saveData({\n      ...data,\n      settings: {\n        ...settings,\n        ...newSettings,\n      },\n    });\n  };\n\n  // 重置所有设置\n  const resetSettings = () => {\n    saveData({\n      ...data,\n      settings: {\n        pluginQuery: \"\",\n        showAllWhenEmpty: true\n      },\n    });\n  };\n\n  return (\n    <Settings>\n      <SettingTitle>搜索设置</SettingTitle>\n      \n      <SettingInput\n        label=\"默认搜索关键词\"\n        type=\"text\"\n        value={settings.pluginQuery || \"\"}\n        placeholder=\"输入插件名称、命令名称或命令ID...\"\n        onChange={(e) => {\n          updateSettings({\n            pluginQuery: e.target.value,\n          });\n        }}\n      />\n      \n      <SettingDescription>\n        设置默认搜索关键词，可以是插件名称、命令名称或命令ID，留空则不预设搜索条件\n      </SettingDescription>\n\n      <SettingDivider />\n\n      <SettingTitle>显示设置</SettingTitle>\n\n      <SettingItem label=\"搜索为空时显示所有命令\">\n        <input\n          type=\"checkbox\"\n          checked={settings.showAllWhenEmpty !== false}\n          onChange={(e) => {\n            updateSettings({\n              showAllWhenEmpty: e.target.checked,\n            });\n          }}\n        />\n      </SettingItem>\n\n      <SettingDescription>\n        当搜索框为空时，是否显示所有插件的命令。关闭此选项可以提高大型库的性能。\n      </SettingDescription>\n\n      <SettingDivider />\n\n      <SettingTitle>操作</SettingTitle>\n\n      <SettingItem label=\"重置设置\">\n        <button\n          onClick={resetSettings}\n          className=\"RH__CommandManager__settings-reset-button\"\n        >\n          重置为默认值\n        </button>\n      </SettingItem>\n\n      <SettingDescription>\n        将所有设置重置为默认值\n      </SettingDescription>\n\n      <SettingDivider />\n\n      <SettingTitle>使用说明</SettingTitle>\n      \n      <div className=\"RH__CommandManager__settings-usage-guide\">\n        <div className=\"RH__CommandManager__settings-usage-section\">\n          <div className=\"RH__CommandManager__settings-usage-title\">功能说明</div>\n          <ul className=\"RH__CommandManager__settings-usage-list\">\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                支持搜索插件名称、命令名称或命令ID\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                点击命令ID或命令名称可直接复制到剪贴板\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                支持模糊搜索，不区分大小写\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                显示每个插件的命令数量统计\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                当搜索命令名称时，会显示包含匹配命令的插件\n              </span>\n            </li>\n          </ul>\n        </div>\n\n        <div className=\"RH__CommandManager__settings-usage-section\">\n          <div className=\"RH__CommandManager__settings-usage-title\">使用技巧</div>\n          <ul className=\"RH__CommandManager__settings-usage-list\">\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                清空搜索框显示所有插件命令\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                使用刷新按钮获取最新的命令列表\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                复制的命令可在其他地方直接使用\n              </span>\n            </li>\n            <li className=\"RH__CommandManager__settings-usage-item\">\n              <span className=\"RH__CommandManager__settings-usage-item-content\">\n                搜索特定功能时可以输入相关的英文关键词\n              </span>\n            </li>\n          </ul>\n        </div>\n      </div>\n    </Settings>\n  );\n}\n",
      "cssCode": "/* 优化右上角按钮布局 */\n.hotkey-manager--toolbar-right {\n  display: flex;\n  align-items: center;\n  flex-shrink: 0;\n}\n\n.hotkey-manager--action-buttons {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n/* 折叠控制按钮样式优化 */\n.hotkey-manager--collapse-controls {\n  display: flex;\n  gap: 8px;\n  align-items: center;\n}\n\n.hotkey-manager--expand-all-button,\n.hotkey-manager--collapse-all-button {\n  padding: 8px 12px;\n  border: 1px solid var(--background-modifier-border);\n  border-radius: 6px;\n  background: var(--background-primary);\n  color: var(--text-normal);\n  cursor: pointer;\n  font-size: 12px;\n  font-weight: 500;\n  transition: all 0.3s ease;\n  white-space: nowrap;\n}\n\n.hotkey-manager--expand-all-button:hover,\n.hotkey-manager--collapse-all-button:hover {\n  background-color: var(--interactive-hover);\n  border-color: var(--interactive-accent);\n}\n\n/* 刷新按钮样式优化 */\n.hotkey-manager--refresh-button {\n  background: var(--interactive-accent);\n  color: white;\n  border: none;\n  padding: 8px 12px;\n  border-radius: 6px;\n  font-weight: 500;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  font-size: 12px;\n  white-space: nowrap;\n}\n\n.hotkey-manager--refresh-button:hover {\n  background: var(--interactive-accent-hover);\n}\n\n.hotkey-manager--refresh-icon {\n  font-size: 12px;\n}\n\n/* 表格样式简化 - 移除类型列 */\n.hotkey-manager--table {\n  width: 100%;\n  border-collapse: collapse;\n  table-layout: fixed;\n  font-size: 13px;\n  background: var(--background-primary);\n}\n\n.hotkey-manager--id-column {\n  width: 40%;\n  min-width: 250px;\n}\n\n.hotkey-manager--name-column {\n  width: 35%;\n  min-width: 250px;\n}\n\n.hotkey-manager--hotkey-column {\n  width: 25%;\n  min-width: 150px;\n}\n\n/* 快捷键显示样式优化 - 移除自定义徽章 */\n.hotkey-manager--hotkey-display {\n  cursor: pointer;\n  transition: all 0.2s ease;\n  padding: 4px 8px;\n  border-radius: 4px;\n  display: inline-block;\n  word-break: break-word;\n  line-height: 1.4;\n  position: relative;\n}\n\n.hotkey-manager--hotkey-set {\n  background-color: rgba(var(--color-green-rgb), 0.1);\n  color: var(--color-green);\n  border: 1px solid rgba(var(--color-green-rgb), 0.2);\n}\n\n.hotkey-manager--hotkey-empty {\n  background-color: rgba(var(--color-gray-rgb), 0.1);\n  color: var(--text-muted);\n  border: 1px solid var(--background-modifier-border);\n}\n\n.hotkey-manager--hotkey-display:hover {\n  background-color: var(--interactive-hover);\n  transform: translateY(-1px);\n}\n\n/* 统计信息优化 */\n.hotkey-manager--custom-count {\n  color: var(--text-muted);\n  font-size: 13px;\n}\n\n.hotkey-manager--custom-count strong {\n  color: var(--text-accent);\n}\n\n.hotkey-manager--filter-active {\n  color: var(--color-orange);\n  font-weight: 600;\n}\n\n/* 插件头部优化 */\n.hotkey-manager--plugin-hotkey-count {\n  font-size: 11px;\n  color: var(--color-green);\n  margin-left: 8px;\n  font-weight: 500;\n}\n\n/* 工具栏布局优化 */\n.hotkey-manager--table-toolbar {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  padding: 16px 20px;\n  background: var(--background-secondary);\n  border-radius: 12px 12px 0 0;\n  border: 1px solid var(--background-modifier-border);\n  border-bottom: none;\n  gap: 16px;\n  flex-wrap: wrap;\n}\n\n.hotkey-manager--toolbar-left {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n  flex: 1;\n  min-width: 300px;\n}\n\n/* 响应式设计 */\n@media (max-width: 768px) {\n  .hotkey-manager--action-buttons {\n    flex-direction: column;\n    gap: 8px;\n    width: 100%;\n  }\n  \n  .hotkey-manager--collapse-controls {\n    width: 100%;\n    justify-content: center;\n  }\n  \n  .hotkey-manager--expand-all-button,\n  .hotkey-manager--collapse-all-button,\n  .hotkey-manager--refresh-button {\n    width: 100%;\n    justify-content: center;\n  }\n  \n  .hotkey-manager--toolbar-right {\n    width: 100%;\n  }\n}\n\n@media (max-width: 480px) {\n  .hotkey-manager--id-column {\n    width: 35%;\n    min-width: 120px;\n  }\n  \n  .hotkey-manager--name-column {\n    width: 40%;\n    min-width: 150px;\n  }\n  \n  .hotkey-manager--hotkey-column {\n    width: 25%;\n    min-width: 100px;\n  }\n}",
