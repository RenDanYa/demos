ks.map(task => ({\n        ...task,\n        id: `migrated-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`,\n        tags: [...new Set([...(task.tags || []), ...migrationTags])],\n        notePath: targetNotePath,\n        migratedFrom: sourceNote.path,\n        migratedAt: new Date().toISOString()\n      })).filter(newTask => !targetTasks.some(existingTask => existingTask.text === newTask.text && existingTask.priority === newTask.priority));\n      if (migratedTasks.length === 0) {\n        setMigrationStatus({\n          running: false,\n          progress: 0,\n          message: '',\n          currentStep: 0,\n          totalSteps: 0\n        });\n        setSuccess(`所有未完成待办都已存在于今日日记中`);\n        return {\n          migrated: 0,\n          total: uncompletedTasks.length\n        };\n      }\n      setMigrationStatus(prev => ({\n        ...prev,\n        progress: 80,\n        message: `正在保存 ${migratedTasks.length} 个待办到今日日记...`,\n        currentStep: 6\n      }));\n      await new Promise(resolve => setTimeout(resolve, 50));\n\n      // 合并任务并保存\n      const allTargetTasks = [...migratedTasks, ...targetTasks];\n      try {\n        await Markdowns.replaceContentUnderHeading(app, targetNotePath, {\n          heading: `# ${effectiveSection}`,\n          includeSubHeadings: true\n        }, convertTasksToMarkdown(allTargetTasks));\n      } catch (error) {\n        // 如果替换失败，尝试使用追加方式（理论上不会发生，因为标题已经确保存在）\n        console.warn('替换内容失败，尝试追加方式:', error);\n        const markdownContent = convertTasksToMarkdown(migratedTasks);\n        await Markdowns.appendContentUnderHeading(app, targetNotePath, {\n          heading: `# ${effectiveSection}`,\n          includeSubHeadings: true\n        }, `\\n${markdownContent}`);\n      }\n\n      // 清理源文件（如果设置允许）\n      if (!keepOriginalTasks && migratedTasks.length > 0) {\n        setMigrationStatus(prev => ({\n          ...prev,\n          progress: 90,\n          message: `正在清理源日记文件...`\n        }));\n        const remaining