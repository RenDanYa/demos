e-item\"\n  }, /*#__PURE__*/React.createElement(\"span\", {\n    className: \"RH__CommandManager__settings-usage-item-content\"\n  }, \"\\u4F7F\\u7528\\u5237\\u65B0\\u6309\\u94AE\\u83B7\\u53D6\\u6700\\u65B0\\u7684\\u547D\\u4EE4\\u5217\\u8868\")), /*#__PURE__*/React.createElement(\"li\", {\n    className: \"RH__CommandManager__settings-usage-item\"\n  }, /*#__PURE__*/React.createElement(\"span\", {\n    className: \"RH__CommandManager__settings-usage-item-content\"\n  }, \"\\u590D\\u5236\\u7684\\u547D\\u4EE4\\u53EF\\u5728\\u5176\\u4ED6\\u5730\\u65B9\\u76F4\\u63A5\\u4F7F\\u7528\")), /*#__PURE__*/React.createElement(\"li\", {\n    className: \"RH__CommandManager__settings-usage-item\"\n  }, /*#__PURE__*/React.createElement(\"span\", {\n    className: \"RH__CommandManager__settings-usage-item-content\"\n  }, \"\\u641C\\u7D22\\u7279\\u5B9A\\u529F\\u80FD\\u65F6\\u53EF\\u4EE5\\u8F93\\u5165\\u76F8\\u5173\\u7684\\u82F1\\u6587\\u5173\\u952E\\u8BCD\"))))));\n}",
