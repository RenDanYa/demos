    {
      "id": "a376e3ce-aa3b-415b-9f57-95077226721e",
      "type": "custom",
      "titleAlign": "center",
      "tabTitle": "TASKS",
      "maxWidthRatio": -1,
      "showBorder": false,
      "showTitle": true,
      "showShadow": false,
      "createAt": "2025-09-12T09:32:22.978Z",
      "updateAt": "2025-11-22T00:33:41.632Z",
      "viewCode": "function App() {\n    const { getData, saveData } = useDataStorage();\n    const app = useObsidianApp();\n    const [tasks, setTasks] = useState([]);\n    const [filter, setFilter] = useState('all');\n    const [newTaskText, setNewTaskText] = useState('');\n    const [newTaskDate, setNewTaskDate] = useState(new Date().toISOString().split('T')[0]);\n    const [loading, setLoading] = useState(false);\n    const [error, setError] = useState('');\n    const [success, setSuccess] = useState('');\n    const [searchQuery, setSearchQuery] = useState('');\n    const [editingTask, setEditingTask] = useState(null);\n    const [actionMenu, setActionMenu] = useState({ show: false, task: null, triggerElement: null });\n    const [showTagSuggestions, setShowTagSuggestions] = useState(false);\n    const [migrationStatus, setMigrationStatus] = useState({ \n        running: false, \n        progress: 0, \n        message: '',\n        currentStep: 0,\n        totalSteps: 0\n    });\n\n    const isInitializedRef = useRef(false);\n\n    const data = getData() || {};\n    const settings = data.settings || {};\n    const { \n        dailyNoteFolder = '',\n        dailyNoteSection = '待办',\n        autoFocus = true,\n        defaultTags = ['工作', '运动', '生活', '学习'],\n        templatePath = '',\n        cacheDays = 3,\n        futureDays = 7,\n        keepOriginalTasks = false,\n        migrationTags = ['迁移']\n    } = settings;\n\n    const allTags = [...new Set(tasks.flatMap(task => task.tags || []))];\n\n    // 日期工具函数\n    const dateUtils = useMemo(() => ({\n        getNotePathByDate: (dateStr = null) => {\n            const dateObj = dateStr ? new Date(dateStr) : new Date();\n            const year = dateObj.getFullYear();\n            const month = String(dateObj.getMonth() + 1).padStart(2, '0');\n            const day = String(dateObj.getDate()).padStart(2, '0');\n            const formattedDate = `${year}-${month}-${day}`;\n            const folder = dailyNoteFolder || '';\n            return folder ? `${folder}/${formattedDate}.md` : `${formattedDate}.md`;\n        },\n        \n        getDateFromNotePath: (notePath) => {\n            const fileName = notePath.split('/').pop().replace('.md', '');\n            return fileName;\n        },\n        \n        isToday: (dateStr) => {\n            const today = new Date().toISOString().split('T')[0];\n            return dateStr === today;\n        },\n        \n        isFutureDate: (dateStr) => {\n            const today = new Date().toISOString().split('T')[0];\n            return dateStr > today;\n        },\n        \n        isPastDate: (dateStr) => {\n            const today = new Date().toISOString().split('T')[0];\n            return dateStr < today;\n        },\n        \n        formatDisplayDate: (dateStr) => {\n            const date = new Date(dateStr);\n            const today = new Date();\n            const yesterday = new Date(today);\n            yesterday.setDate(yesterday.getDate() - 1);\n            const tomorrow = new Date(today);\n            tomorrow.setDate(tomorrow.getDate() + 1);\n            \n            if (date.toDateString() === today.toDateString()) {\n                return '今天';\n            } else if (date.toDateString() === yesterday.toDateString()) {\n                return '昨天';\n            } else if (date.toDateString() === tomorrow.toDateString()) {\n                return '明天';\n            } else {\n                return `${date.getMonth() + 1}月${date.getDate()}日`;\n            }\n        },\n        \n        getRecentDates: (pastDays = 3, futureDays = 7) => {\n            const dates = [];\n            for (let i = 0; i < pastDays; i++) {\n                const date = new Date();\n                date.setDate(date.getDate() - i);\n                const year = date.getFullYear();\n                const month = String(date.getMonth() + 1).padStart(2, '0');\n                const day = String(date.getDate()).padStart(2, '0');\n                dates.push(`${year}-${month}-${day}`);\n            }\n            for (let i = 1; i <= futureDays; i++) {\n                const date = new Date();\n                date.setDate(date.getDate() + i);\n                const year = date.getFullYear();\n                const month = String(date.getMonth() + 1).padStart(2, '0');\n                const day = String(date.getDate()).padStart(2, '0');\n                dates.push(`${year}-${month}-${day}`);\n            }\n            return dates;\n        }\n    }), [dailyNoteFolder]);\n\n    // 优化的日记文件确保逻辑 - 专门用于迁移功能\n    const ensureDailyNoteSectionForMigration = useCallback(async (notePath) => {\n        try {\n            let file = app.vault.getAbstractFileByPath(notePath);\n            let content = '';\n            \n            if (!file) {\n                if (templatePath) {\n                    try {\n                        file = await Files.createFileFromTemplate(app, notePath, templatePath);\n                        content = await app.vault.read(file);\n                    } catch (templateError) {\n                        console.warn('使用模板创建日记失败，创建空文件:', templateError);\n                        file = await Files.createFile(app, notePath, '');\n                        content = '';\n                    }\n                } else {\n                    file = await Files.createFile(app, notePath, '');\n                    content = '';\n                }\n            } else {\n                content = await app.vault.read(file);\n            }\n            \n            const effectiveSection = dailyNoteSection?.trim() || '待办';\n            const headingRegex = new RegExp(`^#\\\\s+${effectiveSection.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&')}\\\\s*$`, 'm');\n            const hasHeading = headingRegex.test(content);\n            \n            // 只有在没有标题时才创建标题\n            if (!hasHeading) {\n                const newContent = content.trim() + (content.trim() ? '\\n\\n' : '') + `# ${effectiveSection}\\n\\n`;\n                await app.vault.modify(file, newContent);\n                return { file, createdHeading: true };\n            }\n            \n            return { file, createdHeading: false };\n        } catch (error) {\n            console.error('确保日记文件存在失败:', error);\n            setError(`日记文件操作失败: ${error.message}`);\n            throw error;\n        }\n    }, [app, dailyNoteSection, templatePath]);\n\n    // 通用的日记文件确保逻辑\n    const ensureDailyNoteAndSection = useCallback(async (notePath) => {\n        try {\n            let file = app.vault.getAbstractFileByPath(notePath);\n            let content = '';\n            \n            if (!file) {\n                if (templatePath) {\n                    try {\n                        file = await Files.createFileFromTemplate(app, notePath, templatePath);\n                        content = await app.vault.read(file);\n                    } catch (templateError) {\n                        console.warn('使用模板创建日记失败，创建空文件:', templateError);\n                        file = await Files.createFile(app, notePath, '');\n                        content = '';\n                    }\n                } else {\n                    file = await Files.createFile(app, notePath, '');\n                    content = '';\n                }\n            } else {\n                content = await app.vault.read(file);\n            }\n            \n            const effectiveSection = dailyNoteSection?.trim() || '待办';\n            const headingRegex = new RegExp(`^#\\\\s+${effectiveSection.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&')}\\\\s*$`, 'm');\n            const hasHeading = headingRegex.test(content);\n            \n            if (!hasHeading) {\n                const newContent = content.trim() + (content.trim() ? '\\n\\n' : '') + `# ${effectiveSection}\\n\\n`;\n                await app.vault.modify(file, newContent);\n            }\n            \n            return true;\n        } catch (error) {\n            console.error('确保日记文件存在失败:', error);\n            setError(`日记文件操作失败: ${error.message}`);\n            return false;\n        }\n    }, [app, dailyNoteSection, templatePath]);\n\n    // 任务加载逻辑保持不变\n    const loadTasks = useCallback(async () => {\n        const effectiveSection = dailyNoteSection?.trim() || '待办';\n        if (!effectiveSection) {\n            setError('请先在设置中指定有效的日记标题');\n            return;\n        }\n        \n        setLoading(true);\n        setError('');\n        try {\n            const dailyNotes = await DailyNotes.getAllDailyNotes(app);\n            const allTasks = [];\n            const recentDates = dateUtils.getRecentDates(cacheDays, futureDays);\n            \n            const recentNotes = dailyNotes.filter(note => {\n                const noteDate = dateUtils.getDateFromNotePath(note.path);\n                return recentDates.includes(noteDate);\n            });\n\n            for (let i = 0; i < recentNotes.length; i++) {\n                const noteFile = recentNotes[i];\n                \n                if (i % 2 === 0 && i > 0) {\n                    await new Promise(resolve => setTimeout(resolve, 10));\n                }\n                \n                try {\n                    const noteDate = dateUtils.getDateFromNotePath(noteFile.path);\n                    \n                    const content = await Markdowns.readContentUnderHeading(\n                        app, \n                        noteFile.path, \n                        { \n                            heading: `# ${effectiveSection}`,\n                            includeSubHeadings: true \n                        }\n                    );\n                    \n                    if (content) {\n                        const parsedTasks = parseTasksFromMarkdown(content, noteFile.path);\n                        allTasks.push(...parsedTasks);\n                    }\n                } catch (error) {\n                    if (!error.message.includes('Heading not found')) {\n                        console.warn(`读取日记 ${noteFile.path} 失败:`, error);\n                    }\n                }\n            }\n            \n            setTasks(allTasks);\n        } catch (error) {\n            console.error('加载待办失败:', error);\n            setError(`加载失败: ${error.message}`);\n        } finally {\n            setLoading(false);\n        }\n    }, [app, dailyNoteSection, dateUtils, cacheDays, futureDays]);\n\n    // 任务保存逻辑保持不变\n    const saveTasksToNote = useCallback(async (notePath, updatedTasks) => {\n        try {\n            const markdownContent = convertTasksToMarkdown(updatedTasks);\n            const effectiveSection = dailyNoteSection?.trim() || '待办';\n            \n            await ensureDailyNoteAndSection(notePath);\n            \n            try {\n                await Markdowns.replaceContentUnderHeading(\n                    app,\n                    notePath,\n                    { \n                        heading: `# ${effectiveSection}`,\n                        includeSubHeadings: true \n                    },\n                    markdownContent\n                );\n                return true;\n            } catch (error) {\n                if (error.message.includes('Heading not found')) {\n                    const headingContent = `# ${effectiveSection}\\n\\n${markdownContent}`;\n                    await Markdowns.appendContent(app, notePath, `\\n\\n${headingContent}`);\n                    return true;\n                } else {\n                    throw error;\n                }\n            }\n        } catch (error) {\n            console.error('保存待办失败:', error);\n            throw error;\n        }\n    }, [app, dailyNoteSection, ensureDailyNoteAndSection]);\n\n    // 优化的迁移逻辑 - 核心改进部分\n    const migrateUncompletedTasks = useCallback(async (sourceDate = null) => {\n        if (migrationStatus.running) {\n            return { migrated: 0, total: 0 };\n        }\n\n        setMigrationStatus({ \n            running: true, \n            progress: 0, \n            message: '正在准备迁移...',\n            currentStep: 1,\n            totalSteps: 6\n        });\n        \n        await new Promise(resolve => setTimeout(resolve, 100));\n        \n        try {\n            const effectiveSection = dailyNoteSection?.trim() || '待办';\n            const today = new Date();\n            let sourceDateObj;\n            \n            if (sourceDate) {\n                sourceDateObj = new Date(sourceDate);\n            } else {\n                sourceDateObj = new Date(today);\n                sourceDateObj.setDate(sourceDateObj.getDate() - 1);\n            }\n            \n            const sourceDateStr = sourceDateObj.toISOString().split('T')[0];\n            const targetDateStr = today.toISOString().split('T')[0];\n            \n            setMigrationStatus(prev => ({ \n                ...prev, \n                progress: 20, \n                message: `正在查找 ${sourceDateStr} 的日记...`,\n                currentStep: 2\n            }));\n            \n            await new Promise(resolve => setTimeout(resolve, 50));\n            \n            const sourceNote = await DailyNotes.getDailyNote(app, sourceDateStr);\n            if (!sourceNote) {\n                setMigrationStatus({ running: false, progress: 0, message: '', currentStep: 0, totalSteps: 0 });\n                setSuccess(`未找到 ${sourceDateStr} 的日记文件，无需迁移`);\n                return { migrated: 0, total: 0 };\n            }\n            \n            setMigrationStatus(prev => ({ \n                ...prev, \n                progress: 40, \n                message: `正在读取 ${sourceDateStr} 的待办事项...`,\n                currentStep: 3\n            }));\n            \n            await new Promise(resolve => setTimeout(resolve, 50));\n            \n            let sourceTasks = [];\n            try {\n                const content = await Markdowns.readContentUnderHeading(\n                    app,\n                    sourceNote.path,\n                    {\n                        heading: `# ${effectiveSection}`,\n                        includeSubHeadings: true\n                    }\n                );\n                sourceTasks = parseTasksFromMarkdown(content, sourceNote.path);\n            } catch (error) {\n                if (!error.message.includes('Heading not found')) {\n                    throw error;\n                }\n                sourceTasks = [];\n            }\n            \n            if (sourceTasks.length === 0) {\n                setMigrationStatus({ running: false, progress: 0, message: '', currentStep: 0, totalSteps: 0 });\n                setSuccess(`${sourceDateStr} 没有待办事项`);\n                return { migrated: 0, total: 0 };\n            }\n            \n            const uncompletedTasks = sourceTasks.filter(task => !task.completed);\n            \n            if (uncompletedTasks.length === 0) {\n                setMigrationStatus({ running: false, progress: 0, message: '', currentStep: 0, totalSteps: 0 });\n                setSuccess(`${sourceDateStr} 没有未完成的待办事项`);\n                return { migrated: 0, total: 0 };\n            }\n            \n            setMigrationStatus(prev => ({ \n                ...prev, \n                progress: 60, \n                message: `找到 ${uncompletedTasks.length} 个未完成待办，准备迁移...`,\n                currentStep: 4\n            }));\n            \n            await new Promise(resolve => setTimeout(resolve, 50));\n            \n            const targetNotePath = dateUtils.getNotePathByDate();\n            \n            setMigrationStatus(prev => ({ \n                ...prev, \n                progress: 70, \n                message: `正在检查今日日记的标题...`,\n                currentStep: 5\n            }));\n            \n            // 优化的关键部分：先确保标题存在，避免重复创建\n            const { createdHeading } = await ensureDailyNoteSectionForMigration(targetNotePath);\n            \n            if (createdHeading) {\n                setMigrationStatus(prev => ({ \n                    ...prev, \n                    message: `今日日记中创建了新的待办标题`\n                }));\n            }\n            \n            let targetTasks = [];\n            try {\n                const targetContent = await Markdowns.readContentUnderHeading(\n                    app,\n                    targetNotePath,\n                    {\n                        heading: `# ${effectiveSection}`,\n                        includeSubHeadings: true\n                    }\n                );\n                targetTasks = parseTasksFromMarkdown(targetContent, targetNotePath);\n            } catch (error) {\n                // 如果读取失败，说明标题确实不存在（虽然理论上不会发生，因为上面已经确保了）\n                console.warn('读取目标日记待办失败，使用空数组:', error);\n                targetTasks = [];\n            }\n            \n            // 创建迁移任务\n            const migratedTasks = uncompletedTasks\n                .map(task => ({\n                    ...task,\n                    id: `migrated-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`,\n                    tags: [...new Set([...(task.tags || []), ...migrationTags])],\n                    notePath: targetNotePath,\n                    migratedFrom: sourceNote.path,\n                    migratedAt: new Date().toISOString()\n                }))\n                .filter(newTask => \n                    !targetTasks.some(existingTask => \n                        existingTask.text === newTask.text && \n                        existingTask.priority === newTask.priority\n                    )\n                );\n            \n            if (migratedTasks.length === 0) {\n                setMigrationStatus({ running: false, progress: 0, message: '', currentStep: 0, totalSteps: 0 });\n                setSuccess(`所有未完成待办都已存在于今日日记中`);\n                return { migrated: 0, total: uncompletedTasks.length };\n            }\n            \n            setMigrationStatus(prev => ({ \n                ...prev, \n                progress: 80, \n                message: `正在保存 ${migratedTasks.length} 个待办到今日日记...`,\n                currentStep: 6\n            }));\n            \n            await new Promise(resolve => setTimeout(resolve, 50));\n            \n            // 合并任务并保存\n            const allTargetTasks = [...migratedTasks, ...targetTasks];\n            \n            try {\n                await Markdowns.replaceContentUnderHeading(\n                    app,\n                    targetNotePath,\n                    { \n                        heading: `# ${effectiveSection}`,\n                        includeSubHeadings: true \n                    },\n                    convertTasksToMarkdown(allTargetTasks)\n                );\n            } catch (error) {\n                // 如果替换失败，尝试使用追加方式（理论上不会发生，因为标题已经确保存在）\n                console.warn('替换内容失败，尝试追加方式:', error);\n                const markdownContent = convertTasksToMarkdown(migratedTasks);\n                await Markdowns.appendContentUnderHeading(\n                    app,\n                    targetNotePath,\n                    { \n                        heading: `# ${effectiveSection}`,\n                        includeSubHeadings: true \n                    },\n                    `\\n${markdownContent}`\n                );\n            }\n            \n            // 清理源文件（如果设置允许）\n            if (!keepOriginalTasks && migratedTasks.length > 0) {\n                setMigrationStatus(prev => ({ \n                    ...prev, \n                    progress: 90, \n                    message: `正在清理源日记文件...`\n                }));\n                \n                const remainingTasks = sourceTasks.filter(sourceTask => \n                    !migratedTasks.some(migratedTask => \n                        migratedTask.text === sourceTask.text &&\n                        migratedTask.priority === sourceTask.priority\n                    )\n                );\n                \n                if (remainingTasks.length > 0) {\n                    await saveTasksToNote(sourceNote.path, remainingTasks);\n                } else {\n                    // 如果没有剩余任务，清空该标题下的内容\n                    try {\n                        await Markdowns.replaceContentUnderHeading(\n                            app,\n                            sourceNote.path,\n                            { \n                                heading: `# ${effectiveSection}`,\n                                includeSubHeadings: true \n                            },\n                            '暂无待办'\n                        );\n                    } catch (error) {\n                        console.warn('清空源日记待办失败:', error);\n                    }\n                }\n            }\n            \n            setMigrationStatus({ running: false, progress: 100, message: '', currentStep: 0, totalSteps: 0 });\n            setSuccess(`成功将 ${migratedTasks.length} 个未完成待办迁移到今日日记`);\n            \n            // 重新加载任务列表\n            setTimeout(() => {\n                loadTasks();\n            }, 500);\n            \n            return { \n                migrated: migratedTasks.length, \n                total: uncompletedTasks.length \n            };\n            \n        } catch (error) {\n            console.error('迁移待办失败:', error);\n            setMigrationStatus({ running: false, progress: 0, message: '', currentStep: 0, totalSteps: 0 });\n            setError(`迁移失败: ${error.message}`);\n            return { migrated: 0, total: 0 };\n        }\n    }, [app, dailyNoteSection, dateUtils, saveTasksToNote, keepOriginalTasks, migrationTags, loadTasks, migrationStatus.running, ensureDailyNoteSectionForMigration]);\n\n    // 任务操作函数保持不变\n    const taskOperations = useMemo(() => ({\n        add: async () => {\n            if (!newTaskText.trim()) return false;\n                \n            const parsed = parseTaskMetadata(newTaskText);\n            const targetDate = newTaskDate || new Date().toISOString().split('T')[0];\n            const targetNotePath = dateUtils.getNotePathByDate(targetDate);\n            \n            const newTask = {\n                id: `task-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`,\n                text: parsed.text.trim(),\n                completed: false,\n                createdAt: new Date().toISOString(),\n                priority: parsed.priority || 'medium',\n                tags: parsed.tags || [],\n                notePath: targetNotePath,\n                startTime: null,\n                dueTime: null,\n                scheduledDate: targetDate\n            };\n            \n            const currentNoteTasks = tasks.filter(task => task.notePath === targetNotePath);\n            const updatedCurrentNoteTasks = [newTask, ...currentNoteTasks];\n            \n            try {\n                const success = await saveTasksToNote(targetNotePath, updatedCurrentNoteTasks);\n                \n                if (success) {\n                    const otherTasks = tasks.filter(task => task.notePath !== targetNotePath);\n                    setTasks([...updatedCurrentNoteTasks, ...otherTasks]);\n                    setNewTaskText('');\n                    setNewTaskDate(new Date().toISOString().split('T')[0]);\n                    return true;\n                } else {\n                    setError('添加待办失败：保存文件时出现问题');\n                    return false;\n                }\n            } catch (error) {\n                setError(`添加待办失败: ${error.message}`);\n                return false;\n            }\n        },\n\n        update: async (taskId, updates) => {\n            const taskToUpdate = tasks.find(task => task.id === taskId);\n            if (!taskToUpdate) return false;\n\n            const noteTasks = tasks.filter(task => task.notePath === taskToUpdate.notePath);\n            const updatedNoteTasks = noteTasks.map(task =>\n                task.id === taskId ? { ...task, ...updates } : task\n            );\n            \n            try {\n                const success = await saveTasksToNote(taskToUpdate.notePath, updatedNoteTasks);\n                \n                if (success) {\n                    const otherTasks = tasks.filter(task => task.notePath !== taskToUpdate.notePath);\n                    setTasks([...updatedNoteTasks, ...otherTasks]);\n                    setEditingTask(null);\n                    return true;\n                } else {\n                    setError('更新待办失败：保存文件时出现问题');\n                    return false;\n                }\n            } catch (error) {\n                setError(`更新待办失败: ${error.message}`);\n                return false;\n            }\n        },\n\n        delete: async (taskId) => {\n            const taskToDelete = tasks.find(task => task.id === taskId);\n            if (!taskToDelete) return false;\n\n            const noteTasks = tasks.filter(task => task.notePath === taskToDelete.notePath);\n            const updatedNoteTasks = noteTasks.filter(task => task.id !== taskId);\n            \n            try {\n                const success = await saveTasksToNote(taskToDelete.notePath, updatedNoteTasks);\n                \n                if (success) {\n                    const otherTasks = tasks.filter(task => task.notePath !== taskToDelete.notePath);\n                    setTasks([...updatedNoteTasks, ...otherTasks]);\n                    setActionMenu({ show: false, task: null, triggerElement: null });\n                    return true;\n                } else {\n                    setError('删除待办失败：保存文件时出现问题');\n                    return false;\n                }\n            } catch (error) {\n                setError(`删除待办失败: ${error.message}`);\n                return false;\n            }\n        },\n\n        toggle: async (taskId) => {\n            const task = tasks.find(t => t.id === taskId);\n            await taskOperations.update(taskId, { \n                completed: !task.completed,\n                completedAt: !task.completed ? new Date().toISOString() : null\n            });\n        }\n    }), [newTaskText, newTaskDate, tasks, saveTasksToNote, dateUtils]);\n\n    // 事件处理函数保持不变\n    const eventHandlers = useMemo(() => ({\n        handleActionButtonClick: (task, event) => {\n            event.stopPropagation();\n            setActionMenu({\n                show: true,\n                task: task,\n                triggerElement: event.currentTarget\n            });\n        },\n\n        closeActionMenu: () => {\n            setActionMenu({ show: false, task: null, triggerElement: null });\n        },\n\n        handleInputChange: (e) => {\n            const value = e.target.value;\n            setNewTaskText(value);\n            \n            const lastChar = value[value.length - 1];\n            if (lastChar === '#') {\n                setShowTagSuggestions(true);\n            } else {\n                setShowTagSuggestions(false);\n            }\n        },\n\n        handleKeyPress: (e) => {\n            if (e.key === 'Enter') {\n                taskOperations.add();\n            }\n        },\n\n        handleTagSelect: (tag) => {\n            const currentText = newTaskText;\n            const textWithoutHash = currentText.slice(0, -1);\n            const newText = textWithoutHash + `#${tag} `;\n            setNewTaskText(newText);\n            setShowTagSuggestions(false);\n            \n            setTimeout(() => {\n                const input = document.querySelector('.modern-todo--add-input');\n                if (input) {\n                    input.focus();\n                    input.setSelectionRange(newText.length, newText.length);\n                }\n            }, 0);\n        },\n\n        reloadAllTasks: async () => {\n            setLoading(true);\n            try {\n                const dailyNotes = await DailyNotes.getAllDailyNotes(app);\n                const allTasks = [];\n                \n                for (let i = 0; i < dailyNotes.length; i++) {\n                    const noteFile = dailyNotes[i];\n                    \n                    if (i % 5 === 0 && i > 0) {\n                        await new Promise(resolve => setTimeout(resolve, 10));\n                    }\n                    \n                    try {\n                        const effectiveSection = dailyNoteSection?.trim() || '待办';\n                        const content = await Markdowns.readContentUnderHeading(\n                            app, \n                            noteFile.path, \n                            { \n                                heading: `# ${effectiveSection}`,\n                                includeSubHeadings: true \n                            }\n                        );\n                        \n                        if (content) {\n                            const parsedTasks = parseTasksFromMarkdown(content, noteFile.path);\n                            allTasks.push(...parsedTasks);\n                        }\n                    } catch (error) {\n                        if (!error.message.includes('Heading not found')) {\n                            console.warn(`读取日记 ${noteFile.path} 失败:`, error);\n                        }\n                    }\n                }\n                \n                setTasks(allTasks);\n                new Notice('已重新加载所有待办数据');\n            } catch (error) {\n                console.error('重新加载待办失败:', error);\n                setError(`重新加载失败: ${error.message}`);\n            } finally {\n                setLoading(false);\n            }\n        }\n    }), [newTaskText, taskOperations, app, dailyNoteSection]);\n\n    // 初始化\n    useEffect(() => {\n        if (isInitializedRef.current) return;\n        \n        const initialize = async () => {\n            isInitializedRef.current = true;\n            await loadTasks();\n        };\n        \n        initialize();\n    }, [loadTasks]);\n\n    // 任务过滤和分组保持不变\n    const { filteredTasks, stats } = useMemo(() => {\n        const filtered = tasks.filter(task => {\n            const taskDate = dateUtils.getDateFromNotePath(task.notePath);\n            const isFuture = dateUtils.isFutureDate(taskDate);\n            \n            if (filter !== 'future' && isFuture) {\n                return false;\n            }\n            \n            if (filter === 'future' && !isFuture) {\n                return false;\n            }\n\n            let statusMatch = true;\n            if (filter !== 'future') {\n                switch (filter) {\n                    case 'active': statusMatch = !task.completed; break;\n                    case 'completed': statusMatch = task.completed; break;\n                    default: statusMatch = true;\n                }\n            }\n\n            const searchMatch = !searchQuery || \n                               task.text.toLowerCase().includes(searchQuery.toLowerCase()) ||\n                               task.tags?.some(tag => tag.toLowerCase().includes(searchQuery.toLowerCase()));\n\n            return statusMatch && searchMatch;\n        }, [tasks, filter, searchQuery, dateUtils]);\n\n        const stats = {\n            total: tasks.filter(t => !dateUtils.isFutureDate(dateUtils.getDateFromNotePath(t.notePath))).length,\n            completed: tasks.filter(t => t.completed && !dateUtils.isFutureDate(dateUtils.getDateFromNotePath(t.notePath))).length,\n            active: tasks.filter(t => !t.completed && !dateUtils.isFutureDate(dateUtils.getDateFromNotePath(t.notePath))).length,\n            future: tasks.filter(t => dateUtils.isFutureDate(dateUtils.getDateFromNotePath(t.notePath))).length\n        };\n\n        return { filteredTasks: filtered, stats };\n    }, [tasks, filter, searchQuery, dateUtils]);\n\n    const groupedTasks = useMemo(() => {\n        const groups = {};\n        \n        filteredTasks.forEach(task => {\n            const date = dateUtils.getDateFromNotePath(task.notePath);\n            if (!groups[date]) {\n                groups[date] = [];\n            }\n            groups[date].push(task);\n        });\n        \n        Object.keys(groups).forEach(date => {\n            groups[date].sort((a, b) => {\n                const priorityOrder = { high: 0, medium: 1, low: 2 };\n                return priorityOrder[a.priority] - priorityOrder[b.priority];\n            });\n        });\n        \n        if (filter === 'future') {\n            return Object.keys(groups)\n                .sort((a, b) => new Date(a) - new Date(b))\n                .map(date => ({\n                    date,\n                    displayDate: dateUtils.formatDisplayDate(date),\n                    isFuture: true,\n                    isToday: dateUtils.isToday(date),\n                    tasks: groups[date]\n                }));\n        } else {\n            return Object.keys(groups)\n                .sort((a, b) => {\n                    const aDate = new Date(a);\n                    const bDate = new Date(b);\n                    const today = new Date().toISOString().split('T')[0];\n                    \n                    if (a === today) return -1;\n                    if (b === today) return 1;\n                    \n                    return bDate - aDate;\n                })\n                .map(date => ({\n                    date,\n                    displayDate: dateUtils.formatDisplayDate(date),\n                    isFuture: dateUtils.isFutureDate(date),\n                    isToday: dateUtils.isToday(date),\n                    isPast: dateUtils.isPastDate(date),\n                    tasks: groups[date]\n                }));\n        }\n    }, [filteredTasks, filter, dateUtils]);\n\n    return (\n        <div className=\"modern-todo\">\n            {error && (\n                <div className=\"modern-todo--error\">\n                    <div className=\"modern-todo--error-content\">\n                        <span>{error}</span>\n                    </div>\n                    <button \n                        onClick={loadTasks}\n                        className=\"modern-todo--retry-btn\"\n                    >\n                        重试\n                    </button>\n                </div>\n            )}\n\n            {success && (\n                <div className=\"modern-todo--success\">\n                    <div className=\"modern-todo--success-content\">\n                        <span>{success}</span>\n                    </div>\n                    <button \n                        onClick={() => setSuccess('')}\n                        className=\"modern-todo--success-close\"\n                    >\n                        ×\n                    </button>\n                </div>\n            )}\n\n            {migrationStatus.running && (\n                <div className=\"modern-todo--migration-status\">\n                    <div className=\"modern-todo--migration-progress-container\">\n                        <div className=\"modern-todo--migration-progress\">\n                            <div \n                                className=\"modern-todo--migration-progress-bar\"\n                                style={{ width: `${migrationStatus.progress}%` }}\n                            ></div>\n                        </div>\n                        <div className=\"modern-todo--migration-steps\">\n                            步骤 {migrationStatus.currentStep}/{migrationStatus.totalSteps}\n                        </div>\n                    </div>\n                    <div className=\"modern-todo--migration-message\">\n                        <span>{migrationStatus.message}</span>\n                    </div>\n                </div>\n            )}\n\n            <div className=\"modern-todo--quick-add\">\n                <div className=\"modern-todo--add-container\">\n                    <input\n                        type=\"date\"\n                        value={newTaskDate}\n                        onChange={(e) => setNewTaskDate(e.target.value)}\n                        className=\"modern-todo--date-input\"\n                        min={new Date().toISOString().split('T')[0]}\n                        title=\"选择待办日期\"\n                    />\n                    <input\n                        type=\"text\"\n                        value={newTaskText}\n                        onChange={eventHandlers.handleInputChange}\n                        onKeyPress={eventHandlers.handleKeyPress}\n                        placeholder=\"添加新待办，输入#选择标签，支持 !优先级...（按回车添加）\"\n                        className=\"modern-todo--add-input\"\n                        autoFocus={autoFocus}\n                    />\n                    <button \n                        onClick={taskOperations.add}\n                        className=\"modern-todo--add-btn\"\n                        disabled={!newTaskText.trim()}\n                        title=\"添加待办\"\n                    >\n                        +\n                    </button>\n                </div>\n\n                {showTagSuggestions && (\n                    <TagSuggestions \n                        tags={[...defaultTags, ...allTags]}\n                        onSelect={eventHandlers.handleTagSelect}\n                        onClose={() => setShowTagSuggestions(false)}\n                    />\n                )}\n            </div>\n\n            <div className=\"modern-todo--filters\">\n                <div className=\"modern-todo--search-section\">\n                    <div className=\"modern-todo--search-box\">\n                        <input\n                            type=\"text\"\n                            value={searchQuery}\n                            onChange={(e) => setSearchQuery(e.target.value)}\n                            placeholder=\"搜索待办或标签...\"\n                            className=\"modern-todo--search-input\"\n                        />\n                        {searchQuery && (\n                            <button \n                                onClick={() => setSearchQuery('')}\n                                className=\"modern-todo--clear-search\"\n                            >\n                                ×\n                            </button>\n                        )}\n                    </div>\n                    \n                    <div className=\"modern-todo--action-buttons\">\n                        <button \n                            onClick={() => migrateUncompletedTasks()}\n                            className=\"modern-todo--migration-btn\"\n                            disabled={migrationStatus.running}\n                            title=\"将昨天未完成的待办移动到今天\"\n                        >\n                            {migrationStatus.running ? '迁移中...' : '迁移'}\n                        </button>\n                        \n                        <button \n                            onClick={eventHandlers.reloadAllTasks}\n                            className=\"modern-todo--reload-btn\"\n                            title=\"重新加载所有数据\"\n                        >\n                            加载\n                        </button>\n                    </div>\n                </div>\n            </div>\n\n            <main className=\"modern-todo--main\">\n                <div className=\"modern-todo--list-view\">\n                    <div className=\"modern-todo--view-filters\">\n                        <div className=\"modern-todo--filter-tabs\">\n                            <button \n                                className={`modern-todo--filter-tab ${filter === 'all' ? 'active' : ''}`}\n                                onClick={() => setFilter('all')}\n                            >\n                                <span>全部</span>\n                                <span className=\"modern-todo--filter-count\">{stats.total}</span>\n                            </button>\n                            <button \n                                className={`modern-todo--filter-tab ${filter === 'active' ? 'active' : ''}`}\n                                onClick={() => setFilter('active')}\n                            >\n                                <span>待办</span>\n                                <span className=\"modern-todo--filter-count\">{stats.active}</span>\n                            </button>\n                            <button \n                                className={`modern-todo--filter-tab ${filter === 'completed' ? 'active' : ''}`}\n                                onClick={() => setFilter('completed')}\n                            >\n                                <span>完成</span>\n                                <span className=\"modern-todo--filter-count\">{stats.completed}</span>\n                            </button>\n                            <button \n                                className={`modern-todo--filter-tab ${filter === 'future' ? 'active' : ''}`}\n                                onClick={() => setFilter('future')}\n                            >\n                                <span>未来</span>\n                                <span className=\"modern-todo--filter-count\">{stats.future}</span>\n                            </button>\n                        </div>\n                    </div>\n\n                    <div className=\"modern-todo--task-list\">\n                        {loading ? (\n                            <div className=\"modern-todo--loading\">\n                                <div className=\"modern-todo--spinner\"></div>\n                                <p>加载待办中...</p>\n                            </div>\n                        ) : groupedTasks.length === 0 ? (\n                            <div className=\"modern-todo--empty-state\">\n                                <div className=\"modern-todo--empty-illustration\">\n                                    {filter === 'future' ? '📅' : '✓'}\n                                </div>\n                                <h3>{\n                                    searchQuery \n                                        ? '没有找到匹配的待办' \n                                        : filter === 'future'\n                                        ? '还没有未来待办'\n                                        : '还没有待办事项'\n                                }</h3>\n                                <p>{\n                                    searchQuery \n                                        ? '尝试调整搜索条件' \n                                        : filter === 'future'\n                                        ? '添加未来日期的待办来规划日程'\n                                        : '在上方输入待办内容后按回车添加第一个待办吧！'\n                                }</p>\n                            </div>\n                        ) : (\n                            groupedTasks.map((group) => (\n                                <div key={group.date} className={`modern-todo--date-group ${group.isToday ? 'today' : ''}`}>\n                                    <div className=\"modern-todo--date-header\">\n                                        <h3 className=\"modern-todo--date-title\">\n                                            {group.displayDate}\n                                        </h3>\n                                        <span className=\"modern-todo--date-count\">{group.tasks.length} 项待办</span>\n                                    </div>\n                                    <div className=\"modern-todo--tasks-container\">\n                                        {group.tasks.map((task) => (\n                                            <TaskCard \n                                                key={task.id}\n                                                task={task}\n                                                onActionClick={eventHandlers.handleActionButtonClick}\n                                                onToggle={taskOperations.toggle}\n                                                actionMenu={actionMenu}\n                                                onCloseActionMenu={eventHandlers.closeActionMenu}\n                                                onEdit={(task) => {\n                                                    setEditingTask(task);\n                                                    eventHandlers.closeActionMenu();\n                                                }}\n                                                onDelete={taskOperations.delete}\n                                            />\n                                        ))}\n                                    </div>\n                                </div>\n                            ))\n                        )}\n                    </div>\n                </div>\n            </main>\n\n            {editingTask && (\n                <TaskEditModal\n                    task={editingTask}\n                    onSave={taskOperations.update}\n                    onClose={() => setEditingTask(null)}\n                    defaultTags={defaultTags}\n                />\n            )}\n        </div>\n    );\n}\n\n// 子组件保持不变\nfunction TagSuggestions({ tags, onSelect, onClose }) {\n    const menuRef = useRef(null);\n\n    useEffect(() => {\n        const handleClickOutside = (event) => {\n            if (menuRef.current && !menuRef.current.contains(event.target)) {\n                onClose();\n            }\n        };\n\n        document.addEventListener('mousedown', handleClickOutside);\n        return () => document.removeEventListener('mousedown', handleClickOutside);\n    }, [onClose]);\n\n    const uniqueTags = [...new Set(tags)].slice(0, 10);\n\n    return (\n        <div \n            ref={menuRef}\n            className=\"modern-todo--tag-suggestions\"\n        >\n            <div className=\"modern-todo--tag-suggestions-header\">\n                <span>选择标签</span>\n                <button onClick={onClose} className=\"modern-todo--tag-suggestions-close\">\n                    ×\n                </button>\n            </div>\n            \n            <div className=\"modern-todo--tag-suggestions-list\">\n                {uniqueTags.map(tag => (\n                    <button\n                        key={tag}\n                        onClick={() => onSelect(tag)}\n                        className=\"modern-todo--tag-suggestion-item\"\n                    >\n                        <span>#{tag}</span>\n                    </button>\n                ))}\n            </div>\n        </div>\n    );\n}\n\nfunction TaskCard({ task, onActionClick, onToggle, actionMenu, onCloseActionMenu, onEdit, onDelete }) {\n    const getPriorityColor = (priority) => {\n        switch (priority) {\n            case 'high': return 'var(--color-red)';\n            case 'medium': return 'var(--color-orange)';\n            case 'low': return 'var(--color-green)';\n            default: return 'var(--text-muted)';\n        }\n    };\n\n    const getPriorityText = (priority) => {\n        switch (priority) {\n            case 'high': return '高优先级';\n            case 'medium': return '中优先级'; \n            case 'low': return '低优先级';\n            default: return '无优先级';\n        }\n    };\n\n    const isCurrentTaskMenuOpen = actionMenu.show && actionMenu.task?.id === task.id;\n\n    return (\n        <div \n            className={`modern-todo--task-card ${task.completed ? 'completed' : ''} ${task.migratedFrom ? 'migrated' : ''}`}\n        >\n            {task.migratedFrom && (\n                <div className=\"modern-todo--migration-badge\">\n                    从昨日迁移\n                </div>\n            )}\n            \n            <div className=\"modern-todo--task-header\">\n                <div className=\"modern-todo--action-button-container\">\n                    <button \n                        onClick={(e) => onActionClick(task, e)}\n                        className=\"modern-todo--action-button\"\n                        title=\"点击查看操作选项\"\n                    >\n                        <div className=\"modern-todo--priority-indicator\">\n                            <div \n                                className=\"modern-todo--priority-dot\"\n                                style={{ backgroundColor: getPriorityColor(task.priority) }}\n                            ></div>\n                            <span className=\"modern-todo--priority-text\">\n                                {getPriorityText(task.priority)}\n                            </span>\n                        </div>\n                    </button>\n                    \n                    {isCurrentTaskMenuOpen && (\n                        <ActionMenu \n                            task={task}\n                            triggerElement={actionMenu.triggerElement}\n                            onEdit={onEdit}\n                            onToggle={onToggle}\n                            onDelete={onDelete}\n                            onClose={onCloseActionMenu}\n                        />\n                    )}\n                </div>\n                \n                <button \n                    onClick={() => onToggle(task.id)}\n                    className={`modern-todo--complete-btn ${task.completed ? 'completed' : ''}`}\n                >\n                    {task.completed ? '✓' : '○'}\n                </button>\n            </div>\n\n            <div className=\"modern-todo--task-content\">\n                <div className=\"modern-todo--task-text\">\n                    {task.text}\n                    {task.tags && task.tags.length > 0 && (\n                        <span className=\"modern-todo--task-tags-inline\">\n                            {' '}\n                            {task.tags.map(tag => `#${tag}`).join(' ')}\n                        </span>\n                    )}\n                </div>\n                \n                <div className=\"modern-todo--task-footer\">\n                    {task.startTime && (\n                        <span className=\"modern-todo--task-start\">\n                            开始: {task.startTime}\n                        </span>\n                    )}\n                    \n                    {task.dueTime && (\n                        <span className=\"modern-todo--task-due\">\n                            截止: {task.dueTime}\n                        </span>\n                    )}\n                </div>\n            </div>\n        </div>\n    );\n}\n\nfunction ActionMenu({ task, triggerElement, onEdit, onToggle, onDelete, onClose }) {\n    const menuRef = useRef(null);\n\n    useEffect(() => {\n        const handleClickOutside = (event) => {\n            if (menuRef.current && !menuRef.current.contains(event.target) && \n                !triggerElement.contains(event.target)) {\n                onClose();\n            }\n        };\n\n        document.addEventListener('mousedown', handleClickOutside);\n        return () => document.removeEventListener('mousedown', handleClickOutside);\n    }, [onClose, triggerElement]);\n\n    return (\n        <div \n            ref={menuRef}\n            className=\"modern-todo--action-menu modern-todo--action-menu-icons\"\n        >\n            <div className=\"modern-todo--action-menu-buttons\">\n                <button \n                    onClick={() => onToggle(task.id)} \n                    className=\"modern-todo--action-menu-icon complete\"\n                    title={task.completed ? \"标记未完成\" : \"标记完成\"}\n                >\n                    {task.completed ? '↶' : '✓'}\n                </button>\n                \n                <button \n                    onClick={() => onEdit(task)} \n                    className=\"modern-todo--action-menu-icon edit\"\n                    title=\"编辑待办\"\n                >\n                    ✎\n                </button>\n                \n                <button \n                    onClick={() => onDelete(task.id)} \n                    className=\"modern-todo--action-menu-icon delete\"\n                    title=\"删除待办\"\n                >\n                    ×\n                </button>\n            </div>\n        </div>\n    );\n}\n\nfunction TaskEditModal({ task, onSave, onClose, defaultTags }) {\n    const [formData, setFormData] = useState({\n        text: task.text,\n        priority: task.priority || 'medium',\n        tags: task.tags || [],\n        startTime: task.startTime || '',\n        dueTime: task.dueTime || ''\n    });\n    const [newTag, setNewTag] = useState('');\n\n    const handleSave = () => {\n        onSave(task.id, formData);\n    };\n\n    const addTag = () => {\n        if (newTag.trim() && !formData.tags.includes(newTag.trim())) {\n            setFormData(prev => ({\n                ...prev,\n                tags: [...prev.tags, newTag.trim()]\n            }));\n            setNewTag('');\n        }\n    };\n\n    const removeTag = (tagToRemove) => {\n        setFormData(prev => ({\n            ...prev,\n            tags: prev.tags.filter(tag => tag !== tagToRemove)\n        }));\n    };\n\n    return (\n        <div className=\"modern-todo--modal-overlay\" onClick={onClose}>\n            <div className=\"modern-todo--modal\" onClick={e => e.stopPropagation()}>\n                <div className=\"modern-todo--modal-header\">\n                    <h2>编辑待办</h2>\n                    <button onClick={onClose} className=\"modern-todo--modal-close\">\n                        ×\n                    </button>\n                </div>\n                \n                <div className=\"modern-todo--modal-body\">\n                    <div className=\"modern-todo--form-group\">\n                        <label>待办内容</label>\n                        <textarea\n                            value={formData.text}\n                            onChange={(e) => setFormData(prev => ({ ...prev, text: e.target.value }))}\n                            className=\"modern-todo--textarea\"\n                            rows=\"3\"\n                            placeholder=\"请输入待办描述...\"\n                        />\n                    </div>\n                    \n                    <div className=\"modern-todo--form-group\">\n                        <label>优先级</label>\n                        <div className=\"modern-todo--priority-buttons\">\n                            <button\n                                type=\"button\"\n                                className={`modern-todo--priority-btn ${formData.priority === 'high' ? 'active high' : ''}`}\n                                onClick={() => setFormData(prev => ({ ...prev, priority: 'high' }))}\n                            >\n                                高优先级\n                            </button>\n                            <button\n                                type=\"button\"\n                                className={`modern-todo--priority-btn ${formData.priority === 'medium' ? 'active medium' : ''}`}\n                                onClick={() => setFormData(prev => ({ ...prev, priority: 'medium' }))}\n                            >\n                                中优先级\n                            </button>\n                            <button\n                                type=\"button\"\n                                className={`modern-todo--priority-btn ${formData.priority === 'low' ? 'active low' : ''}`}\n                                onClick={() => setFormData(prev => ({ ...prev, priority: 'low' }))}\n                            >\n                                低优先级\n                            </button>\n                        </div>\n                    </div>\n                    \n                    <div className=\"modern-todo--form-group\">\n                        <label>标签</label>\n                        <div className=\"modern-todo--tag-input-group\">\n                            <input\n                                type=\"text\"\n                                value={newTag}\n                                onChange={(e) => setNewTag(e.target.value)}\n                                onKeyPress={(e) => e.key === 'Enter' && addTag()}\n                                placeholder=\"输入标签...\"\n                                className=\"modern-todo--input\"\n                            />\n                            <button onClick={addTag} className=\"modern-todo--add-tag-btn\">\n                                +\n                            </button>\n                        </div>\n                        <div className=\"modern-todo--quick-tags\">\n                            {defaultTags.map(tag => (\n                                <button\n                                    key={tag}\n                                    type=\"button\"\n                                    onClick={() => {\n                                        if (!formData.tags.includes(tag)) {\n                                            setFormData(prev => ({\n                                                ...prev,\n                                                tags: [...prev.tags, tag]\n                                            }));\n                                        }\n                                    }}\n                                    className=\"modern-todo--quick-tag\"\n                                >\n                                    #{tag}\n                                </button>\n                            ))}\n                        </div>\n                        <div className=\"modern-todo--tags-list\">\n                            {formData.tags.map(tag => (\n                                <span key={tag} className=\"modern-todo--tag\">\n                                    #{tag}\n                                    <button onClick={() => removeTag(tag)} className=\"modern-todo--remove-tag\">\n                                        ×\n                                    </button>\n                                </span>\n                            ))}\n                        </div>\n                    </div>\n                    \n                    <div className=\"modern-todo--form-row\">\n                        <div className=\"modern-todo--form-group\">\n                            <label>开始时间</label>\n                            <input\n                                type=\"time\"\n                                value={formData.startTime}\n                                onChange={(e) => setFormData(prev => ({ ...prev, startTime: e.target.value }))}\n                                className=\"modern-todo--input\"\n                            />\n                        </div>\n                        \n                        <div className=\"modern-todo--form-group\">\n                            <label>截止时间</label>\n                            <input\n                                type=\"time\"\n                                value={formData.dueTime}\n                                onChange={(e) => setFormData(prev => ({ ...prev, dueTime: e.target.value }))}\n                                className=\"modern-todo--input\"\n                            />\n                        </div>\n                    </div>\n                </div>\n                \n                <div className=\"modern-todo--modal-footer\">\n                    <button onClick={onClose} className=\"modern-todo--cancel-btn\">\n                        取消\n                    </button>\n                    <button onClick={handleSave} className=\"modern-todo--save-btn\">\n                        保存更改\n                    </button>\n                </div>\n            </div>\n        </div>\n    );\n}\n\n// 工具函数保持不变\nfunction parseTasksFromMarkdown(content, notePath) {\n    if (!content) return [];\n    \n    const lines = content.split('\\n').filter(line => line.trim());\n    const tasks = [];\n    \n    lines.forEach((line, index) => {\n        const taskMatch = line.match(/^[-*] \\[(.)\\] (.+)$/);\n        if (taskMatch) {\n            const [, status, text] = taskMatch;\n            const parsed = parseTaskMetadata(text.trim());\n            \n            tasks.push({\n                id: `task-${notePath}-${index}-${Date.now()}`,\n                text: parsed.text,\n                completed: status.toLowerCase() === 'x',\n                createdAt: new Date().toISOString(),\n                priority: parsed.priority || 'medium',\n                tags: parsed.tags || [],\n                notePath: notePath,\n                startTime: parsed.startTime || null,\n                dueTime: parsed.dueTime || null\n            });\n        }\n    });\n    \n    return tasks;\n}\n\nfunction parseTaskMetadata(text) {\n    const result = { text, tags: [] };\n    \n    const tagMatches = text.match(/#(\\w+)/g);\n    if (tagMatches) {\n        result.tags = tagMatches.map(tag => tag.slice(1));\n        result.text = result.text.replace(/#(\\w+)/g, '').trim();\n    }\n    \n    const priorityMatch = text.match(/!(高|中|低)/);\n    if (priorityMatch) {\n        result.priority = priorityMatch[1] === '高' ? 'high' : \n                         priorityMatch[1] === '中' ? 'medium' : 'low';\n        result.text = result.text.replace(/!(高|中|低)/, '').trim();\n    }\n    \n    const metadataMatch = text.match(/\\[([^\\]]+)\\]/);\n    if (metadataMatch) {\n        const metadataStr = metadataMatch[1];\n        result.text = result.text.replace(/\\[([^\\]]+)\\]/, '').trim();\n        \n        const keyValuePairs = [];\n        const regex = /(\\w+):([\\d:]+)/g;\n        let match;\n        \n        while ((match = regex.exec(metadataStr)) !== null) {\n            const key = match[1];\n            const value = match[2];\n            keyValuePairs.push({ key, value });\n        }\n        \n        keyValuePairs.forEach(({ key, value }) => {\n            if (key === 'start') {\n                result.startTime = formatTimeToHHMM(value);\n            } else if (key === 'due') {\n                result.dueTime = formatTimeToHHMM(value);\n            }\n        });\n    }\n    \n    return result;\n}\n\nfunction formatTimeToHHMM(timeStr) {\n    if (!timeStr) return '';\n    \n    const cleanTime = timeStr.replace(/[^\\d]/g, '');\n    \n    if (cleanTime.length === 4) {\n        return `${cleanTime.substring(0, 2)}:${cleanTime.substring(2, 4)}`;\n    } else if (cleanTime.length === 3) {\n        return `0${cleanTime.substring(0, 1)}:${cleanTime.substring(1, 3)}`;\n    } else if (cleanTime.length === 2) {\n        return `${cleanTime}:00`;\n    } else if (cleanTime.length === 1) {\n        return `0${cleanTime}:00`;\n    } else {\n        if (timeStr.includes(':')) {\n            const [hours, minutes] = timeStr.split(':');\n            return `${hours.padStart(2, '0')}:${(minutes || '00').padStart(2, '0')}`;\n        }\n        return timeStr;\n    }\n}\n\nfunction convertTasksToMarkdown(tasks) {\n    if (tasks.length === 0) {\n        return '暂无待办';\n    }\n    \n    return tasks.map(task => {\n        let text = task.text;\n        \n        if (task.tags && task.tags.length > 0) {\n            text += ' ' + task.tags.map(tag => `#${tag}`).join(' ');\n        }\n        \n        if (task.priority === 'high') {\n            text += ' !高';\n        } else if (task.priority === 'low') {\n            text += ' !低';\n        }\n        \n        const metadata = [];\n        if (task.startTime) {\n            metadata.push(`start:${task.startTime}`);\n        }\n        if (task.dueTime) {\n            metadata.push(`due:${task.dueTime}`);\n        }\n        \n        if (metadata.length > 0) {\n            text += ` [${metadata.join(' ')}]`;\n        }\n        \n        return `- [${task.completed ? 'x' : ' '}] ${text}`;\n    }).join('\\n');\n}",
      "settingsCode": "function App() {\n    const { getData, saveData } = useDataStorage();\n    const [settings, setSettings] = useState({});\n    const [isSaving, setIsSaving] = useState(false);\n    const app = useObsidianApp();\n\n    const saveTimeoutRef = useRef(null);\n\n    const isInitialized = useRef(false);\n    useEffect(() => {\n        if (isInitialized.current) return;\n        \n        const data = getData() || {};\n        setSettings(data.settings || {});\n        isInitialized.current = true;\n    }, [getData]);\n\n    // 优化的保存函数\n    const saveSettings = useCallback((newSettings) => {\n        if (isSaving) return;\n        \n        setIsSaving(true);\n        \n        if (saveTimeoutRef.current) {\n            clearTimeout(saveTimeoutRef.current);\n        }\n        \n        saveTimeoutRef.current = setTimeout(async () => {\n            try {\n                const data = getData() || {};\n                \n                if (newSettings.dailyNoteSection !== undefined) {\n                    const trimmedSection = newSettings.dailyNoteSection.trim();\n                    if (!trimmedSection) {\n                        newSettings.dailyNoteSection = '待办';\n                    }\n                }\n                \n                const updatedSettings = { ...data.settings, ...newSettings };\n                data.settings = updatedSettings;\n                \n                await saveData(data);\n                setSettings(updatedSettings);\n            } catch (error) {\n                console.error('保存设置失败:', error);\n            } finally {\n                setIsSaving(false);\n            }\n        }, 500);\n    }, [getData, saveData, isSaving]);\n\n    // 优化的模板文件获取\n    const getTemplateFiles = useCallback(() => {\n        try {\n            const files = app.vault.getMarkdownFiles();\n            return files.map(file => ({\n                id: file.path,\n                value: file.path,\n                label: file.name,\n                description: file.path\n            }));\n        } catch (error) {\n            console.error('获取模板文件失败:', error);\n            return [];\n        }\n    }, [app]);\n\n    // 优化的设置变化处理\n    const handleSettingChange = useCallback((key, value) => {\n        saveSettings({ [key]: value });\n    }, [saveSettings]);\n\n    const handleInputBlur = useCallback((key, value) => {\n        saveSettings({ [key]: value });\n    }, [saveSettings]);\n\n    return (\n        <Settings>\n            <SettingTitle>待办管理设置</SettingTitle>\n            \n            <SettingDescription>配置待办事项的存储位置和个性化设置</SettingDescription>\n\n            <SettingItem label=\"日记文件夹\">\n                <FolderSettingAutocomplete\n                    label=\"选择日记文件夹\"\n                    value={settings.dailyNoteFolder || ''}\n                    onChange={(value) => handleSettingChange('dailyNoteFolder', value)}\n                    placeholder=\"选择日记文件夹...\"\n                />\n                <SettingDescription>存储日记的文件夹路径，留空则保存在根目录</SettingDescription>\n            </SettingItem>\n\n            <SettingItem label=\"日记标题\">\n                <SettingInput\n                    type=\"text\"\n                    value={settings.dailyNoteSection || '待办'}\n                    placeholder=\"例如: 待办\"\n                    onChange={(e) => setSettings(prev => ({ ...prev, dailyNoteSection: e.target.value }))}\n                    onBlur={(e) => handleInputBlur('dailyNoteSection', e.target.value)}\n                />\n                <SettingDescription>在日记中用于识别待办列表的标题（将创建为一级标题 #）</SettingDescription>\n            </SettingItem>\n\n            <SettingDivider />\n\n            <SettingItem label=\"日记模板\">\n                <SettingAutocomplete\n                    label=\"选择模板文件\"\n                    value={settings.templatePath || ''}\n                    onChange={(value) => handleSettingChange('templatePath', value)}\n                    placeholder=\"选择日记模板...\"\n                    items={getTemplateFiles}\n                />\n                <SettingDescription>选择用于创建新日记的模板文件</SettingDescription>\n            </SettingItem>\n\n            <SettingDivider />\n\n            <SettingItem label=\"数据缓存天数\">\n                <SettingInput\n                    type=\"number\"\n                    value={settings.cacheDays || 3}\n                    min=\"1\"\n                    max=\"30\"\n                    onChange={(e) => setSettings(prev => ({ ...prev, cacheDays: parseInt(e.target.value) || 3 }))}\n                    onBlur={(e) => handleInputBlur('cacheDays', parseInt(e.target.value) || 3)}\n                />\n                <SettingDescription>设置加载最近几天的待办数据，提高加载性能</SettingDescription>\n            </SettingItem>\n\n            <SettingItem label=\"未来待办天数\">\n                <SettingInput\n                    type=\"number\"\n                    value={settings.futureDays || 7}\n                    min=\"1\"\n                    max=\"30\"\n                    onChange={(e) => setSettings(prev => ({ ...prev, futureDays: parseInt(e.target.value) || 7 }))}\n                    onBlur={(e) => handleInputBlur('futureDays', parseInt(e.target.value) || 7)}\n                />\n                <SettingDescription>设置加载未来几天的待办数据</SettingDescription>\n            </SettingItem>\n\n            <SettingDivider />\n\n            <SettingItem label=\"界面设置\">\n                <SettingSwitch\n                    label=\"自动聚焦到输入框\"\n                    value={settings.autoFocus !== undefined ? settings.autoFocus : true}\n                    onChange={(value) => handleSettingChange('autoFocus', value)}\n                />\n            </SettingItem>\n\n            <SettingDivider />\n\n            <SettingTitle>待办迁移设置</SettingTitle>\n            <SettingDescription>手动将前一天未完成的待办移动到今天的日记中</SettingDescription>\n\n            <SettingItem label=\"迁移后处理\">\n                <SettingSwitch\n                    label=\"保留原日记中的待办（仅复制）\"\n                    value={settings.keepOriginalTasks || false}\n                    onChange={(value) => handleSettingChange('keepOriginalTasks', value)}\n                />\n                <SettingDescription>启用后，原日记中的待办会保留；禁用则会删除已迁移的待办</SettingDescription>\n            </SettingItem>\n\n            <SettingItem label=\"迁移标签\">\n                <TagsManager \n                    tags={settings.migrationTags || ['迁移']}\n                    onSave={(migrationTags) => handleSettingChange('migrationTags', migrationTags)}\n                    placeholder=\"输入迁移标签...\"\n                />\n                <SettingDescription>为迁移的待办添加的标签，用于区分迁移的待办</SettingDescription>\n            </SettingItem>\n\n            <SettingDivider />\n\n            <SettingTitle>标签管理</SettingTitle>\n            <SettingDescription>管理常用的标签选项</SettingDescription>\n            <TagsManager \n                tags={settings.defaultTags || ['工作', '运动', '生活', '学习']}\n                onSave={(defaultTags) => handleSettingChange('defaultTags', defaultTags)}\n                placeholder=\"输入常用标签...\"\n            />\n        </Settings>\n    );\n}\n\nfunction TagsManager({ tags, onSave, placeholder = \"输入标签...\" }) {\n    const [newTag, setNewTag] = useState('');\n\n    const addTag = () => {\n        if (newTag.trim() && !tags.includes(newTag.trim())) {\n            onSave([...tags, newTag.trim()]);\n            setNewTag('');\n        }\n    };\n\n    const removeTag = (tagToRemove) => {\n        onSave(tags.filter(tag => tag !== tagToRemove));\n    };\n\n    return (\n        <div>\n            <div style={{ display: 'flex', gap: '0.5rem', marginBottom: '1rem' }}>\n                <SettingInput\n                    type=\"text\"\n                    value={newTag}\n                    onChange={(e) => setNewTag(e.target.value)}\n                    onKeyPress={(e) => e.key === 'Enter' && addTag()}\n                    placeholder={placeholder}\n                    style={{ flex: 1 }}\n                />\n                <button \n                    onClick={addTag}\n                    className=\"modern-todo--setting-add-btn\"\n                >\n                    添加\n                </button>\n            </div>\n            \n            <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.5rem' }}>\n                {tags.map(tag => (\n                    <div \n                        key={tag}\n                        className=\"modern-todo--setting-tag\"\n                    >\n                        <span>#{tag}</span>\n                        <button \n                            onClick={() => removeTag(tag)}\n                            className=\"modern-todo--setting-remove-btn\"\n                        >\n                            ×\n                        </button>\n                    </div>\n                ))}\n            </div>\n        </div>\n    );\n}",
      "cssCode": "/* 现代化待办管理组件样式 */\n.modern-todo {\n    --primary-color: var(--interactive-accent);\n    --primary-hover: var(--interactive-accent-hover);\n    --success-color: var(--color-green);\n    --warning-color: var(--color-orange);\n    --danger-color: var(--color-red);\n    --info-color: var(--color-blue);\n    \n    --text-primary: var(--text-normal);\n    --text-secondary: var(--text-muted);\n    --text-muted: var(--text-faint);\n    \n    --border-color: var(--background-modifier-border);\n    \n    --radius-sm: var(--radius-s);\n    --radius-md: var(--radius-m);\n    --radius-lg: var(--radius-l);\n    \n    font-family: var(--font-family);\n    line-height: 1;\n    color: var(--text-primary);\n    background: transparent !important;\n    max-width: 100%;\n    margin: 0 auto;\n    font-size: var(--font-size-normal);\n    \n    height: 100%;\n    max-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n}\n\n/* 布局样式 */\n.modern-todo--quick-add {\n    padding: 0.75rem 1rem 0.5rem;\n    background: transparent !important;\n    position: relative;\n    flex-shrink: 0;\n}\n\n.modern-todo--filters {\n    padding: 0.5rem 1rem;\n    background: transparent !important;\n    border-bottom: 1px solid var(--border-color);\n    flex-shrink: 0;\n}\n\n.modern-todo--main {\n    padding: 0 1rem 1rem;\n    max-width: 1200px;\n    margin: 0 auto;\n    background: transparent !important;\n    flex: 1;\n    overflow-y: auto;\n    min-height: 0;\n}\n\n/* 隐藏滚动条但保留功能 */\n.modern-todo--main::-webkit-scrollbar,\n.modern-todo--modal::-webkit-scrollbar,\n.modern-todo--tag-suggestions::-webkit-scrollbar {\n    display: none;\n    width: 0;\n    height: 0;\n    background: transparent;\n}\n\n.modern-todo--main,\n.modern-todo--modal,\n.modern-todo--tag-suggestions {\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n}\n\n/* 错误提示 */\n.modern-todo--error {\n    background: rgba(var(--color-red-rgb), 0.1);\n    border-radius: var(--radius-md);\n    margin: 0.5rem 1rem;\n    padding: 0.75rem;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    gap: 1rem;\n    flex-shrink: 0;\n}\n\n.modern-todo--error-content {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    color: var(--danger-color);\n    font-weight: 500;\n    font-size: 0.875rem;\n}\n\n.modern-todo--retry-btn {\n    padding: 0.5rem 0.875rem;\n    background: transparent !important;\n    color: var(--danger-color);\n    border-radius: var(--radius-sm);\n    font-size: 0.8125rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n}\n\n.modern-todo--retry-btn:hover {\n    background: var(--danger-color);\n    color: white;\n}\n\n/* 成功提示 */\n.modern-todo--success {\n    background: rgba(var(--color-green-rgb), 0.1);\n    border-radius: var(--radius-md);\n    margin: 0.5rem 1rem;\n    padding: 0.75rem;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    gap: 1rem;\n    flex-shrink: 0;\n    border: 1px solid rgba(var(--color-green-rgb), 0.2);\n}\n\n.modern-todo--success-content {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    color: var(--success-color);\n    font-weight: 500;\n    font-size: 0.875rem;\n}\n\n.modern-todo--success-close {\n    padding: 0.25rem;\n    background: transparent !important;\n    color: var(--success-color);\n    border-radius: var(--radius-sm);\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n    border: none;\n}\n\n.modern-todo--success-close:hover {\n    background: var(--success-color);\n    color: white;\n}\n\n/* 迁移状态提示 */\n.modern-todo--migration-status {\n    background: var(--background-primary);\n    border-radius: var(--radius-md);\n    margin: 0.5rem 1rem;\n    padding: 0.75rem;\n    border: 1px solid var(--border-color);\n    flex-shrink: 0;\n}\n\n.modern-todo--migration-progress-container {\n    margin-bottom: 0.5rem;\n}\n\n.modern-todo--migration-progress {\n    height: 4px;\n    background: var(--background-modifier-border);\n    border-radius: 2px;\n    overflow: hidden;\n    margin-bottom: 0.25rem;\n}\n\n.modern-todo--migration-progress-bar {\n    height: 100%;\n    background: linear-gradient(90deg, var(--color-blue), var(--color-cyan));\n    border-radius: 2px;\n    transition: width 0.3s ease;\n}\n\n.modern-todo--migration-steps {\n    font-size: 0.75rem;\n    color: var(--text-muted);\n    text-align: right;\n}\n\n.modern-todo--migration-message {\n    font-size: 0.875rem;\n    color: var(--text-secondary);\n    text-align: center;\n}\n\n/* 快速添加 - 日期选择器在左边，添加按钮在右边 */\n.modern-todo--add-container {\n    display: flex;\n    gap: 0.5rem;\n    max-width: 600px;\n    margin: 0 auto;\n    background: transparent !important;\n    border-radius: var(--radius-lg);\n    padding: 0.75rem;\n    align-items: center;\n}\n\n/* 日期选择器在左边 */\n.modern-todo--date-input {\n    padding: 0.75rem;\n    border: none;\n    background: transparent !important;\n    font-size: 0.875rem;\n    color: var(--text-primary);\n    outline: none;\n    border-radius: var(--radius-md);\n    min-width: 120px;\n    order: 1; /* 日期选择器在左侧 */\n}\n\n.modern-todo--add-input {\n    flex: 1;\n    border: none;\n    background: transparent !important;\n    font-size: 0.875rem;\n    color: var(--text-primary);\n    outline: none;\n    order: 2; /* 输入框在中间 */\n}\n\n.modern-todo--add-input::placeholder {\n    color: var(--text-muted);\n}\n\n/* 添加按钮在右边 */\n.modern-todo--add-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 30px;\n    height: 30px;\n    border: none;\n    background: var(--primary-color);\n    color: white;\n    border-radius: var(--radius-md);\n    font-size: 1.25rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n    order: 3; /* 添加按钮在右侧 */\n}\n\n.modern-todo--add-btn:hover:not(:disabled) {\n    background: var(--primary-hover);\n    transform: scale(1.05);\n}\n\n.modern-todo--add-btn:disabled {\n    background: var(--text-muted);\n    cursor: not-allowed;\n    opacity: 0.5;\n}\n\n/* 搜索和筛选栏 - 优化小屏布局 */\n.modern-todo--search-section {\n    display: flex;\n    align-items: center;\n    gap: 0.75rem;\n    max-width: 600px;\n    margin: 0 auto;\n}\n\n.modern-todo--search-box {\n    position: relative;\n    flex: 1;\n    max-width: 300px;\n}\n\n.modern-todo--search-input {\n    width: 100%;\n    padding: 0.6875rem 0.875rem;\n    border: none;\n    background: transparent !important;\n    border-radius: var(--radius-md);\n    font-size: 0.875rem;\n    color: var(--text-primary);\n    transition: all 0.15s ease;\n}\n\n.modern-todo--search-input:focus {\n    outline: none;\n}\n\n.modern-todo--clear-search {\n    position: absolute;\n    right: 0.75rem;\n    top: 50%;\n    transform: translateY(-50%);\n    border: none;\n    background: transparent !important;\n    color: var(--text-muted);\n    cursor: pointer;\n    padding: 0.25rem;\n    border-radius: var(--radius-sm);\n    box-shadow: none !important;\n}\n\n.modern-todo--clear-search:hover {\n    background: var(--background-modifier-hover);\n    color: var(--text-primary);\n}\n\n/* 迁移和加载按钮在同一行 */\n.modern-todo--action-buttons {\n    display: flex;\n    gap: 0.5rem;\n    align-items: center;\n}\n\n/* 迁移按钮样式统一为加载按钮样式 */\n.modern-todo--migration-btn {\n    padding: 0.6875rem 1rem;\n    border: none;\n    background: transparent !important;\n    color: var(--text-secondary);\n    border-radius: var(--radius-md);\n    font-size: 0.8125rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n    white-space: nowrap;\n}\n\n.modern-todo--migration-btn:hover:not(:disabled) {\n    color: var(--primary-color);\n}\n\n.modern-todo--migration-btn:disabled {\n    opacity: 0.5;\n    cursor: not-allowed;\n    color: var(--text-muted);\n}\n\n.modern-todo--reload-btn {\n    padding: 0.6875rem 1rem;\n    border: none;\n    background: transparent !important;\n    color: var(--text-secondary);\n    border-radius: var(--radius-md);\n    font-size: 0.8125rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n    white-space: nowrap;\n}\n\n.modern-todo--reload-btn:hover {\n    color: var(--primary-color);\n}\n\n/* 筛选器 */\n.modern-todo--view-filters {\n    margin-bottom: 1rem;\n    flex-shrink: 0;\n}\n\n.modern-todo--filter-tabs {\n    display: flex;\n    background: transparent !important;\n    border-radius: var(--radius-md);\n    padding: 1px;\n    flex-wrap: wrap;\n    gap: 0.25rem;\n}\n\n.modern-todo--filter-tab {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    padding: 0.75rem 1rem;\n    border: none;\n    background: transparent !important;\n    color: var(--text-secondary);\n    border-radius: var(--radius-l);\n    font-size: 0.8125rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n    flex: 1;\n    min-width: 0;\n    justify-content: center;\n}\n\n.modern-todo--filter-tab:hover {\n    color: var(--text-primary);\n    background: var(--background-modifier-hover);\n}\n\n.modern-todo--filter-tab.active {\n    background: var(--background-modifier-hover);\n    color: var(--primary-color);\n}\n\n.modern-todo--filter-count {\n    background: transparent !important;\n    color: var(--text-muted);\n    border-radius: 10px;\n    padding: 6px 6px;\n    font-size: 0.75rem;\n    font-weight: 600;\n    min-width: 18px;\n    text-align: center;\n    line-height: 0;\n}\n\n.modern-todo--filter-tab.active .modern-todo--filter-count {\n    background: var(--primary-color);\n    color: red;\n}\n\n/* 日期分组样式 */\n.modern-todo--date-group {\n    margin-bottom: 1.5rem;\n}\n\n.modern-todo--date-group.today {\n    border-left: 3px solid var(--color-green);\n    padding-left: 0.5rem;\n    margin-left: -0.5rem;\n}\n\n.modern-todo--date-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 0.875rem;\n    padding: 0.5rem 0;\n    border-bottom: 1px solid var(--border-color);\n    flex-wrap: wrap;\n    gap: 0.5rem;\n}\n\n.modern-todo--date-title {\n    font-size: 1rem;\n    font-weight: 600;\n    color: var(--text-primary);\n    margin: 0;\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n}\n\n.modern-todo--date-count {\n    font-size: 0.75rem;\n    color: var(--text-muted);\n    background: transparent !important;\n    padding: 0.25rem 0.5rem;\n    border-radius: var(--radius-sm);\n}\n\n.modern-todo--tasks-container {\n    display: flex;\n    flex-direction: column;\n    gap: 0.75rem;\n}\n\n/* 待办列表 */\n.modern-todo--task-list {\n    display: flex;\n    flex-direction: column;\n    gap: 1.25rem;\n}\n\n/* 待办卡片 */\n.modern-todo--task-card {\n    background: transparent !important;\n    border: none;\n    border-radius: 0;\n    padding: 0.3rem 0.2rem;\n    transition: all 0.2s ease;\n    cursor: pointer;\n    position: relative;\n    user-select: none;\n}\n\n.modern-todo--task-card:hover {\n    background: var(--background-modifier-hover) !important;\n    border-radius: var(--radius-md);\n}\n\n.modern-todo--task-card.completed {\n    opacity: 0.7;\n}\n\n.modern-todo--task-card.completed .modern-todo--task-text {\n    text-decoration: line-through;\n    color: var(--text-muted);\n}\n\n/* 迁移标识 */\n.modern-todo--task-card.migrated {\n    border-left: 3px solid var(--color-blue);\n}\n\n.modern-todo--migration-badge {\n    position: absolute;\n    top: 0.5rem;\n    right: 0.5rem;\n    background: rgba(var(--color-blue-rgb), 0.1);\n    color: var(--color-blue);\n    padding: 0.2rem 0.5rem;\n    border-radius: 10px;\n    font-size: 0.7rem;\n    font-weight: 600;\n}\n\n.modern-todo--task-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    margin-bottom: 0.75rem;\n}\n\n.modern-todo--action-button-container {\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    z-index: 1;\n}\n\n.modern-todo--action-button {\n    border: none;\n    background: transparent !important;\n    cursor: pointer;\n    padding: 0;\n    margin: 0;\n    box-shadow: none !important;\n    outline: none;\n}\n\n.modern-todo--priority-indicator {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    padding: 0.25rem 0.5rem;\n    border-radius: var(--radius-sm);\n    transition: all 0.15s ease;\n}\n\n.modern-todo--action-button:hover .modern-todo--priority-indicator {\n    background: var(--background-modifier-hover);\n}\n\n.modern-todo--priority-dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n}\n\n.modern-todo--priority-text {\n    font-size: 0.7rem;\n    font-weight: 600;\n    color: var(--text-secondary);\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n}\n\n.modern-todo--complete-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 28px;\n    height: 28px;\n    border: none;\n    background: transparent !important;\n    color: var(--text-muted);\n    border-radius: 50%;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    font-size: 16px;\n    box-shadow: none !important;\n}\n\n.modern-todo--complete-btn:hover {\n    background: var(--background-modifier-hover);\n    color: var(--success-color);\n}\n\n.modern-todo--complete-btn.completed {\n    color: var(--success-color);\n}\n\n.modern-todo--task-content {\n    flex: 1;\n}\n\n.modern-todo--task-text {\n    font-size: 0.875rem;\n    color: var(--text-primary);\n    line-height: 1.5;\n    margin-bottom: 0.5rem;\n    word-break: break-word;\n    overflow-wrap: break-word;\n}\n\n.modern-todo--task-tags-inline {\n    color: var(--text-secondary);\n    font-size: 0.875rem;\n}\n\n.modern-todo--task-footer {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    flex-wrap: wrap;\n    margin-top: 0.3rem;\n}\n\n.modern-todo--task-start,\n.modern-todo--task-due {\n    display: flex;\n    align-items: center;\n    gap: 0.25rem;\n    font-size: 0.75rem;\n    padding: 0.15rem 1rem;\n    background: var(--background-modifier-hover);\n    color: var(--text-secondary);\n    border-radius: 20px;\n    white-space: nowrap;\n}\n\n.modern-todo--task-start {\n    background: rgba(var(--color-blue-rgb), 0.1);\n    color: var(--color-blue);\n}\n\n.modern-todo--task-due {\n    background: rgba(var(--color-red-rgb), 0.1);\n    color: var(--color-red);\n}\n\n/* 操作菜单 */\n.modern-todo--action-menu-icons {\n    position: absolute;\n    top: 100%;\n    left: 0;\n    background: var(--background-primary) !important;\n    border: 1px solid var(--border-color);\n    border-radius: var(--radius-lg);\n    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1), 0 2px 8px rgba(0, 0, 0, 0.05);\n    padding: 0.5rem;\n    z-index: 2147483647;\n    overflow: hidden;\n    margin-top: 4px;\n    animation: modern-todo--menu-appear 0.15s ease-out;\n    backdrop-filter: none;\n    opacity: 1 !important;\n    min-width: auto;\n}\n\n.modern-todo--action-menu-buttons {\n    display: flex;\n    gap: 0.5rem;\n    align-items: center;\n    justify-content: center;\n}\n\n.modern-todo--action-menu-icon {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 36px;\n    height: 36px;\n    border: none;\n    background: transparent !important;\n    color: var(--text-primary);\n    border-radius: 50%;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n    font-size: 16px;\n    font-weight: bold;\n    position: relative;\n}\n\n.modern-todo--action-menu-icon:hover {\n    background: var(--background-modifier-hover) !important;\n    transform: scale(1.1);\n}\n\n.modern-todo--action-menu-icon.complete:hover {\n    background: var(--success-color) !important;\n    color: white;\n}\n\n.modern-todo--action-menu-icon.edit:hover {\n    background: var(--info-color) !important;\n    color: white;\n}\n\n.modern-todo--action-menu-icon.delete:hover {\n    background: var(--danger-color) !important;\n    color: white;\n}\n\n.modern-todo--action-menu-icons,\n.modern-todo--action-menu-icons * {\n    background: var(--background-primary) !important;\n    opacity: 1 !important;\n}\n\n@keyframes modern-todo--menu-appear {\n    from {\n        opacity: 0;\n        transform: translateY(-8px) scale(0.95);\n    }\n    to {\n        opacity: 1;\n        transform: translateY(0) scale(1);\n    }\n}\n\n/* 标签建议框 */\n.modern-todo--tag-suggestions {\n    position: absolute;\n    top: 100%;\n    left: 0;\n    right: 0;\n    background: var(--background-primary) !important;\n    border: 1px solid var(--border-color);\n    border-radius: var(--radius-md);\n    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.08);\n    min-width: 200px;\n    max-height: 200px;\n    overflow-y: auto;\n    z-index: 9999;\n    margin-top: 4px;\n    animation: modern-todo--menu-appear 0.15s ease-out;\n    backdrop-filter: none;\n    opacity: 1 !important;\n}\n\n.modern-todo--tag-suggestions,\n.modern-todo--tag-suggestions * {\n    background: var(--background-primary) !important;\n    opacity: 1 !important;\n}\n\n.modern-todo--tag-suggestions-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 0.75rem 1rem;\n    border-bottom: 1px solid var(--border-color);\n    background: var(--background-primary) !important;\n    font-size: 0.8125rem;\n    font-weight: 600;\n    color: var(--text-primary);\n}\n\n.modern-todo--tag-suggestions-close {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 20px;\n    height: 20px;\n    border: none;\n    background: transparent !important;\n    color: var(--text-muted);\n    border-radius: var(--radius-sm);\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n    font-size: 16px;\n}\n\n.modern-todo--tag-suggestions-close:hover {\n    background: var(--background-modifier-hover) !important;\n    color: var(--text-primary);\n}\n\n.modern-todo--tag-suggestions-list {\n    padding: 0.5rem;\n    background: var(--background-primary) !important;\n}\n\n.modern-todo--tag-suggestion-item {\n    display: flex;\n    align-items: center;\n    width: 100%;\n    padding: 0.75rem 0.875rem;\n    border: none;\n    background: var(--background-primary) !important;\n    color: var(--text-primary);\n    border-radius: var(--radius-sm);\n    font-size: 0.8125rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n    text-align: left;\n    margin: 0;\n    opacity: 1 !important;\n}\n\n.modern-todo--tag-suggestion-item:hover {\n    background: var(--background-modifier-hover) !important;\n    color: var(--primary-color);\n}\n\n/* 模态框 */\n.modern-todo--modal-overlay {\n    position: fixed;\n    top: 0;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    background: rgba(0, 0, 0, 0.4);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    z-index: 10000;\n    padding: 1rem;\n    backdrop-filter: blur(2px);\n}\n\n.modern-todo--modal {\n    background: var(--background-primary) !important;\n    border-radius: var(--radius-lg);\n    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);\n    max-width: 500px;\n    width: 90vw;\n    max-height: 85vh;\n    overflow-y: auto;\n    z-index: 10001;\n    position: relative;\n    margin: auto;\n}\n\n.modern-todo--modal-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 1.25rem 1.5rem 0;\n    margin-bottom: 1.25rem;\n    background: var(--background-primary) !important;\n}\n\n.modern-todo--modal-header h2 {\n    font-size: 1.125rem;\n    font-weight: 600;\n    color: var(--text-primary);\n    margin: 0;\n}\n\n.modern-todo--modal-close {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 30px;\n    height: 30px;\n    border: none;\n    background: transparent !important;\n    color: var(--text-muted);\n    border-radius: var(--radius-sm);\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n}\n\n.modern-todo--modal-close:hover {\n    background: var(--background-modifier-hover);\n    color: var(--text-primary);\n}\n\n.modern-todo--modal-body {\n    padding: 0 1.5rem;\n    background: var(--background-primary) !important;\n}\n\n.modern-todo--modal-footer {\n    display: flex;\n    justify-content: flex-end;\n    gap: 0.75rem;\n    padding: 1.25rem;\n    margin-top: 1.25rem;\n    border-top: 1px solid var(--border-color);\n    background: var(--background-primary) !important;\n}\n\n.modern-todo--cancel-btn {\n    padding: 0.75rem 1.25rem;\n    border: 1px solid var(--border-color);\n    background: transparent !important;\n    color: var(--text-primary);\n    border-radius: var(--radius-md);\n    font-size: 0.875rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n}\n\n.modern-todo--cancel-btn:hover {\n    border-color: var(--text-muted);\n}\n\n.modern-todo--save-btn {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    padding: 0.75rem 1.25rem;\n    border: none;\n    background: var(--primary-color);\n    color: white;\n    border-radius: var(--radius-md);\n    font-size: 0.875rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n}\n\n.modern-todo--save-btn:hover {\n    background: var(--primary-hover);\n}\n\n/* 表单元素 */\n.modern-todo--form-group {\n    margin-bottom: 1.25rem;\n}\n\n.modern-todo--form-row {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 1rem;\n}\n\n.modern-todo--form-group label {\n    display: block;\n    font-size: 0.875rem;\n    font-weight: 500;\n    color: var(--text-primary);\n    margin-bottom: 0.5rem;\n}\n\n.modern-todo--input,\n.modern-todo--textarea {\n    width: 100%;\n    padding: 0.75rem;\n    border: 1px solid var(--border-color);\n    background: transparent !important;\n    border-radius: var(--radius-md);\n    font-size: 0.875rem;\n    color: var(--text-primary);\n    transition: all 0.15s ease;\n}\n\n.modern-todo--input:focus,\n.modern-todo--textarea:focus {\n    outline: none;\n    border-color: var(--primary-color);\n}\n\n.modern-todo--textarea {\n    resize: vertical;\n    min-height: 80px;\n}\n\n.modern-todo--priority-buttons {\n    display: flex;\n    gap: 0.5rem;\n    flex-wrap: wrap;\n}\n\n.modern-todo--priority-btn {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    padding: 0.5rem 0.875rem;\n    border: 1px solid var(--border-color);\n    background: transparent !important;\n    color: var(--text-secondary);\n    border-radius: var(--radius-md);\n    font-size: 0.75rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    flex: 1;\n    min-width: 0;\n    justify-content: center;\n    box-shadow: none !important;\n}\n\n.modern-todo--priority-btn:hover {\n    border-color: var(--primary-color);\n    color: var(--primary-color);\n}\n\n.modern-todo--priority-btn.active {\n    border-color: var(--action-color);\n    background: var(--action-color);\n    color: white;\n}\n\n.modern-todo--priority-btn.active.high {\n    --action-color: var(--danger-color);\n}\n\n.modern-todo--priority-btn.active.medium {\n    --action-color: var(--warning-color);\n}\n\n.modern-todo--priority-btn.active.low {\n    --action-color: var(--success-color);\n}\n\n.modern-todo--tag-input-group {\n    display: flex;\n    gap: 0.5rem;\n    margin-bottom: 0.75rem;\n}\n\n.modern-todo--add-tag-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 38px;\n    border: 1px solid var(--border-color);\n    background: transparent !important;\n    color: var(--text-muted);\n    border-radius: var(--radius-md);\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n}\n\n.modern-todo--add-tag-btn:hover {\n    border-color: var(--primary-color);\n    color: var(--primary-color);\n}\n\n.modern-todo--quick-tags {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 0.5rem;\n    margin-bottom: 0.75rem;\n}\n\n.modern-todo--quick-tag {\n    padding: 0.375rem 0.75rem;\n    border: 1px solid var(--border-color);\n    background: transparent !important;\n    color: var(--text-secondary);\n    border-radius: 14px;\n    font-size: 0.75rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n}\n\n.modern-todo--quick-tag:hover {\n    border-color: var(--primary-color);\n    color: var(--primary-color);\n}\n\n.modern-todo--tags-list {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 0.5rem;\n}\n\n.modern-todo--tag {\n    display: flex;\n    align-items: center;\n    gap: 0.25rem;\n    padding: 0.375rem 0.75rem;\n    background: transparent !important;\n    color: var(--text-secondary);\n    border-radius: 14px;\n    font-size: 0.75rem;\n    font-weight: 500;\n}\n\n.modern-todo--remove-tag {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 14px;\n    height: 14px;\n    border: none;\n    background: transparent !important;\n    color: var(--text-muted);\n    border-radius: 50%;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n}\n\n.modern-todo--remove-tag:hover {\n    background: var(--text-muted);\n    color: var(--background-primary);\n}\n\n/* 设置页面样式 */\n.modern-todo--setting-add-btn {\n    padding: 0.5rem 1rem;\n    border: 1px solid var(--border-color);\n    background: transparent !important;\n    border-radius: var(--radius-sm);\n    font-size: 0.875rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n}\n\n.modern-todo--setting-add-btn:hover {\n    border-color: var(--primary-color);\n    color: var(--primary-color);\n}\n\n.modern-todo--setting-tag {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    padding: 0.5rem 0.75rem;\n    background: var(--background-modifier-hover);\n    border-radius: var(--radius-sm);\n    font-size: 0.875rem;\n}\n\n.modern-todo--setting-remove-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 20px;\n    height: 20px;\n    border: none;\n    background: transparent !important;\n    color: var(--text-muted);\n    border-radius: 50%;\n    cursor: pointer;\n    transition: all 0.15s ease;\n    box-shadow: none !important;\n}\n\n.modern-todo--setting-remove-btn:hover {\n    background: var(--danger-color);\n    color: white;\n}\n\n/* 加载状态 */\n.modern-todo--loading {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 2.5rem 1rem;\n    color: var(--text-muted);\n    background: transparent !important;\n}\n\n.modern-todo--spinner {\n    width: 28px;\n    height: 28px;\n    border: 2px solid var(--border-color);\n    border-top: 2px solid var(--primary-color);\n    border-radius: 50%;\n    animation: modern-todo--spin 1s linear infinite;\n    margin-bottom: 1rem;\n}\n\n@keyframes modern-todo--spin {\n    0% { transform: rotate(0deg); }\n    100% { transform: rotate(360deg); }\n}\n\n/* 空状态 */\n.modern-todo--empty-state {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 2.5rem 1rem;\n    text-align: center;\n    color: var(--text-muted);\n    background: transparent !important;\n}\n\n.modern-todo--empty-illustration {\n    margin-bottom: 1rem;\n    opacity: 0.5;\n    font-size: 48px;\n}\n\n.modern-todo--empty-state h3 {\n    font-size: 1.0625rem;\n    font-weight: 600;\n    color: var(--text-secondary);\n    margin: 0 0 0.5rem 0;\n}\n\n.modern-todo--empty-state p {\n    font-size: 0.875rem;\n    margin: 0;\n}\n\n/* 动画效果 */\n@keyframes modern-todo--fade-in {\n    from {\n        opacity: 0;\n        transform: translateY(10px);\n    }\n    to {\n        opacity: 1;\n        transform: translateY(0);\n    }\n}\n\n.modern-todo--task-card {\n    animation: modern-todo--fade-in 0.3s ease-out;\n}\n\n.modern-todo--date-group {\n    animation: modern-todo--fade-in 0.4s ease-out;\n}\n\n/* 响应式布局 - 优化小屏显示 */\n@media (max-width: 768px) {\n    .modern-todo--modal-overlay {\n        padding: 0.5rem;\n        align-items: flex-start;\n        padding-top: 10vh;\n    }\n    \n    .modern-todo--modal {\n        width: 95vw;\n        max-height: 80vh;\n        margin: 0 auto;\n    }\n    \n    /* 小屏上搜索栏改为垂直布局 */\n    .modern-todo--search-section {\n        flex-direction: column;\n        align-items: stretch;\n        gap: 0.75rem;\n    }\n    \n    .modern-todo--search-box {\n        max-width: none;\n    }\n    \n    /* 小屏上迁移和加载按钮在同一行 */\n    .modern-todo--action-buttons {\n        display: flex;\n        justify-content: space-between;\n        width: 100%;\n    }\n    \n    .modern-todo--migration-btn,\n    .modern-todo--reload-btn {\n        flex: 1;\n        text-align: center;\n    }\n    \n    .modern-todo--view-filters {\n        flex-direction: column;\n        align-items: stretch;\n        gap: 1rem;\n    }\n    \n    .modern-todo--filter-tabs {\n        width: 100%;\n    }\n    \n    .modern-todo--filter-tab {\n        flex: 1;\n        justify-content: center;\n        min-width: 0;\n        padding: 0.75rem 0.5rem;\n        font-size: 0.75rem;\n    }\n    \n    /* 小屏上输入框布局优化 */\n    .modern-todo--add-container {\n        flex-direction: row;\n        gap: 0.5rem;\n    }\n    \n    .modern-todo--date-input {\n        min-width: 100px;\n        order: 1;\n    }\n    \n    .modern-todo--add-input {\n        order: 2;\n    }\n    \n    .modern-todo--add-btn {\n        order: 3;\n        width: 44px;\n        height: 44px;\n    }\n    \n    .modern-todo--form-row {\n        grid-template-columns: 1fr;\n    }\n    \n    .modern-todo--date-header {\n        flex-direction: column;\n        align-items: flex-start;\n        gap: 0.5rem;\n    }\n    \n    .modern-todo--task-footer {\n        flex-direction: column;\n        align-items: flex-start;\n        gap: 0.5rem;\n    }\n    \n    .modern-todo--priority-buttons {\n        flex-direction: column;\n    }\n    \n    .modern-todo--quick-add,\n    .modern-todo--filters,\n    .modern-todo--main {\n        padding-left: 0.75rem;\n        padding-right: 0.75rem;\n    }\n    \n    .modern-todo--task-text {\n        font-size: 0.8125rem;\n    }\n}\n\n@media (max-width: 480px) {\n    .modern-todo--quick-add,\n    .modern-todo--filters,\n    .modern-todo--main {\n        padding-left: 0.5rem;\n        padding-right: 0.5rem;\n    }\n    \n    .modern-todo--filter-tab {\n        padding: 0.5rem 0.25rem;\n        font-size: 0.7rem;\n    }\n    \n    .modern-todo--filter-count {\n        font-size: 0.65rem;\n        padding: 4px 4px;\n        min-width: 16px;\n    }\n    \n    /* 超小屏上日期选择器宽度调整 */\n    .modern-todo--date-input {\n        min-width: 90px;\n        font-size: 0.8rem;\n    }\n    \n    /* 超小屏上添加按钮稍微缩小 */\n    .modern-todo--add-btn {\n        width: 40px;\n        height: 40px;\n        font-size: 1.1rem;\n    }\n}",
      "viewCompilation": {
        "compiledCode": "function App() {\n  const {\n    getData,\n    saveData\n  } = useDataStorage();\n  const app = useObsidianApp();\n  const [tasks, setTasks] = useState([]);\n  const [filter, setFilter] = useState('all');\n  const [newTaskText, setNewTaskText] = useState('');\n  const [newTaskDate, setNewTaskDate] = useState(new Date().toISOString().split('T')[0]);\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState('');\n  const [success, setSuccess] = useState('');\n  const [searchQuery, setSearchQuery] = useState('');\n  const [editingTask, setEditingTask] = useState(null);\n  const [actionMenu, setActionMenu] = useState({\n    show: false,\n    task: null,\n    triggerElement: null\n  });\n  const [showTagSuggestions, setShowTagSuggestions] = useState(false);\n  const [migrationStatus, setMigrationStatus] = useState({\n    running: false,\n    progress: 0,\n    message: '',\n    currentStep: 0,\n    totalSteps: 0\n  });\n  const isInitializedRef = useRef(false);\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const {\n    dailyNoteFolder = '',\n    dailyNoteSection = '待办',\n    autoFocus = true,\n    defaultTags = ['工作', '运动', '生活', '学习'],\n    templatePath = '',\n    cacheDays = 3,\n    futureDays = 7,\n    keepOriginalTasks = false,\n    migrationTags = ['迁移']\n  } = settings;\n  const allTags = [...new Set(tasks.flatMap(task => task.tags || []))];\n\n  // 日期工具函数\n  const dateUtils = useMemo(() => ({\n    getNotePathByDate: (dateStr = null) => {\n      const dateObj = dateStr ? new Date(dateStr) : new Date();\n      const year = dateObj.getFullYear();\n      const month = String(dateObj.getMonth() + 1).padStart(2, '0');\n      const day = String(dateObj.getDate()).padStart(2, '0');\n      const formattedDate = `${year}-${month}-${day}`;\n      const folder = dailyNoteFolder || '';\n      return folder ? `${folder}/${formattedDate}.md` : `${formattedDate}.md`;\n    },\n    getDateFromNotePath: notePath => {\n      const fileName = notePath.split('/').pop().replace('.md', '');\n      return fileName;\n    },\n    isToday: dateStr => {\n      const today = new Date().toISOString().split('T')[0];\n      return dateStr === today;\n    },\n    isFutureDate: dateStr => {\n      const today = new Date().toISOString().split('T')[0];\n      return dateStr > today;\n    },\n    isPastDate: dateStr => {\n      const today = new Date().toISOString().split('T')[0];\n      return dateStr < today;\n    },\n    formatDisplayDate: dateStr => {\n      const date = new Date(dateStr);\n      const today = new Date();\n      const yesterday = new Date(today);\n      yesterday.setDate(yesterday.getDate() - 1);\n      const tomorrow = new Date(today);\n      tomorrow.setDate(tomorrow.getDate() + 1);\n      if (date.toDateString() === today.toDateString()) {\n        return '今天';\n      } else if (date.toDateString() === yesterday.toDateString()) {\n        return '昨天';\n      } else if (date.toDateString() === tomorrow.toDateString()) {\n        return '明天';\n      } else {\n        return `${date.getMonth() + 1}月${date.getDate()}日`;\n      }\n    },\n    getRecentDates: (pastDays = 3, futureDays = 7) => {\n      const dates = [];\n      for (let i = 0; i < pastDays; i++) {\n        const date = new Date();\n        date.setDate(date.getDate() - i);\n        const year = date.getFullYear();\n        const month = String(date.getMonth() + 1).padStart(2, '0');\n        const day = String(date.getDate()).padStart(2, '0');\n        dates.push(`${year}-${month}-${day}`);\n      }\n      for (let i = 1; i <= futureDays; i++) {\n        const date = new Date();\n        date.setDate(date.getDate() + i);\n        const year = date.getFullYear();\n        const month = String(date.getMonth() + 1).padStart(2, '0');\n        const day = String(date.getDate()).padStart(2, '0');\n        dates.push(`${year}-${month}-${day}`);\n      }\n      return dates;\n    }\n  }), [dailyNoteFolder]);\n\n  // 优化的日记文件确保逻辑 - 专门用于迁移功能\n  const ensureDailyNoteSectionForMigration = useCallback(async notePath => {\n    try {\n      let file = app.vault.getAbstractFileByPath(notePath);\n      let content = '';\n      if (!file) {\n        if (templatePath) {\n          try {\n            file = await Files.createFileFromTemplate(app, notePath, templatePath);\n            content = await app.vault.read(file);\n          } catch (templateError) {\n            console.warn('使用模板创建日记失败，创建空文件:', templateError);\n            file = await Files.createFile(app, notePath, '');\n            content = '';\n          }\n        } else {\n          file = await Files.createFile(app, notePath, '');\n          content = '';\n        }\n      } else {\n        content = await app.vault.read(file);\n      }\n      const effectiveSection = dailyNoteSection?.trim() || '待办';\n      const headingRegex = new RegExp(`^#\\\\s+${effectiveSection.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&')}\\\\s*$`, 'm');\n      const hasHeading = headingRegex.test(content);\n\n      // 只有在没有标题时才创建标题\n      if (!hasHeading) {\n        const newContent = content.trim() + (content.trim() ? '\\n\\n' : '') + `# ${effectiveSection}\\n\\n`;\n        await app.vault.modify(file, newContent);\n        return {\n          file,\n          createdHeading: true\n        };\n      }\n      return {\n        file,\n        createdHeading: false\n      };\n    } catch (error) {\n      console.error('确保日记文件存在失败:', error);\n      setError(`日记文件操作失败: ${error.message}`);\n      throw error;\n    }\n  }, [app, dailyNoteSection, templatePath]);\n\n  // 通用的日记文件确保逻辑\n  const ensureDailyNoteAndSection = useCallback(async notePath => {\n    try {\n      let file = app.vault.getAbstractFileByPath(notePath);\n      let content = '';\n      if (!file) {\n        if (templatePath) {\n          try {\n            file = await Files.createFileFromTemplate(app, notePath, templatePath);\n            content = await app.vault.read(file);\n          } catch (templateError) {\n            console.warn('使用模板创建日记失败，创建空文件:', templateError);\n            file = await Files.createFile(app, notePath, '');\n            content = '';\n          }\n        } else {\n          file = await Files.createFile(app, notePath, '');\n          content = '';\n        }\n      } else {\n        content = await app.vault.read(file);\n      }\n      const effectiveSection = dailyNoteSection?.trim() || '待办';\n      const headingRegex = new RegExp(`^#\\\\s+${effectiveSection.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&')}\\\\s*$`, 'm');\n      const hasHeading = headingRegex.test(content);\n      if (!hasHeading) {\n        const newContent = content.trim() + (content.trim() ? '\\n\\n' : '') + `# ${effectiveSection}\\n\\n`;\n        await app.vault.modify(file, newContent);\n      }\n      return true;\n    } catch (error) {\n      console.error('确保日记文件存在失败:', error);\n      setError(`日记文件操作失败: ${error.message}`);\n      return false;\n    }\n  }, [app, dailyNoteSection, templatePath]);\n\n  // 任务加载逻辑保持不变\n  const loadTasks = useCallback(async () => {\n    const effectiveSection = dailyNoteSection?.trim() || '待办';\n    if (!effectiveSection) {\n      setError('请先在设置中指定有效的日记标题');\n      return;\n    }\n    setLoading(true);\n    setError('');\n    try {\n      const dailyNotes = await DailyNotes.getAllDailyNotes(app);\n      const allTasks = [];\n      const recentDates = dateUtils.getRecentDates(cacheDays, futureDays);\n      const recentNotes = dailyNotes.filter(note => {\n        const noteDate = dateUtils.getDateFromNotePath(note.path);\n        return recentDates.includes(noteDate);\n      });\n      for (let i = 0; i < recentNotes.length; i++) {\n        const noteFile = recentNotes[i];\n        if (i % 2 === 0 && i > 0) {\n          await new Promise(resolve => setTimeout(resolve, 10));\n        }\n        try {\n          const noteDate = dateUtils.getDateFromNotePath(noteFile.path);\n          const content = await Markdowns.readContentUnderHeading(app, noteFile.path, {\n            heading: `# ${effectiveSection}`,\n            includeSubHeadings: true\n          });\n          if (content) {\n            const parsedTasks = parseTasksFromMarkdown(content, noteFile.path);\n            allTasks.push(...parsedTasks);\n          }\n        } catch (error) {\n          if (!error.message.includes('Heading not found')) {\n            console.warn(`读取日记 ${noteFile.path} 失败:`, error);\n          }\n        }\n      }\n      setTasks(allTasks);\n    } catch (error) {\n      console.error('加载待办失败:', error);\n      setError(`加载失败: ${error.message}`);\n    } finally {\n      setLoading(false);\n    }\n  }, [app, dailyNoteSection, dateUtils, cacheDays, futureDays]);\n\n  // 任务保存逻辑保持不变\n  const saveTasksToNote = useCallback(async (notePath, updatedTasks) => {\n    try {\n      const markdownContent = convertTasksToMarkdown(updatedTasks);\n      const effectiveSection = dailyNoteSection?.trim() || '待办';\n      await ensureDailyNoteAndSection(notePath);\n      try {\n        await Markdowns.replaceContentUnderHeading(app, notePath, {\n          heading: `# ${effectiveSection}`,\n          includeSubHeadings: true\n        }, markdownContent);\n        return true;\n      } catch (error) {\n        if (error.message.includes('Heading not found')) {\n          const headingContent = `# ${effectiveSection}\\n\\n${markdownContent}`;\n          await Markdowns.appendContent(app, notePath, `\\n\\n${headingContent}`);\n          return true;\n        } else {\n          throw error;\n        }\n      }\n    } catch (error) {\n      console.error('保存待办失败:', error);\n      throw error;\n    }\n  }, [app, dailyNoteSection, ensureDailyNoteAndSection]);\n\n  // 优化的迁移逻辑 - 核心改进部分\n  const migrateUncompletedTasks = useCallback(async (sourceDate = null) => {\n    if (migrationStatus.running) {\n      return {\n        migrated: 0,\n        total: 0\n      };\n    }\n    setMigrationStatus({\n      running: true,\n      progress: 0,\n      message: '正在准备迁移...',\n      currentStep: 1,\n      totalSteps: 6\n    });\n    await new Promise(resolve => setTimeout(resolve, 100));\n    try {\n      const effectiveSection = dailyNoteSection?.trim() || '待办';\n      const today = new Date();\n      let sourceDateObj;\n      if (sourceDate) {\n        sourceDateObj = new Date(sourceDate);\n      } else {\n        sourceDateObj = new Date(today);\n        sourceDateObj.setDate(sourceDateObj.getDate() - 1);\n      }\n      const sourceDateStr = sourceDateObj.toISOString().split('T')[0];\n      const targetDateStr = today.toISOString().split('T')[0];\n      setMigrationStatus(prev => ({\n        ...prev,\n        progress: 20,\n        message: `正在查找 ${sourceDateStr} 的日记...`,\n        currentStep: 2\n      }));\n      await new Promise(resolve => setTimeout(resolve, 50));\n      const sourceNote = await DailyNotes.getDailyNote(app, sourceDateStr);\n      if (!sourceNote) {\n        setMigrationStatus({\n          running: false,\n          progress: 0,\n          message: '',\n          currentStep: 0,\n          totalSteps: 0\n        });\n        setSuccess(`未找到 ${sourceDateStr} 的日记文件，无需迁移`);\n        return {\n          migrated: 0,\n          total: 0\n        };\n      }\n      setMigrationStatus(prev => ({\n        ...prev,\n        progress: 40,\n        message: `正在读取 ${sourceDateStr} 的待办事项...`,\n        currentStep: 3\n      }));\n      await new Promise(resolve => setTimeout(resolve, 50));\n      let sourceTasks = [];\n      try {\n        const content = await Markdowns.readContentUnderHeading(app, sourceNote.path, {\n          heading: `# ${effectiveSection}`,\n          includeSubHeadings: true\n        });\n        sourceTasks = parseTasksFromMarkdown(content, sourceNote.path);\n      } catch (error) {\n        if (!error.message.includes('Heading not found')) {\n          throw error;\n        }\n        sourceTasks = [];\n      }\n      if (sourceTasks.length === 0) {\n  