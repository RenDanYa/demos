      "showBorder": true,
      "showShadow": true,
      "createAt": "2024-05-24T23:33:41.561Z",
      "updateAt": "2024-05-24T23:33:41.561Z",
      "query": "let month = moment().format('MM')\nlet date = moment().format('MMDD')\nlet url = `https://baike.baidu.com/cms/home/eventsOnHistory/${month}.json`\nlet res = await request({url: url,method: \"GET\"});\nlet data = JSON.parse(res)\nconsole.log(data[month][date])\ndv.container.classList.add('components--dataview-eventsOnHistoryTimeline')\ndv.table(\n\t['年份','事件','','详细内容',''],\n\tdata[month][date].map(p=>[p.year,p.title, '',p.desc,'',`[跳转](${p.link})`])\n\t)",
      "queryType": "dataviewjs",
      "maxHeight": 591,
      "dynamicParamComponents": [],
      "title": "历史上的今天"
    },
