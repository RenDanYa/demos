        "compiledCode": "function App() {\n  const {\n    getData,\n    saveData\n  } = useDataStorage();\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const updateSetting = (key, value) => {\n    const newSettings = {\n      ...settings,\n      [key]: value\n    };\n    saveData({\n      ...data,\n      settings: newSettings\n    });\n  };\n  const saveLocationOptions = [{\n    label: \"文件开头\",\n    value: \"start\"\n  }, {\n    label: \"文件末尾\",\n    value: \"end\"\n  }, {\n    label: \"指定标题下\",\n    value: \"under_heading\"\n  }];\n\n  // 预设模板选项\n  const templatePresets = [{\n    label: \"纯文本\",\n    value: \"{{text}}\",\n    description: \"不添加任何格式的纯文本\"\n  }, {\n    label: \"时间戳笔记\",\n    value: \"- {{date:YYYY-MM-DD HH:mm}}: {{text}}\",\n    description: \"在文本前添加时间戳\"\n  }, {\n    label: \"日记条目\",\n    value: \"## {{date:YYYY-MM-DD}}\\n{{text}}\\n\",\n    description: \"带日期标题的日记格式\"\n  }, {\n    label: \"任务清单\",\n    value: \"- [ ] {{text}}\",\n    description: \"转换为待办事项格式\"\n  }, {\n    label: \"引用块\",\n    value: \"> {{text}}\\n> \\n> — 记录于 {{date:YYYY-MM-DD}}\",\n    description: \"格式化为引用块并添加记录时间\"\n  }, {\n    label: \"详细时间戳\",\n    value: \"**{{date:YYYY-MM-DD dddd}}** {{time:HH:mm}}\\n\\n{{text}}\",\n    description: \"包含星期的详细时间戳格式\"\n  }];\n  const handlePresetSelect = presetValue => {\n    updateSetting(\"contentTemplate\", presetValue);\n  };\n  return /*#__PURE__*/React.createElement(Settings, null, /*#__PURE__*/React.createElement(SettingTitle, null, \"\\u5FEB\\u901F\\u6355\\u83B7\\u8BBE\\u7F6E\"), /*#__PURE__*/React.createElement(SettingDescription, null, \"\\u914D\\u7F6E\\u60A8\\u7684\\u60F3\\u6CD5\\u4FDD\\u5B58\\u4F4D\\u7F6E\\u548C\\u65B9\\u5F0F\\u3002\"), /*#__PURE__*/React.createElement(SettingDivider, null), /*#__PURE__*/React.createElement(FileSettingAutocomplete, {\n    label: \"\\u76EE\\u6807\\u6587\\u4EF6\\u8DEF\\u5F84\",\n    placeholder: \"\\u4F8B\\u5982: Ideas/Daily/{{date:YYYY-MM-DD}}.md\",\n    value: sett