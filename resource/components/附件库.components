        "compiledCode": "function App() {\n  const {\n    getData,\n    saveData\n  } = useDataStorage();\n  const data = getData() || {};\n  const settings = data.settings || {};\n\n  // 更新设置\n  const updateSettings = newSettings => {\n    saveData({\n      ...data,\n      settings: {\n        ...settings,\n        ...newSettings\n      }\n    });\n  };\n\n  // 重置所有设置\n  const resetSettings = () => {\n    saveData({\n      ...data,\n      settings: {\n        pluginQuery: \"\",\n        showAllWhenEmpty: true\n      }\n    });\n  };\n  return /*#__PURE__*/React.createElement(Settings, null, /*#__PURE__*/React.createElement(SettingTitle, null, \"\\u641C\\u7D22\\u8BBE\\u7F6E\"), /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"\\u9ED8\\u8BA4\\u641C\\u7D22\\u5173\\u952E\\u8BCD\",\n    type: \"text\",\n    value: settings.pluginQuery || \"\",\n    placeholder: \"\\u8F93\\u5165\\u63D2\\u4EF6\\u540D\\u79F0\\u3001\\u547D\\u4EE4\\u540D\\u79F0\\u6216\\u547D\\u4EE4ID...\",\n    onChange: e => {\n      updateSettings({\n        pluginQuery: e.target.value\n      });\n    }\n  }), /*#__PURE__*/React.createElement(SettingDescription, null, \"\\u8BBE\\u7F6E\\u9ED8\\u8BA4\\u641C\\u7D22\\u5173\\u952E\\u8BCD\\uFF0C\\u53EF\\u4EE5\\u662F\\u63D2\\u4EF6\\u540D\\u79F0\\u3001\\u547D\\u4EE4\\u540D\\u79F0\\u6216\\u547D\\u4EE4ID\\uFF0C\\u7559\\u7A7A\\u5219\\u4E0D\\u9884\\u8BBE\\u641C\\u7D22\\u6761\\u4EF6\"), /*#__PURE__*/React.createElement(SettingDivider, null), /*#__PURE__*/React.createElement(SettingTitle, null, \"\\u663E\\u793A\\u8BBE\\u7F6E\"), /*#__PURE__*/React.createElement(SettingItem, {\n    label: \"\\u641C\\u7D22\\u4E3A\\u7A7A\\u65F6\\u663E\\u793A\\u6240\\u6709\\u547D\\u4EE4\"\n  }, /*#__PURE__*/React.createElement(\"input\", {\n    type: \"checkbox\",\n    checked: settings.showAllWhenEmpty !== false,\n    onChange: e => {\n      updateSettings({\n        showAllWhenEmpty: e.target.checked\n      });\n    }\n  })), /*#__PURE__*/React.createElement(SettingDescripti