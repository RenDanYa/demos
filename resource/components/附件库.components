      "updateAt": "2025-10-30T14:33:36.690Z",
      "viewCode": "function App() {\n  const { getData, saveData } = useDataStorage();\n  const app = useObsidianApp();\n  const data = getData() || {};\n  const settings = data.settings || {};\n\n  // 从设置中读取配置\n  const targetFilePathTemplate = settings.filePath || \"QuickCaptures.md\";\n  const templateFile = settings.templateFile || \"\";\n  const saveLocation = settings.saveLocation || \"end\";\n  const targetHeading = settings.targetHeading || \"\";\n  const contentTemplate = settings.contentTemplate || \"{{text}}\";\n  const includeSubHeadings = settings.includeSubHeadings === true;\n\n  const [inputText, setInputText] = useState(data.inputText || \"\");\n  const [saveStatus, setSaveStatus] = useState(\"idle\"); // 'idle', 'saving', 'success', 'error'\n\n  // 临时存储输入内容 - 使用防抖来避免频繁保存\n  useEffect(() => {\n    const timeoutId = setTimeout(() => {\n      if (data.inputText !== inputText) {\n        saveData({ ...data, inputText });\n      }\n    }, 300); // 300ms 防抖\n\n    return () => clearTimeout(timeoutId);\n  }, [inputText, data.inputText, saveData]);\n\n  // 处理模板变量替换\n  const processTemplate = useCallback((template, text) => {\n    const now = moment();\n    \n    let result = template.replace(/{{text}}/g, text);\n    result = result.replace(/{{date:([^}]+)}}/g, (match, formatStr) => now.format(formatStr));\n    result = result.replace(/{{time:([^}]+)}}/g, (match, formatStr) => now.format(formatStr));\n    result = result.replace(/{{date}}/g, now.format(\"YYYY-MM-DD\"));\n    result = result.replace(/{{time}}/g, now.format(\"HH:mm:ss\"));\n\n    return result;\n  }, []);\n\n  // 解析文件路径中的变量\n  const resolveFilePath = useCallback((pathTemplate) => {\n    const now = moment();\n\n    return pathTemplate\n      .replace(/{{date:YYYY-MM-DD}}/g, now.format(\"YYYY-MM-DD\"))\n      .replace(/{{date:YYYY}}/g, now.format(\"YYYY\"))\n      .replace(/{{date}}/g, now.format(\"YYYY-MM-DD\"));\n  }, []);\n\n  // 智能文件创建 - 支持模板\n  const ensureFileExists = useCallback(async (filePath) => {\n    try {\n      const existingFile = app.vault.getAbstractFileByPath(filePath);\n      if (existingFile) {\n        return { created: false, fromTemplate: false };\n      }\n      \n      // 如果文件不存在，使用模板创建\n      if (templateFile) {\n        await Files.createFileFromTemplate(app, filePath, templateFile);\n        return { created: true, fromTemplate: true };\n      } else {\n        await Files.createFile(app, filePath, \"\");\n        return { created: true, fromTemplate: false };\n      }\n    } catch (error) {\n      console.error(\"Failed to create file:\", error);\n      return null;\n    }\n  }, [app, templateFile]);\n\n  const handleSave = useCallback(async () => {\n    if (!inputText.trim()) {\n      new Obsidian.Notice(\"Nothing to save.\");\n      return;\n    }\n\n    setSaveStatus(\"saving\");\n    \n    try {\n      const finalFilePath = resolveFilePath(targetFilePathTemplate);\n      const finalContent = processTemplate(contentTemplate, inputText);\n\n      const fileResult = await ensureFileExists(finalFilePath);\n      if (!fileResult) {\n        throw new Error(\"Failed to create target file\");\n      }\n      // awit 100ms\n      await new Promise(res => setTimeout(res, 100));\n\n      if (saveLocation === \"start\") {\n        await Markdowns.prependContent(app, finalFilePath, finalContent + \"\\n\");\n      } else if (saveLocation === \"end\") {\n        await Markdowns.appendContent(app, finalFilePath, \"\\n\" + finalContent);\n      } else if (saveLocation === \"under_heading\" && targetHeading) {\n        const headingLocation = {\n          heading: targetHeading,\n          includeSubHeadings: includeSubHeadings\n        };\n        await Markdowns.appendContentUnderHeading(app, finalFilePath, headingLocation, \"\\n\" + finalContent);\n      } else {\n        await Markdowns.appendContent(app, finalFilePath, \"\\n\" + finalContent);\n      }\n      \n      setSaveStatus(\"success\");\n      \n      // 提供更详细的成功消息\n      let successMessage = \"💡 Idea captured successfully!\";\n      if (fileResult.created && fileResult.fromTemplate) {\n        successMessage = \"� File created from template and idea captured!\";\n      } else if (fileResult.created) {\n        successMessage = \"📝 New file created and idea captured!\";\n      }\n      \n      new Obsidian.Notice(successMessage);\n      setInputText(\"\");\n      saveData({ ...data, inputText: \"\" });\n      \n      setTimeout(() => setSaveStatus(\"idle\"), 2000);\n    } catch (err) {\n      console.error(\"Failed to save idea:\", err);\n      setSaveStatus(\"error\");\n      let errorMessage = \"❌ Failed to save idea. Please check your settings.\";\n      \n      // 提供更具体的错误信息\n      if (err.message?.includes(\"file\")) {\n        errorMessage = \"❌ Failed to create or access the target file.\";\n      } else if (err.message?.includes(\"heading\")) {\n        errorMessage = \"❌ Target heading not found. Please check the heading name.\";\n      }\n      \n      new Obsidian.Notice(errorMessage);\n      setTimeout(() => setSaveStatus(\"idle\"), 3000);\n    }\n  }, [\n    inputText, \n    targetFilePathTemplate, \n    contentTemplate, \n    saveLocation, \n    targetHeading, \n    includeSubHeadings, \n    templateFile,\n    app, \n    data, \n    saveData, \n    resolveFilePath, \n    processTemplate, \n    ensureFileExists\n  ]);\n\n  const handleKeyDown = useCallback((e) => {\n    // Cmd/Ctrl + Enter 保存\n    if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {\n      e.preventDefault();\n      handleSave();\n    }\n    // 普通 Enter (不包含修饰键) 也保存，Shift+Enter 换行\n    else if (e.key === 'Enter' && !e.shiftKey && !e.metaKey && !e.ctrlKey) {\n      e.preventDefault();\n      handleSave();\n    }\n  }, [handleSave]);\n\n  // 字符计数和验证\n  const charCount = inputText.length;\n  const maxChars = 2000; // 增加字符限制，更实用\n  const isNearLimit = charCount > maxChars * 0.9;\n  const isOverLimit = charCount > maxChars;\n\n  // 添加快捷键提示\n  const placeholderText = useCallback(() => {\n    const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0;\n    const shortcut = isMac ? '⌘+Enter' : 'Ctrl+Enter';\n    const templateStatus = templateFile ? ' 📄 已配置模板' : '';\n    return `✨ 开始记录...${templateStatus} (${shortcut} 保存, Shift+Enter 换行)`;\n  }, [templateFile]);\n\n  // 获取保存按钮显示内容\n  const getSaveButtonContent = () => {\n    switch (saveStatus) {\n      case \"saving\":\n        return <LucideIcon name=\"loader\" size={16} />;\n      case \"success\":\n        return <LucideIcon name=\"check\" size={16} />;\n      case \"error\":\n        return <LucideIcon name=\"x\" size={16} />;\n      default:\n        return <LucideIcon name=\"send\" size={16} />;\n    }\n  };\n\n  const getSaveButtonClass = () => {\n    let baseClass = \"capture--SaveButton\";\n    switch (saveStatus) {\n      case \"saving\":\n        return baseClass + \" capture--SaveButton-loading\";\n      case \"success\":\n        return baseClass + \" capture--SaveButton-success\";\n      case \"error\":\n        return baseClass + \" capture--SaveButton-error\";\n      default:\n        return baseClass;\n    }\n  };\n\n  return (\n    <div className=\"capture--Container\">\n      <div className=\"capture--InputArea\">\n        <textarea\n          className=\"capture--Textarea\"\n          value={inputText}\n          onChange={(e) => setInputText(e.target.value)}\n          onKeyDown={handleKeyDown}\n          placeholder={placeholderText()}\n          maxLength={maxChars}\n          disabled={saveStatus === \"saving\"}\n        />\n        <div className=\"capture--InputFooter\">\n          <div className=\"capture--CharCount\">\n            <span className={isNearLimit ? \"capture--CharCount-warning\" : \"\"}>\n              {charCount}/{maxChars}\n            </span>\n            {isOverLimit && (\n              <span className=\"capture--CharCount-error\">\n                Character limit exceeded!\n              </span>\n            )}\n          </div>\n        </div>\n      </div>\n      <div className=\"capture--ButtonContainer\">\n        <button \n          className={getSaveButtonClass()}\n          onClick={handleSave}\n          disabled={saveStatus === \"saving\" || !inputText.trim() || isOverLimit}\n          title={\n            saveStatus === \"saving\" \n              ? \"Saving...\" \n              : isOverLimit \n                ? \"Character limit exceeded\" \n                : \"Save idea\"\n          }\n        >\n          {getSaveButtonContent()}\n        </button>\n      </div>\n    </div>\n  );\n}",
      "settingsCode": "function App() {\n    const { getData, saveData } = useDataStorage();\n    const data = getData() || {};\n    const settings = data.settings || {};\n\n    const updateSetting = (key, value) => {\n        const newSettings = { ...settings, [key]: value };\n        saveData({ ...data, settings: newSettings });\n    };\n\n    const saveLocationOptions = [\n        { label: \"文件开头\", value: \"start\" },\n        { label: \"文件末尾\", value: \"end\" },\n        { label: \"指定标题下\", value: \"under_heading\" }\n    ];\n\n    // 预设模板选项\n    const templatePresets = [\n        { \n            label: \"纯文本\", \n            value: \"{{text}}\", \n            description: \"不添加任何格式的纯文本\" \n        },\n        { \n            label: \"时间戳笔记\", \n            value: \"- {{date:YYYY-MM-DD HH:mm}}: {{text}}\", \n            description: \"在文本前添加时间戳\" \n        },\n        { \n            label: \"日记条目\", \n            value: \"## {{date:YYYY-MM-DD}}\\n{{text}}\\n\", \n            description: \"带日期标题的日记格式\" \n        },\n        { \n            label: \"任务清单\", \n            value: \"- [ ] {{text}}\", \n            description: \"转换为待办事项格式\" \n        },\n        { \n            label: \"引用块\", \n            value: \"> {{text}}\\n> \\n> — 记录于 {{date:YYYY-MM-DD}}\", \n            description: \"格式化为引用块并添加记录时间\" \n        },\n        {\n            label: \"详细时间戳\",\n            value: \"**{{date:YYYY-MM-DD dddd}}** {{time:HH:mm}}\\n\\n{{text}}\",\n            description: \"包含星期的详细时间戳格式\"\n        }\n    ];\n\n    const handlePresetSelect = (presetValue) => {\n        updateSetting(\"contentTemplate\", presetValue);\n    };\n\n    return (\n        <Settings>\n            <SettingTitle>快速捕获设置</SettingTitle>\n            <SettingDescription>配置您的想法保存位置和方式。</SettingDescription>\n\n            <SettingDivider />\n\n            <FileSettingAutocomplete\n                label=\"目标文件路径\"\n                placeholder=\"例如: Ideas/Daily/{{date:YYYY-MM-DD}}.md\"\n                value={settings.filePath || \"\"}\n                onChange={(value) => updateSetting(\"filePath\", value)}\n            />\n\n            <FileSettingAutocomplete\n                label=\"文件创建模板\"\n                placeholder=\"选择文件不存在时用于创建的模板文件 (可选)\"\n                value={settings.templateFile || \"\"}\n                filter={(file) => file.extension === \"md\"}\n                onChange={(value) => updateSetting(\"templateFile\", value)}\n            />\n\n            <SettingDescription>\n                <div className=\"capture-settings--TemplateFileHelp\">\n                    <strong>💡 模板文件功能：</strong>\n                    <ul>\n                        <li>如果目标文件不存在，将使用选择的模板文件来创建新文件</li>\n                        <li>模板支持变量替换：{\"{{date}}\"}, {\"{{time}}\"}, {\"{{title}}\"} 等</li>\n                        <li>不选择模板文件则创建空白文件</li>\n                    </ul>\n                </div>\n            </SettingDescription>\n\n            <SettingSelect\n                label=\"保存位置\"\n                value={settings.saveLocation || \"end\"}\n                options={saveLocationOptions}\n                onChange={(value) => updateSetting(\"saveLocation\", value)}\n            />\n\n            {settings.saveLocation === \"under_heading\" && (\n                <>\n                    <SettingInput\n                        label=\"目标标题\"\n                        placeholder=\"例如: ## 想法\"\n                        value={settings.targetHeading || \"\"}\n                        onChange={(e) => updateSetting(\"targetHeading\", e.target.value)}\n                    />\n                    <SettingSwitch\n                        label=\"包含子标题\"\n                        value={settings.includeSubHeadings === true}\n                        onChange={(value) => updateSetting(\"includeSubHeadings\", value)}\n                    />\n                </>\n            )}\n\n            <SettingDivider />\n\n            <SettingTitle>内容模板</SettingTitle>\n            <SettingDescription>选择预设模板或自定义内容格式。</SettingDescription>\n\n            <SettingItem label=\"模板预设\">\n                <div className=\"capture-settings--PresetContainer\">\n                    {templatePresets.map((preset, index) => (\n                        <button\n                            key={index}\n                            className={`capture-settings--PresetButton ${\n                                settings.contentTemplate === preset.value ? 'capture-settings--PresetButton-active' : ''\n                            }`}\n                            onClick={() => handlePresetSelect(preset.value)}\n                            title={preset.description}\n                        >\n                            {preset.label}\n                        </button>\n                    ))}\n                </div>\n            </SettingItem>\n\n            <SettingItem label=\"自定义模板\">\n                <textarea\n                    className=\"capture-settings--TemplateTextarea\"\n                    value={settings.contentTemplate || \"{{text}}\"}\n                    onChange={(e) => updateSetting(\"contentTemplate\", e.target.value)}\n                    placeholder=\"例如: - {{date}} {{time}}: {{text}}\"\n                />\n            </SettingItem>\n\n            <SettingDescription>\n                <div className=\"capture-settings--TemplateHelp\">\n                    <strong>可用变量：</strong>\n                    <ul>\n                        <li><code>{\"{{text}}\"}</code> - 您捕获的内容</li>\n                        <li><code>{\"{{date}}\"}</code> - 当前日期 (YYYY-MM-DD)</li>\n                        <li><code>{\"{{time}}\"}</code> - 当前时间 (HH:mm:ss)</li>\n                        <li><code>{\"{{date:FORMAT}}\"}</code> - 自定义日期格式 (使用 moment.js 格式)</li>\n                        <li><code>{\"{{time:FORMAT}}\"}</code> - 自定义时间格式 (使用 moment.js 格式)</li>\n                    </ul>\n                    <div className=\"capture-settings--FormatExamples\">\n                        <strong>格式示例：</strong>\n                        <ul>\n                            <li><code>YYYY-MM-DD</code> → 2024-03-15</li>\n                            <li><code>YYYY-MM-DD dddd</code> → 2024-03-15 Friday</li>\n                            <li><code>HH:mm:ss</code> → 14:30:25</li>\n                            <li><code>MMMM Do, YYYY</code> → March 15th, 2024</li>\n                        </ul>\n                    </div>\n                    <div className=\"capture-settings--TemplateExample\">\n                        <strong>示例：</strong> <code>- {\"{{date:YYYY-MM-DD HH:mm}}\"}: {\"{{text}}\"}</code>\n                    </div>\n                </div>\n            </SettingDescription>\n        </Settings>\n    );\n}",
      "cssCode": "/* 容器样式 */\n.capture--Container {\n  display: flex;\n  flex-direction: column;\n  gap: var(--size-4-3);\n  padding: var(--size-4-4);\n  background: var(--background-primary);\n  border-radius: var(--radius-l);\n  border: 1px solid var(--background-modifier-border);\n  transition: all 0.2s ease-in-out;\n  position: relative;\n}\n\n.capture--Container:hover {\n  border-color: var(--background-modifier-border-hover);\n  box-shadow: 0 2px 8px var(--background-modifier-box-shadow);\n}\n\n/* 输入区域样式 */\n.capture--InputArea {\n  display: flex;\n  flex-direction: column;\n  gap: var(--size-4-2);\n}\n\n.capture--Textarea {\n  width: 100%;\n  min-height: 100px;\n  max-height: 300px;\n  padding: var(--size-4-3);\n  background-color: var(--background-modifier-form-field);\n  color: var(--text-normal);\n  border: 2px solid var(--background-modifier-border);\n  border-radius: var(--radius-m);\n  resize: vertical;\n  font-family: var(--font-text);\n  font-size: var(--font-ui-medium);\n  line-height: var(--line-height-normal);\n  transition: all 0.2s ease-in-out;\n  outline: none;\n}\n\n.capture--Textarea:focus {\n  border-color: var(--interactive-accent);\n  box-shadow: 0 0 0 2px var(--interactive-accent-hover);\n  background-color: var(--background-primary);\n  transform: translateY(-1px);\n}\n\n.capture--Textarea::placeholder {\n  color: var(--text-muted);\n  font-style: italic;\n}\n\n/* 输入底部信息 */\n.capture--InputFooter {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.capture--CharCount {\n  font-size: var(--font-ui-smaller);\n  color: var(--text-muted);\n  transition: color 0.2s ease-in-out;\n  display: flex;\n  gap: var(--size-4-2);\n  align-items: center;\n}\n\n.capture--CharCount-warning {\n  color: var(--text-warning);\n  font-weight: var(--font-weight-medium);\n}\n\n.capture--CharCount-error {\n  color: var(--text-error);\n  font-weight: var(--font-weight-medium);\n  font-size: var(--font-ui-smaller);\n}\n\n/* 按钮容器 */\n.capture--ButtonContainer {\n  display: flex;\n  justify-content: flex-end;\n  align-items: center;\n  gap: var(--size-4-2);\n}\n\n/* 保存按钮基础样式 */\n.capture--SaveButton {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  min-width: 44px;\n  height: 44px;\n  padding: var(--size-4-2);\n  background-color: var(--interactive-accent);\n  color: var(--text-on-accent);\n  border: none;\n  border-radius: var(--radius-m);\n  cursor: pointer;\n  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);\n  position: relative;\n  overflow: hidden;\n}\n\n.capture--SaveButton:hover:not(:disabled) {\n  background-color: var(--interactive-accent-hover);\n  transform: translateY(-2px);\n  box-shadow: 0 4px 12px var(--background-modifier-box-shadow);\n}\n\n.capture--SaveButton:active:not(:disabled) {\n  transform: translateY(0);\n  box-shadow: 0 2px 4px var(--background-modifier-box-shadow);\n}\n\n.capture--SaveButton:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n  transform: none;\n}\n\n/* 保存按钮状态样式 */\n.capture--SaveButton-loading {\n  background-color: var(--text-accent);\n  animation: capture-pulse 1.5s ease-in-out infinite;\n}\n\n.capture--SaveButton-loading svg {\n  animation: capture-spin 1s linear infinite;\n}\n\n.capture--SaveButton-success {\n  background-color: var(--color-green);\n  animation: capture-success 0.6s ease-out;\n}\n\n.capture--SaveButton-error {\n  background-color: var(--color-red);\n  animation: capture-error 0.6s ease-out;\n}\n\n/* 按钮图标样式 */\n.capture--SaveButton svg {\n  color: inherit;\n  transition: transform 0.2s ease-in-out;\n}\n\n/* 动画定义 */\n@keyframes capture-spin {\n  from { transform: rotate(0deg); }\n  to { transform: rotate(360deg); }\n}\n\n@keyframes capture-pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.7; }\n}\n\n@keyframes capture-success {\n  0% { transform: scale(1); }\n  50% { transform: scale(1.1); }\n  100% { transform: scale(1); }\n}\n\n@keyframes capture-error {\n  0%, 20%, 40%, 60%, 80% { transform: translateX(0); }\n  10%, 30%, 50%, 70% { transform: translateX(-5px); }\n}\n\n/* 设置页面样式 */\n.capture-settings--PresetContainer {\n  display: flex;\n  flex-wrap: wrap;\n  gap: var(--size-4-2);\n  margin-top: var(--size-4-2);\n}\n\n.capture-settings--PresetButton {\n  padding: var(--size-4-2) var(--size-4-3);\n  background-color: var(--background-modifier-form-field);\n  color: var(--text-normal);\n  border: 1px solid var(--background-modifier-border);\n  border-radius: var(--radius-s);\n  cursor: pointer;\n  font-size: var(--font-ui-small);\n  transition: all 0.2s ease-in-out;\n  white-space: nowrap;\n}\n\n.capture-settings--PresetButton:hover {\n  background-color: var(--background-modifier-hover);\n  border-color: var(--background-modifier-border-hover);\n}\n\n.capture-settings--PresetButton-active {\n  background-color: var(--interactive-accent);\n  color: var(--text-on-accent);\n  border-color: var(--interactive-accent);\n}\n\n.capture-settings--TemplateTextarea {\n  width: 100%;\n  min-height: 80px;\n  padding: var(--size-4-3);\n  background-color: var(--background-modifier-form-field);\n  color: var(--text-normal);\n  border: 1px solid var(--background-modifier-border);\n  border-radius: var(--radius-m);\n  resize: vertical;\n  font-family: var(--font-monospace);\n  font-size: var(--font-ui-small);\n  line-height: var(--line-height-normal);\n  transition: border-color 0.2s ease-in-out;\n}\n\n.capture-settings--TemplateTextarea:focus {\n  outline: none;\n  border-color: var(--interactive-accent);\n  box-shadow: 0 0 0 2px var(--background-modifier-border-focus);\n}\n\n.capture-settings--TemplateHelp {\n  padding: var(--size-4-3);\n  background-color: var(--background-secondary);\n  border-radius: var(--radius-m);\n  border-left: 3px solid var(--interactive-accent);\n}\n\n.capture-settings--TemplateFileHelp {\n  padding: var(--size-4-3);\n  background-color: var(--background-secondary);\n  border-radius: var(--radius-m);\n  border-left: 3px solid var(--color-accent);\n  margin-top: var(--size-4-2);\n}\n\n.capture-settings--TemplateFileHelp ul {\n  margin: var(--size-4-2) 0;\n  padding-left: var(--size-4-4);\n}\n\n.capture-settings--TemplateFileHelp li {\n  margin: var(--size-4-1) 0;\n  font-size: var(--font-ui-small);\n  color: var(--text-normal);\n}\n\n.capture-settings--TemplateHelp ul {\n  margin: var(--size-4-2) 0;\n  padding-left: var(--size-4-4);\n}\n\n.capture-settings--TemplateHelp li {\n  margin: var(--size-4-1) 0;\n  font-size: var(--font-ui-small);\n}\n\n.capture-settings--FormatExamples {\n  margin: var(--size-4-3) 0;\n  padding: var(--size-4-2);\n  background-color: var(--background-modifier-form-field);\n  border-radius: var(--radius-s);\n  border-left: 2px solid var(--interactive-accent);\n}\n\n.capture-settings--FormatExamples ul {\n  margin: var(--size-4-1) 0;\n  padding-left: var(--size-4-3);\n}\n\n.capture-settings--FormatExamples li {\n  margin: var(--size-2-1) 0;\n  font-family: var(--font-monospace);\n  font-size: var(--font-ui-smaller);\n  color: var(--text-muted);\n}\n\n.capture-settings--TemplateHelp code {\n  background-color: var(--background-modifier-border);\n  padding: var(--size-2-1) var(--size-2-2);\n  border-radius: var(--radius-s);\n  font-family: var(--font-monospace);\n  font-size: var(--font-ui-smaller);\n}\n\n.capture-settings--TemplateExample {\n  margin-top: var(--size-4-2);\n  padding: var(--size-4-2);\n  background-color: var(--background-modifier-form-field);\n  border-radius: var(--radius-s);\n  font-size: var(--font-ui-small);\n}\n\n/* 响应式设计 */\n@media (max-width: 768px) {\n  .capture--Container {\n    padding: var(--size-4-3);\n    gap: var(--size-4-2);\n  }\n  \n  .capture--Textarea {\n    min-height: 80px;\n    font-size: var(--font-ui-medium);\n  }\n  \n  .capture-settings--PresetContainer {\n    flex-direction: column;\n  }\n  \n  .capture-settings--PresetButton {\n    text-align: center;\n  }\n}\n\n/* 暗色主题优化 */\n.theme-dark .capture--Container {\n  border-color: var(--background-modifier-border);\n}\n\n.theme-dark .capture--Textarea:focus {\n  box-shadow: 0 0 0 2px var(--interactive-accent);\n}\n\n.theme-dark .capture-settings--TemplateHelp {\n  background-color: var(--background-primary-alt);\n}\n",
      "viewCompilation": {
        "compiledCode": "function App() {\n  const {\n    getData,\n    saveData\n  } = useDataStorage();\n  const app = useObsidianApp();\n  const data = getData() || {};\n  const settings = data.settings || {};\n\n  // 从设置中读取配置\n  const targetFilePathTemplate = settings.filePath || \"QuickCaptures.md\";\n  const templateFile = settings.templateFile || \"\";\n  const saveLocation = settings.saveLocation || \"end\";\n  const targetHeading = settings.targetHeading || \"\";\n  const contentTemplate = settings.contentTemplate || \"{{text}}\";\n  const includeSubHeadings = settings.includeSubHeadings === true;\n  const [inputText, setInputText] = useState(data.inputText || \"\");\n  const [saveStatus, setSaveStatus] = useState(\"idle\"); // 'idle', 'saving', 'success', 'error'\n\n  // 临时存储输入内容 - 使用防抖来避免频繁保存\n  useEffect(() => {\n    const timeoutId = setTimeout(() => {\n      if (data.inputText !== inputText) {\n        saveData({\n          ...data,\n          inputText\n        });\n      }\n    }, 300); // 300ms 防抖\n\n    return () => clearTimeout(timeoutId);\n  }, [inputText, data.inputText, saveData]);\n\n  // 处理模板变量替换\n  const processTemplate = useCallback((template, text) => {\n    const now = moment();\n    let result = template.replace(/{{text}}/g, text);\n    result = result.replace(/{{date:([^}]+)}}/g, (match, formatStr) => now.format(formatStr));\n    result = result.replace(/{{time:([^}]+)}}/g, (match, formatStr) => now.format(formatStr));\n    result = result.replace(/{{date}}/g, now.format(\"YYYY-MM-DD\"));\n    result = result.replace(/{{time}}/g, now.format(\"HH:mm:ss\"));\n    return result;\n  }, []);\n\n  // 解析文件路径中的变量\n  const resolveFilePath = useCallback(pathTemplate => {\n    const now = moment();\n    return pathTemplate.replace(/{{date:YYYY-MM-DD}}/g, now.format(\"YYYY-MM-DD\")).replace(/{{date:YYYY}}/g, now.format(\"YYYY\")).replace(/{{date}}/g, now.format(\"YYYY-MM-DD\"));\n  }, []);\n\n  // 智能文件创建 - 支持模板\n  const ensureFileExists = useCallback(async filePath => {\n    try {\n      const existingFile = app.vault.getAbstractFileByPath(filePath);\n      if (existingFile) {\n        return {\n          created: false,\n          fromTemplate: false\n        };\n      }\n\n      // 如果文件不存在，使用模板创建\n      if (templateFile) {\n        await Files.createFileFromTemplate(app, filePath, templateFile);\n        return {\n          created: true,\n          fromTemplate: true\n        };\n      } else {\n        await Files.createFile(app, filePath, \"\");\n        return {\n          created: true,\n          fromTemplate: false\n        };\n      }\n    } catch (error) {\n      console.error(\"Failed to create file:\", error);\n      return null;\n    }\n  }, [app, templateFile]);\n  const handleSave = useCallback(async () => {\n    if (!inputText.trim()) {\n      new Obsidian.Notice(\"Nothing to save.\");\n      return;\n    }\n    setSaveStatus(\"saving\");\n    try {\n      const finalFilePath = resolveFilePath(targetFilePathTemplate);\n      const finalContent = processTemplate(contentTemplate, inputText);\n      const fileResult = await ensureFileExists(finalFilePath);\n      if (!fileResult) {\n        throw new Error(\"Failed to create target file\");\n      }\n      // awit 100ms\n      await new Promise(res => setTimeout(res, 100));\n      if (saveLocation === \"start\") {\n        await Markdowns.prependContent(app, finalFilePath, finalContent + \"\\n\");\n      } else if (saveLocation === \"end\") {\n        await Markdowns.appendContent(app, finalFilePath, \"\\n\" + finalContent);\n      } else if (saveLocation === \"under_heading\" && targetHeading) {\n        const headingLocation = {\n          heading: targetHeading,\n          includeSubHeadings: includeSubHeadings\n        };\n        await Markdowns.appendContentUnderHeading(app, finalFilePath, headingLocation, \"\\n\" + finalContent);\n      } else {\n        await Markdowns.appendContent(app, finalFilePath, \"\\n\" + finalContent);\n      }\n      setSaveStatus(\"success\");\n\n      // 提供更详细的成功消息\n      let successMessage = \"💡 Idea captured successfully!\";\n      if (fileResult.created && fileResult.fromTemplate) {\n        successMessage = \"� File created from template and idea captured!\";\n      } else if (fileResult.created) {\n        successMessage = \"📝 New file created and idea captured!\";\n      }\n      new Obsidian.Notice(successMessage);\n      setInputText(\"\");\n      saveData({\n        ...data,\n        inputText: \"\"\n      });\n      setTimeout(() => setSaveStatus(\"idle\"), 2000);\n    } catch (err) {\n      console.error(\"Failed to save idea:\", err);\n      setSaveStatus(\"error\");\n      let errorMessage = \"❌ Failed to save idea. Please check your settings.\";\n\n      // 提供更具体的错误信息\n      if (err.message?.includes(\"file\")) {\n        errorMessage = \"❌ Failed to create or access the target file.\";\n      } else if (err.message?.includes(\"heading\")) {\n        errorMessage = \"❌ Target heading not found. Please check the heading name.\";\n      }\n      new Obsidian.Notice(errorMessage);\n      setTimeout(() => setSaveStatus(\"idle\"), 3000);\n    }\n  }, [inputText, targetFilePathTemplate, contentTemplate, saveLocation, targetHeading, includeSubHeadings, templateFile, app, data, saveData, resolveFilePath, processTemplate, ensureFileExists]);\n  const handleKeyDown = useCallback(e => {\n    // Cmd/Ctrl + Enter 保存\n    if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {\n      e.preventDefault();\n      handleSave();\n    }\n    // 普通 Enter (不包含修饰键) 也保存，Shift+Enter 换行\n    else if (e.key === 'Enter' && !e.shiftKey && !e.metaKey && !e.ctrlKey) {\n      e.preventDefault();\n      handleSave();\n    }\n  }, [handleSave]);\n\n  // 字符计数和验证\n  const charCount = inputText.length;\n  const maxChars = 2000; // 增加字符限制，更实用\n  const isNearLimit = charCount > maxChars * 0.9;\n  const isOverLimit = charCount > maxChars;\n\n  // 添加快捷键提示\n  const placeholderText = useCallback(() => {\n    const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0;\n    const shortcut = isMac ? '⌘+Enter' : 'Ctrl+Enter';\n    const templateStatus = templateFile ? ' 📄 已配置模板' : '';\n    return `✨ 开始记录...${templateStatus} (${shortcut} 保存, Shift+Enter 换行)`;\n  }, [templateFile]);\n\n  // 获取保存按钮显示内容\n  const getSaveButtonContent = () => {\n    switch (saveStatus) {\n      case \"saving\":\n        return /*#__PURE__*/React.createElement(LucideIcon, {\n          name: \"loader\",\n          size: 16\n        });\n      case \"success\":\n        return /*#__PURE__*/React.createElement(LucideIcon, {\n          name: \"check\",\n          size: 16\n        });\n      case \"error\":\n        return /*#__PURE__*/React.createElement(LucideIcon, {\n          name: \"x\",\n          size: 16\n        });\n      default:\n        return /*#__PURE__*/React.createElement(LucideIcon, {\n          name: \"send\",\n          size: 16\n        });\n    }\n  };\n  const getSaveButtonClass = () => {\n    let baseClass = \"capture--SaveButton\";\n    switch (saveStatus) {\n      case \"saving\":\n        return baseClass + \" capture--SaveButton-loading\";\n      case \"success\":\n        return baseClass + \" capture--SaveButton-success\";\n      case \"error\":\n        return baseClass + \" capture--SaveButton-error\";\n      default:\n        return baseClass;\n    }\n  };\n  return /*#__PURE__*/React.createElement(\"div\", {\n    className: \"capture--Container\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"capture--InputArea\"\n  }, /*#__PURE__*/React.createElement(\"textarea\", {\n    className: \"capture--Textarea\",\n    value: inputText,\n    onChange: e => setInputText(e.target.value),\n    onKeyDown: handleKeyDown,\n    placeholder: placeholderText(),\n    maxLength: maxChars,\n    disabled: saveStatus === \"saving\"\n  }), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"capture--InputFooter\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"capture--CharCount\"\n  }, /*#__PURE__*/React.createElement(\"span\", {\n    className: isNearLimit ? \"capture--CharCount-warning\" : \"\"\n  }, charCount, \"/\", maxChars), isOverLimit && /*#__PURE__*/React.createElement(\"span\", {\n    className: \"capture--CharCount-error\"\n  }, \"Character limit exceeded!\")))), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"capture--ButtonContainer\"\n  }, /*#__PURE__*/React.createElement(\"button\", {\n    className: getSaveButtonClass(),\n    onClick: handleSave,\n    disabled: saveStatus === \"saving\" || !inputText.trim() || isOverLimit,\n    title: saveStatus === \"saving\" ? \"Saving...\" : isOverLimit ? \"Character limit exceeded\" : \"Save idea\"\n  }, getSaveButtonContent())));\n}",
        "success": true
