          },
          "obsidian42-brat": {
            "remark": "",
            "lastModified": "2025-10-05 22:11:54"
          },
          "copilot": {
            "remark": "在 Obsidian 中集成 AI 助手，让你能够通过指令让 AI 帮你撰写、总结、翻译或重构笔记内容",
            "lastModified": "2025-10-27 22:25:58"
          },
          "obsidian-custom-frames": {
            "remark": "可以将任何网页应用（如 Spotify, Notion, Todoist）作为标签页嵌入到 Obsidian 中，让你的知识管理中心一体化",
            "lastModified": "2025-10-27 22:26:24"
          },
          "obsidian-outliner": {
            "remark": "为喜欢用列表（bullet points）组织信息的用户优化体验。它提供了更符合大纲操作逻辑的拖放、折叠和键盘导航",
            "lastModified": "2025-10-27 22:28:43"
          },
          "table-editor-obsidian": {
            "remark": "在编辑 Markdown 表格时提供强大的辅助功能。它能自动格式化表格，支持通过快捷键调整行列，让表格的创建和维护变得非常轻松",
            "lastModified": "2025-10-27 22:25:16"
          },
          "calendar-beta": {
            "remark": " 在侧边栏创建一个简单的日历视图。你可以点击日期快速创建或跳转到对应的每日笔记，非常适合用于日记或日常记录",
            "lastModified": "2025-10-27 22:25:22"
          },
          "callout-manager": {
            "remark": "为 Obsidian 的“标注”功能（那些可折叠的彩色信息块）提供一个图形化界面，方便你创建、管理和切换不同类型的标注",
            "lastModified": "2025-10-27 22:25:28"
          },
          "oz-clear-unused-images": {
            "remark": "帮助你扫描并清理仓库中未被任何笔记引用的图片文件，释放存储空间，保持仓库整洁",
            "lastModified": "2025-10-27 22:25:37"
          },
          "convert-url-to-iframe": {
            "remark": "快速将选中的网页链接转换为嵌入的预览iframe，让你可以在笔记内直接查看网页内容",
            "lastModified": "2025-10-27 22:25:53"
          },
          "creases": {
            "remark": "允许你折叠（收起）Markdown 标题，并将折叠状态保存下来，即使关闭笔记再打开，之前折叠的部分也会保持原样",
            "lastModified": "2025-10-27 22:26:16"
          },
          "mermaid-popup": {
            "remark": "当你鼠标悬停在 Mermaid、Excalidraw 等图表链接上时，会弹出一个窗口实时预览图表内容，无需打开文件",
            "lastModified": "2025-10-27 22:26:35"
          },
          "obsidian-enhancing-export": {
            "remark": "增强 Obsidian 的导出功能（如 PDF, HTML），提供更多自定义选项，比如更好的样式支持、页眉页脚等",
            "lastModified": "2025-10-27 22:26:47"
          },
          "obsidian-excel-to-markdown-table": {
            "remark": "让你能够轻松地将 Excel 或 Google Sheets 中的表格数据粘贴为格式正确的 Markdown 表格",
            "lastModified": "2025-10-27 22:26:53"
          },
          "file-explorer-note-count": {
            "remark": "在文件浏览器的文件夹旁边显示其包含的笔记数量，让你对笔记的分布一目了然",
            "lastModified": "2025-10-27 22:26:57"
          },
          "obsidian-hover-editor": {
            "remark": "当你使用鼠标悬停在笔记链接上时，不再是一个简单的预览弹出框，而是一个完整的微型编辑器，可以直接在悬停窗口中编辑笔记",
            "lastModified": "2025-10-27 22:27:03"
          },
          "ibook": {
            "remark": "用于管理和同步 iBook（Apple Books）的高亮和笔记到 Obsidian 中",
            "lastModified": "2025-10-27 22:27:14"
          },
          "obsidian-importer": {
            "remark": "可以从许多其他笔记应用（如 Notion, Evernote, OneNote）中导入笔记、图片和附件到 Obsidian，迁移利器",
            "lastModified": "2025-10-27 22:27:18"
          },
          "diagram-zoom-drag": {
            "remark": "允许你在笔记中创建可交互的元素，如复选框、下拉菜单和按钮，提升笔记的交互性",
            "lastModified": "2025-10-27 22:27:26"
          },
          "journals": {
            "remark": "为日记类笔记提供便捷的导航和创建方式，通常与日历功能结合，方便你回顾过去和规划未来的日记",
            "lastModified": "2025-10-27 22:27:32"
          },
          "obsidian-linter": {
            "remark": "一个笔记“语法检查器”，可以自动格式化你的笔记，如统一标题格式、标准化标点符号、整理 YAML 属性等，保持笔记风格一致",
            "lastModified": "2025-10-27 22:27:41"
          },
          "make-md": {
            "remark": "一套全面的编辑和界面增强工具，提供滑箱编辑、块状页面预览、更美观的界面等，旨在提供类似 Notion 的现代化体验",
            "lastModified": "2025-10-27 22:27:51"
          },
          "media-extended": {
            "remark": "增强 Obsidian 内置的媒体播放器功能，支持播放速度调整、字幕、循环播放片段等，对视频学习笔记尤其有用",
            "lastModified": "2025-10-27 22:27:56"
          },
          "merge-notes": {
            "remark": "允许你将多个笔记文件合并为一个文件，并保留所有的链接和引用关系",
            "lastModified": "2025-10-27 22:28:04"
          },
          "metadata-menu": {
            "remark": "为笔记的 YAML 前置属性（metadata）提供一个强大的图形化编辑器，可以创建字段类型、选项列表等，让元数据管理变得直观",
            "lastModified": "2025-10-27 22:28:07"
          },
          "obsidian-mind-map": {
            "remark": "在笔记中直接将 Markdown 列表或标题渲染成一个可视化的思维导图",
            "lastModified": "2025-10-27 22:28:16"
          },
          "obisidian-note-linker": {
            "remark": "自动分析你的笔记内容，并建议链接到其他相关笔记，帮助你快速建立笔记之间的关联",
            "lastModified": "2025-10-27 22:28:23"
          },
          "note-refactor-obsidian": {
            "remark": "提供一系列重构笔记的工具，例如将选中的文本提取成一个新笔记，或将一个大型笔记按标题拆分成多个小笔记",
            "lastModified": "2025-10-27 22:28:35"
          },
          "pkmer": {
            "remark": "一个集成了多种功能的工具箱，包括模板管理、OCR文字识别、发布到博客等，旨在扩展 Obsidian 的个人知识管理能力",
            "lastModified": "2025-10-27 22:28:49"
          },
          "obsidian-regex-replace": {
            "remark": "使用正则表达式在单个文件或整个仓库中进行高级的查找和替换操作，适合批量处理内容",
            "lastModified": "2025-10-27 22:28:58"
          },
          "sentence-rhythm": {
            "remark": "一个面向写作者的插件，可以分析你文本的节奏和句子结构，帮助你改善写作的韵律和可读性",
            "lastModified": "2025-10-27 22:29:06"
          },
          "smart-connections": {
            "remark": "一个 AI 驱动的插件，利用本地或开放的 AI 模型分析你的笔记，帮你发现意想不到的笔记联系、回答问题并生成内容",
            "lastModified": "2025-10-27 22:29:13"
          },
          "obsidian-tasks-plugin": {
            "remark": "一个强大的任务管理插件。你可以使用特定语法在笔记中创建任务，然后通过查询在所有笔记中汇总、筛选和显示它们",
            "lastModified": "2025-10-27 22:29:21"
          },
          "templater-obsidian": {
            "remark": "一个比内置模板更强大的插件。它支持动态内容插入和执行 JavaScript 代码，可以实现高度自动化的笔记创建流程",
            "lastModified": "2025-10-27 22:29:29"
          },
          "obsidian-text-format": {
            "remark": "提供了一系列方便的文本格式化快捷键，例如转换大小写、对齐文本、添加下划线等，无需记忆复杂的快捷键",
            "lastModified": "2025-10-27 22:29:41"
          },
          "obsidian-textgenerator-plugin": {
            "remark": "在 Obsidian 中集成 OpenAI 的 GPT 模型，让你可以通过指令让 AI 帮你生成、扩展或优化文本内容",
            "lastModified": "2025-10-27 22:29:52"
          },
          "timekeep": {
            "remark": "一个简单的时间追踪器，允许你在笔记中记录你在不同任务或项目上花费的时间",
            "lastModified": "2025-10-27 22:30:01"
          },
          "obsidian-tracker": {
            "remark": "让你可以在笔记中创建图表，来可视化跟踪嵌入在文本中的数据（例如体重、心情、习惯打卡等）",
            "lastModified": "2025-10-27 22:30:10"
          },
          "obsidian-weread-plugin": {
            "remark": "让你可以直接在 Obsidian 中同步你的微信读书划线、笔记和想法，并自动生成格式化的笔记",
            "lastModified": "2025-10-27 22:30:22"
          },
          "yesterday": {
            "remark": "一个简单的插件，可以快速插入相对于今天的日期，例如“昨天”、“上周三”等，非常适合用于日记或日志记录",
            "lastModified": "2025-10-27 22:30:27"
          },
          "note-toolbar": {
            "remark": "一键点击完成最常用和最需要的操作，让你更专注于内容创作本身，而不是寻找功能按钮",
            "lastModified": "2025-11-05 14:55:42"
          }
        },
        "tags": {
          "增强插件": {
