ct.createElement(\"div\", {\n      className: `hotkey-manager--plugin-header ${pluginHasHotkeys ? 'hotkey-manager--plugin-has-hotkeys' : 'hotkey-manager--plugin-no-hotkeys'}`,\n      onClick: () => togglePluginCollapse(plugin),\n      title: isCollapsed ? \"点击展开\" : \"点击折叠\"\n    }, /*#__PURE__*/React.createElement(\"span\", {\n      className: \"hotkey-manager--collapse-icon\"\n    }, isCollapsed ? \"▶\" : \"▼\"), /*#__PURE__*/React.createElement(\"span\", {\n      className: \"hotkey-manager--plugin-name\"\n    }, plugin), /*#__PURE__*/React.createElement(\"span\", {\n      className: \"hotkey-manager--command-count\"\n    }, items.length, \" \\u6761\\u547D\\u4EE4\", hotkeyCount > 0 && /*#__PURE__*/React.createElement(\"span\", {\n      className: \"hotkey-manager--plugin-hotkey-count\"\n    }, \"(\", hotkeyCount, \" \\u4E2A\\u6709\\u5FEB\\u6377\\u952E)\"))), !isCollapsed && renderHotkeyTable(items));\n  }) : /*#__PURE__*/React.createElement(\"div\", {\n    className: \"hotkey-manager--empty-state\"\n  }, /*#__PURE__*/React.createElement(\"span\", {\n    className: \"hotkey-manager--empty-icon\"\n  }, \"\\u2328\\uFE0F\"), /*#__PURE__*/React.createElement(\"h3\", null, \"\\u672A\\u627E\\u5230\\u5FEB\\u6377\\u952E\"), /*#__PURE__*/React.createElement(\"p\", null, searchTerm || showHotkeyOnly ? `未找到匹配的内容${searchTerm ? `: \"${searchTerm}\"` : ''}${showHotkeyOnly ? ' (已启用\"仅显示有快捷键的命令\")' : ''}` : showAllWhenEmpty ? '正在加载快捷键...' : '输入关键词来搜索插件名称、命令名称、命令ID或快捷键'), (searchTerm || showHotkeyOnly) && /*#__PURE__*/React.createElement(\"button\", {\n    onClick: () => {\n      handleSearch(\"\");\n      setShowHotkeyOnly(false);\n    },\n    className: \"hotkey-manager--show-all-button\"\n  }, \"\\u663E\\u793A\\u6240\\u6709\\u547D\\u4EE4\"))));\n}",
