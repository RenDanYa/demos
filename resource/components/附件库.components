      "settingsCompilation": {
        "compiledCode": "function App() {\n  const {\n    getData,\n    saveData\n  } = useDataStorage();\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const {\n    username = \"Username\",\n    description = \"A short description\",\n    birthday = \"2000-01-01\",\n    obsidianStartDate = \"\",\n    avatarType = \"url\",\n    avatarUrl = \"https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=300\",\n    avatarFile = \"\",\n    heatmapYear = new Date().getFullYear().toString(),\n    colorSegments = [{\n      min: 0,\n      max: 0,\n      color: \"var(--background-primary)\"\n    }, {\n      min: 1,\n      max: 4,\n      color: \"hsl(140, 70%, 80%)\"\n    }, {\n      min: 5,\n      max: 10,\n      color: \"hsl(140, 70%, 60%)\"\n    }, {\n      min: 11,\n      max: 999,\n      color: \"hsl(140, 70%, 40%)\"\n    }],\n    dataSource = \"frontmatter\",\n    frontmatterField = \"created\"\n  } = settings;\n  const handleSave = (key, value) => {\n    saveData({\n      ...data,\n      settings: {\n        ...settings,\n        [key]: value\n      }\n    });\n  };\n  const handleColorSegmentChange = (index, field, value) => {\n    const newSegments = [...colorSegments];\n    if (field === 'min' || field === 'max') {\n      newSegments[index][field] = parseInt(value) || 0;\n    } else {\n      newSegments[index][field] = value;\n    }\n    handleSave(\"colorSegments\", newSegments);\n  };\n  const addColorSegment = () => {\n    const newSegments = [...colorSegments];\n    const lastSegment = newSegments[newSegments.length - 1];\n    const newMin = lastSegment ? lastSegment.max + 1 : 0;\n    const newMax = newMin + 5;\n    newSegments.push({\n      min: newMin,\n      max: newMax,\n      color: \"hsl(140, 70%, 50%)\"\n    });\n    handleSave(\"colorSegments\", newSegments);\n  };\n  const removeColorSegment = index => {\n    if (colorSegments.length <= 1) return;\n    const newSegments = colorSegments.filter((_, i) => i !== index);\n    handleSave(\"colorSegments\", newSegments);\n  };\n  return /*#__PURE__*/React.createElement(Settings, null, /*#__PURE__*/React.createElement(SettingTitle, null, \"\\u7528\\u6237\\u540D\\u7247\\u8BBE\\u7F6E\"), /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"\\u7528\\u6237\\u540D\",\n    type: \"text\",\n    value: username,\n    onChange: e => handleSave(\"username\", e.target.value),\n    placeholder: \"\\u8F93\\u5165\\u7528\\u6237\\u540D\"\n  }), /*#__PURE__*/React.createElement(SettingItem, {\n    label: \"\\u4E2A\\u4EBA\\u63CF\\u8FF0\"\n  }, /*#__PURE__*/React.createElement(\"textarea\", {\n    className: \"user-profile-form--textarea\",\n    value: description,\n    onChange: e => handleSave(\"description\", e.target.value),\n    placeholder: \"\\u8F93\\u5165\\u4E2A\\u4EBA\\u63CF\\u8FF0\",\n    rows: 3\n  })), /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"\\u751F\\u65E5\",\n    type: \"date\",\n    value: birthday,\n    max: \"9999-12-31\",\n    onChange: e => handleSave(\"birthday\", e.target.value)\n  }), /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"Obsidian \\u5F00\\u59CB\\u4F7F\\u7528\\u65E5\\u671F\",\n    type: \"date\",\n    value: obsidianStartDate,\n    max: \"9999-12-31\",\n    onChange: e => handleSave(\"obsidianStartDate\", e.target.value),\n    description: \"\\u7528\\u4E8E\\u8BA1\\u7B97\\u4F7F\\u7528\\u5929\\u6570\\u548C\\u7EDF\\u8BA1\\u4FE1\\u606F\"\n  }), /*#__PURE__*/React.createElement(SettingDivider, null), /*#__PURE__*/React.createElement(SettingTitle, null, \"\\u5934\\u50CF\\u8BBE\\u7F6E\"), /*#__PURE__*/React.createElement(SettingSelect, {\n    label: \"\\u5934\\u50CF\\u7C7B\\u578B\",\n    value: avatarType,\n    onChange: value => handleSave(\"avatarType\", value),\n    options: [{\n      label: \"图片链接\",\n      value: \"url\"\n    }, {\n      label: \"本地图片\",\n      value: \"file\"\n    }]\n  }), avatarType === \"url\" ? /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"\\u5934\\u50CF\\u94FE\\u63A5\",\n    type: \"text\",\n    value: avatarUrl,\n    onChange: e => handleSave(\"avatarUrl\", e.target.value),\n    placeholder: \"https://example.com/avatar.png\"\n  }) : /*#__PURE__*/React.createElement(FileSettingAutocomplete, {\n    label: \"\\u5934\\u50CF\\u6587\\u4EF6\",\n    value: avatarFile,\n    onChange: value => handleSave(\"avatarFile\", value),\n    filter: file => [\"png\", \"jpg\", \"jpeg\", \"gif\", \"svg\"].includes(file.extension),\n    placeholder: \"\\u4ECE\\u5E93\\u4E2D\\u9009\\u62E9\\u56FE\\u7247\\u6587\\u4EF6\"\n  }), /*#__PURE__*/React.createElement(SettingDivider, null), /*#__PURE__*/React.createElement(SettingTitle, null, \"\\u70ED\\u529B\\u56FE\\u8BBE\\u7F6E\"), /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"\\u70ED\\u529B\\u56FE\\u5E74\\u4EFD\",\n    type: \"number\",\n    value: heatmapYear,\n    min: \"2000\",\n    max: \"2100\",\n    onChange: e => handleSave(\"heatmapYear\", e.target.value),\n    placeholder: \"\\u8F93\\u5165\\u5E74\\u4EFD\",\n    description: \"\\u8BBE\\u7F6E\\u8981\\u663E\\u793A\\u7684\\u70ED\\u529B\\u56FE\\u5E74\\u4EFD\"\n  }), /*#__PURE__*/React.createElement(SettingSelect, {\n    label: \"\\u6570\\u636E\\u6765\\u6E90\",\n    value: dataSource,\n    onChange: value => handleSave(\"dataSource\", value),\n    options: [{\n      label: \"Frontmatter 字段\",\n      value: \"frontmatter\"\n    }, {\n      label: \"文件创建时间\",\n      value: \"fileCreation\"\n    }],\n    description: \"\\u9009\\u62E9\\u7EDF\\u8BA1\\u6587\\u4EF6\\u65E5\\u671F\\u7684\\u6570\\u636E\\u6765\\u6E90\"\n  }), dataSource === \"frontmatter\" && /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"Frontmatter \\u5B57\\u6BB5\\u540D\",\n    type: \"text\",\n    value: frontmatterField,\n    onChange: e => handleSave(\"frontmatterField\", e.target.value),\n    placeholder: \"created\",\n    description: \"\\u8BBE\\u7F6E\\u7528\\u4E8E\\u7EDF\\u8BA1\\u65E5\\u671F\\u7684 frontmatter \\u5B57\\u6BB5\\u540D\\u