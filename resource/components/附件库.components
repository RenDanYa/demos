        "compiledCode": "function App() {\n  const app = useObsidianApp();\n  const {\n    getData,\n    saveData\n  } = useDataStorage();\n\n  // 获取设置数据\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const pluginQuery = settings.pluginQuery || \"\";\n  const showAllWhenEmpty = settings.showAllWhenEmpty !== false;\n\n  // 状态管理\n  const [searchTerm, setSearchTerm] = useState(pluginQuery);\n  const [hotkeys, setHotkeys] = useState([]);\n  const [groupedHotkeys, setGroupedHotkeys] = useState({});\n  const [filteredGroupedHotkeys, setFilteredGroupedHotkeys] = useState({});\n  const [collapsedPlugins, setCollapsedPlugins] = useState(new Set());\n  const [showHotkeyOnly, setShowHotkeyOnly] = useState(false);\n\n  // 复制到剪贴板的函数\n  const copyToClipboard = useCallback(text => {\n    const el = document.createElement('textarea');\n    el.value = text;\n    document.body.appendChild(el);\n    el.select();\n    document.execCommand('copy');\n    document.body.removeChild(el);\n    new Obsidian.Notice(`已复制: ${text}`);\n  }, []);\n\n  // 获取完整的快捷键数据（修复版本）\n  const getHotkeyData = useCallback(() => {\n    if (!app?.hotkeyManager) return [];\n    const hotkeyList = [];\n    try {\n      // 从 hotkeyManager 获取所有快捷键\n      const hotkeyMap = app.hotkeyManager.getHotkeys();\n\n      // 遍历所有命令获取快捷键\n      const commands = app.commands.commands;\n      Object.keys(commands).forEach(commandId => {\n        const command = commands[commandId];\n        if (!command) return;\n        const pluginName = commandId.split(':')[0];\n\n        // 获取该命令的快捷键\n        let commandHotkeys = [];\n        let isCustom = false;\n\n        // 首先检查是否有自定义快捷键\n        if (app.hotkeyManager.customKeys && app.hotkeyManager.customKeys[commandId]) {\n          isCustom = true;\n          const customHotkeys = app.hotkeyManager.customKeys[commandId];\n          commandHotkeys = Array.isArray(customHotkeys) ? customHotkeys : [customHotkeys];\n        }\n        // 如果没有自定义快捷键，检查默认快捷键\n   