ge: e => updateSetting(\"targetHeading\", e.target.value)\n  }), /*#__PURE__*/React.createElement(SettingSwitch, {\n    label: \"\\u5305\\u542B\\u5B50\\u6807\\u9898\",\n    value: settings.includeSubHeadings === true,\n    onChange: value => updateSetting(\"includeSubHeadings\", value)\n  })), /*#__PURE__*/React.createElement(SettingDivider, null), /*#__PURE__*/React.createElement(SettingTitle, null, \"\\u5185\\u5BB9\\u6A21\\u677F\"), /*#__PURE__*/React.createElement(SettingDescription, null, \"\\u9009\\u62E9\\u9884\\u8BBE\\u6A21\\u677F\\u6216\\u81EA\\u5B9A\\u4E49\\u5185\\u5BB9\\u683C\\u5F0F\\u3002\"), /*#__PURE__*/React.createElement(SettingItem, {\n    label: \"\\u6A21\\u677F\\u9884\\u8BBE\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"capture-settings--PresetContainer\"\n  }, templatePresets.map((preset, index) => /*#__PURE__*/React.createElement(\"button\", {\n    key: index,\n    className: `capture-settings--PresetButton ${settings.contentTemplate === preset.value ? 'capture-settings--PresetButton-active' : ''}`,\n    onClick: () => handlePresetSelect(preset.value),\n    title: preset.description\n  }, preset.label)))), /*#__PURE__*/React.createElement(SettingItem, {\n    label: \"\\u81EA\\u5B9A\\u4E49\\u6A21\\u677F\"\n  }, /*#__PURE__*/React.createElement(\"textarea\", {\n    className: \"capture-settings--TemplateTextarea\",\n    value: settings.contentTemplate || \"{{text}}\",\n    onChange: e => updateSetting(\"contentTemplate\", e.target.value),\n    placeholder: \"\\u4F8B\\u5982: - {{date}} {{time}}: {{text}}\"\n  })), /*#__PURE__*/React.createElement(SettingDescription, null, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"capture-settings--TemplateHelp\"\n  }, /*#__PURE__*/React.createElement(\"strong\", null, \"\\u53EF\\u7528\\u53D8\\u91CF\\uFF1A\"), /*#__PURE__*/React.createElement(\"ul\", null, /*#__PURE__*/React.createElement(\"li\", null, /*#__PURE__*/React.createElement(\"code\", null, \"{{text}}\"), \" - \\u6