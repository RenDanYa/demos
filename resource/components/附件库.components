        "compiledCode": "function App() {\n  const {\n    getData,\n    saveData\n  } = useDataStorage();\n  const app = useObsidianApp();\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const checkinItems = settings.checkinItems || [];\n  const [dailyNoteOptions, setDailyNoteOptions] = useState(null);\n  const [currentDateNote, setCurrentDateNote] = useState(null);\n  useEffect(() => {\n    const options = DailyNotes.getDailyNoteOptions(app);\n    setDailyNoteOptions(options);\n    const checkTodayNote = async () => {\n      const today = moment().format(\"YYYY-MM-DD\");\n      try {\n        const note = await DailyNotes.getDailyNote(app, today);\n        setCurrentDateNote(note);\n      } catch (error) {\n        console.error(\"Failed to check today note:\", error);\n      }\n    };\n    checkTodayNote();\n  }, [app]);\n  const updateSettings = useCallback(newSettings => {\n    saveData({\n      ...data,\n      settings: {\n        ...settings,\n        ...newSettings\n      }\n    });\n  }, [data, settings, saveData]);\n  const addCheckinItem = useCallback(() => {\n    const defaultItem = {\n      name: \"新项目\",\n      icon: \"🙂\",\n      property: \"property\",\n      value: \"value\"\n    };\n    const updatedItems = [...checkinItems, defaultItem];\n    updateSettings({\n      checkinItems: updatedItems\n    });\n    new Obsidian.Notice(\"已添加新的打卡项目\");\n  }, [checkinItems, updateSettings]);\n  const removeCheckinItem = useCallback(index => {\n    const updatedItems = checkinItems.filter((_, i) => i !== index);\n    updateSettings({\n      checkinItems: updatedItems\n    });\n    new Obsidian.Notice(\"打卡项目已删除\");\n  }, [checkinItems, updateSettings]);\n  const updateCheckinItem = useCallback((index, field, value) => {\n    const updatedItems = [...checkinItems];\n    updatedItems[index] = {\n      ...updatedItems[index],\n      [field]: value\n    };\n    updateSettings({\n      checkinItems: updatedItems\n    });\n  }, [checkinItems, updateSettings]);\n  const moveItem = useCallback((fromIndex, direction) => {\n    const toIndex = direction === \"up\" ? fromIndex - 1 : fromIndex + 1;\n    if (toIndex < 0 || toIndex >= checkinItems.length) return;\n    const updatedItems = [...checkinItems];\n    [updatedItems[fromIndex], updatedItems[toIndex]] = [updatedItems[toIndex], updatedItems[fromIndex]];\n    updateSettings({\n      checkinItems: updatedItems\n    });\n  }, [checkinItems, updateSettings]);\n  return /*#__PURE__*/React.createElement(Settings, null, /*#__PURE__*/React.createElement(SettingTitle, null, \"\\u65E5\\u8BB0\\u914D\\u7F6E\"), /*#__PURE__*/React.createElement(SettingDescription, null, \"\\u6253\\u5361\\u6570\\u636E\\u5C06\\u81EA\\u52A8\\u4FDD\\u5B58\\u5230\\u65E5\\u8BB0\\u4E2D\\u3002\"), dailyNoteOptions ? /*#__PURE__*/React.createElement(React.Fragment, null, /*#__PURE__*/React.createElement(SettingItem, {\n    label: \"\\u65E5\\u8BB0\\u6587\\u4EF6\\u5939\"\n  }, /*#__PURE__*/React.createElement(\"span\", {\n    className: \"checkin-form--InfoValue\"\n  }, dailyNoteOptions.folder || \"库根目录\")), /*#__PURE__*/React.createElement(SettingItem, {\n    label: \"\\u65E5\\u671F\\u683C\\u5F0F\"\n  }, /*#__PURE__*/React.createElement(\"span\", {\n    className: \"checkin-form--InfoValue\"\n  }, dailyNoteOptions.format || \"YYYY-MM-DD\")), /*#__PURE__*/React.createElement(SettingItem, {\n    label: \"\\u6A21\\u677F\\u6587\\u4EF6\"\n  }, /*#__PURE__*/React.createElement(\"span\", {\n    className: \"checkin-form--InfoValue\"\n  }, dailyNoteOptions.template || \"无\")), /*#__PURE__*/React.createElement(SettingItem, {\n    label: \"\\u4ECA\\u65E5\\u65E5\\u8BB0\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"checkin-form--TodayNoteStatus\"\n  }, currentDateNote ? /*#__PURE__*/React.createElement(React.Fragment, null, /*#__PURE__*/React.createElement(LucideIcon, {\n    name: \"CheckCircle\",\n    size: 16,\n    color: \"var(--text-success)\"\n  }), /*#__PURE__*/React.createElement(\"span\", null, \"\\u5DF2\\u5B58\\u5728: \", currentDateNote.name)) : /*#__PURE__*/React.createElement(React.Fragment, null, /*#__PURE__*/React.createElement(LucideIcon, {\n    name: \"Plus\",\n    size: 16,\n    color: \"var(--text-muted)\"\n  }), /*#__PURE__*/React.createElement(\"span\", null, \"\\u9996\\u6B21\\u6253\\u5361\\u65F6\\u521B\\u5EFA\"))))) : /*#__PURE__*/React.createElement(SettingItem, {\n    label: \"\\u65E5\\u8BB0\\u72B6\\u6001\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"checkin-form--ErrorStatus\"\n  }, /*#__PURE__*/React.createElement(LucideIcon, {\n    name: \"AlertTriangle\",\n    size: 16,\n    color: \"var(--text-error)\"\n  }), /*#__PURE__*/React.createElement(\"span\", null, \"\\u65E5\\u8BB0\\u63D2\\u4EF6\\u672A\\u914D\\u7F6E\\u3002\\u8BF7\\u5728 Obsidian \\u8BBE\\u7F6E\\u4E2D\\u542F\\u7528\\u5B83\\u3002\"))), /*#__PURE__*/React.createElement(SettingDivider, null), /*#__PURE__*/React.createElement(SettingTitle, null, \"\\u6253\\u5361\\u9879\\u76EE\"), /*#__PURE__*/React.createElement(SettingDescription, {\n    style: {\n      display: \"block\"\n    }\n  }, /*#__PURE__*/React.createElement(\"p\", null, \"\\u6DFB\\u52A0\\u6253\\u5361\\u9879\\u76EE\\uFF0C\\u914D\\u7F6E\\u56FE\\u6807\\u3001\\u5C5E\\u6027\\u540D\\u548C\\u5C5E\\u6027\\u503C\\u3002\"), /*#__PURE__*/React.createElement(\"p\", null, \"\\u5982\\u679C\\u591A\\u4E2A\\u6253\\u5361\\u9879\\u8BBE\\u7F6E\\u4E3A\\u4E86\\u76F8\\u540C\\u7684\\u5C5E\\u6027\\u540D\\uFF0C\\u90A3\\u4E48\\u6253\\u5361\\u65F6\\u4F1A\\u8986\\u76D6\\u4E4B\\u524D\\u7684\\u503C\\uFF08\\u76F8\\u5F53\\u4E8E\\u53EA\\u80FD\\u70B9\\u4EAE\\u4E00\\u4E2A\\uFF09\", \" \")), /*#__PURE__*/React.createElement(SettingContent, {\n    label: \"\\u6253\\u5361\\u9879\\u76EE\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"checkin-form--TableWrapper\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"checkin-form--TableHeader\"\n  }, /*#__PURE__*/React.createElement(\"span\", null, \"\\u540D\\u79F0\"), /*#__PURE__*/React.createElement(\"span\", null, \"\\u56FE\\u6807\"), /*#__PURE__*/React.createElement(\"span\", null, \"\\u5C5E\\u6027\\u540D\"), /*#__PURE__*/React.createElement(\"span\", null, \"\\u5C5E\\u6027\\u503C\"), /*#__PURE__*/React.createElement(\"span\", {\n    className: \"checkin-form--HeaderActions\"\n  }, \"\\u64CD\\u4F5C\")), checkinItems.length > 0 ? checkinItems.map((item, index) => /*#__PURE__*/React.createElement(\"div\", {\n    key: index,\n    className: \"checkin-form--TableRow\"\n  }, /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"\",\n    className: \"checkin-form--TableInput\",\n    type: \"text\",\n    placeholder: \"\\u540D\\u79F0\",\n    \"aria-label\": \"\\u6253\\u5361\\u9879\\u76EE\\u540D\\u79F0\",\n    value: item.name,\n    onChange: event => updateCheckinItem(index, \"name\", event.target.value)\n  }), /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"\",\n    className: \"checkin-form--TableInput checkin-form--IconCell\",\n    type: \"text\",\n    placeholder: \"\\uD83D\\uDE42\",\n    \"aria-label\": \"\\u6253\\u5361\\u9879\\u76EE\\u56FE\\u6807\",\n    value: item.icon,\n    onChange: event => updateCheckinItem(index, \"icon\", event.target.value)\n  }), /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"\",\n    className: \"checkin-form--TableInput\",\n    type: \"text\",\n    placeholder: \"property\",\n    \"aria-label\": \"\\u6253\\u5361\\u9879\\u76EE\\u5C5E\\u6027\\u540D\",\n    value: item.property || \"\",\n    onChange: event => updateCheckinItem(index, \"property\", event.target.value)\n  }), /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"\",\n    className: \"checkin-form--TableInput\",\n    type: \"text\",\n    placeholder: \"value\",\n    \"aria-label\": \"\\u6253\\u5361\\u9879\\u76EE\\u5C5E\\u6027\\u503C\",\n    value: item.value || \"\",\n    onChange: event => updateCheckinItem(index, \"value\", event.target.value)\n  }), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"checkin-form--TableActions\"\n  }, /*#__PURE__*/React.createElement(\"button\", {\n    type: \"button\",\n    onClick: () => moveItem(index, \"up\"),\n    disabled: index === 0,\n    className: \"checkin-form--ActionButton\",\n    \"aria-label\": \"\\u4E0A\\u79FB\"\n  }, /*#__PURE__*/React.createElement(LucideIcon, {\n    name: \"ChevronUp\",\n    size: 16\n  })), /*#__PURE__*/React.createElement(\"button\", {\n    type: \"button\",\n    onClick: () => moveItem(index, \"down\"),\n    disabled: index === checkinItems.length - 1,\n    className: \"checkin-form--ActionButton\",\n    \"aria-label\": \"\\u4E0B\\u79FB\"\n  }, /*#__PURE__*/React.createElement(LucideIcon, {\n    name: \"ChevronDown\",\n    size: 16\n  })), /*#__PURE__*/React.createElement(\"button\", {\n    type: \"button\",\n    onClick: () => removeCheckinItem(index),\n    className: \"checkin-form--ActionButton checkin-form--RemoveButton\",\n    \"aria-label\": \"\\u5220\\u9664\\u9879\\u76EE\"\n  }, /*#__PURE__*/React.createElement(LucideIcon, {\n    name: \"Trash2\",\n    size: 16\n  }))))) : /*#__PURE__*/React.createElement(\"div\", {\n    className: \"checkin-form--EmptyTableRow\"\n  }, /*#__PURE__*/React.createElement(\"span\", null, \"\\u6682\\u65E0\\u6253\\u5361\\u9879\\u76EE\\uFF0C\\u70B9\\u51FB\\u4E0B\\u65B9\\u6309\\u94AE\\u6DFB\\u52A0\\u3002\")))), /*#__PURE__*/React.createElement(\"button\", {\n    type: \"button\",\n    onClick: addCheckinItem,\n    className: \"checkin-form--TableAddButton\"\n  }, /*#__PURE__*/React.createElement(LucideIcon, {\n    name: \"Plus\",\n    size: 16\n  }), \"\\u6DFB\\u52A0\\u6253\\u5361\\u9879\\u76EE\"));\n}",
        "success": true
      },
      "data": {
        "settings": {
          "checkinItems": [
            {
              "name": "超级开心",
              "icon": "🥳",
              "property": "morning_mood",
              "value": "🥳"
            },
            {
              "name": "平静愉悦",
              "icon": "😊",
              "property": "morning_mood",
              "value": "😊"
            },
            {
              "name": "状态不在线",
              "icon": "😡",
              "property": "morning_mood",
              "value": "😡"
            }
          ]
        }
      },
      "title": "上午心情打卡区"
    },
    {
      "id": "aac64e29-089f-43f4-adf5-2317e3c6f951",
      "type": "custom",
      "titleAlign": "center",
      "tabTitle": "下午心情打卡区",
      "maxWidthRatio": -1,
      "showBorder": true,
      "showTitle": true,
      "showShadow": true,
      "createAt": "2025-09-23T11:11:00.869Z",
      "updateAt": "2026-01-18T03:44:47.694Z",
      "viewCode": "function App() {\n  const { getData } = useDataStorage();\n  const app = useObsidianApp();\n  const data = getData() || {};\n  const settings = data.settings || {};\n\n  const checkinItems = settings.checkinItems || [];\n\n  const [checkinStates, setCheckinStates] = useState({});\n  const [isLoading, setIsLoading] = useState(false);\n  const [currentDate] = useState(moment().format(\"YYYY-MM-DD\"));\n\n  const normalizeValue = useCallback((value) => {\n    if (value === undefined || value === null) {\n      return \"\";\n    }\n    if (Array.isArray(value)) {\n      return value\n        .map((item) =>\n          item === undefined || item === null ? \"\" : String(item).trim()\n        )\n        .join(\",\");\n    }\n    return String(value).trim();\n  }, []);\n\n  // 读取今日日记的 frontmatter\n  const loadCheckinStates = async () => {\n    try {\n      const dailyNote = await DailyNotes.getDailyNote(app, currentDate);\n      if (!dailyNote) {\n        // 如果今日日记不存在，返回空状态，不创建文件\n        setCheckinStates({});\n        return;\n      }\n\n      const metadata = app.metadataCache.getFileCache(dailyNote);\n      const frontmatter = metadata?.frontmatter || {};\n\n      const states = {};\n      checkinItems.forEach((item) => {\n        const propertyName = item.property || item.name;\n        const expectedValue = item.value || \"true\";\n        const actualValue = frontmatter[propertyName];\n\n        states[item.name] =\n          normalizeValue(actualValue) === normalizeValue(expectedValue);\n      });\n\n      setCheckinStates(states);\n    } catch (error) {\n      console.error(\"Failed to load checkin states:\", error);\n    }\n  };\n\n  // 切换打卡状态\n  const toggleCheckin = useCallback(\n    async (itemName) => {\n      if (isLoading) return;\n\n      const item = checkinItems.find(\n        (candidate) => candidate.name === itemName\n      );\n      if (!item) return;\n\n      setIsLoading(true);\n      try {\n        const dailyNote = await DailyNotes.createDailyNote(app, currentDate);\n        const propertyName = item.property || item.name;\n        const expectedValue = item.value || \"true\";\n\n        let updatedFrontmatterSnapshot = null;\n        let nextState = false;\n\n        await app.fileManager.processFrontMatter(\n          dailyNote,\n          (frontmatterDraft) => {\n            // 借助 Obsidian 提供的 Frontmatter 编辑 API，避免手动解析 YAML\n            const currentValue = normalizeValue(frontmatterDraft[propertyName]);\n            const expectedNormalized = normalizeValue(expectedValue);\n\n            if (currentValue === expectedNormalized) {\n              delete frontmatterDraft[propertyName];\n              nextState = false;\n            } else {\n              frontmatterDraft[propertyName] = expectedValue;\n              nextState = true;\n            }\n\n            const snapshot = { ...frontmatterDraft };\n            delete snapshot.position;\n            updatedFrontmatterSnapshot = snapshot;\n          }\n        );\n\n        if (updatedFrontmatterSnapshot) {\n          const states = {};\n          checkinItems.forEach((checkItem) => {\n            const propertyKey = checkItem.property || checkItem.name;\n            const expected = checkItem.value || \"true\";\n            const actual = updatedFrontmatterSnapshot[propertyKey];\n            states[checkItem.name] =\n              normalizeValue(actual) === normalizeValue(expected);\n          });\n          setCheckinStates(states);\n        }\n\n        new Obsidian.Notice(`${itemName} ${nextState ? \"已打卡\" : \"已取消\"}`);\n      } catch (error) {\n        console.error(\"Failed to toggle checkin:\", error);\n        new Obsidian.Notice(\"更新打卡状态失败：\" + error.message);\n      } finally {\n        setIsLoading(false);\n      }\n    },\n    [app, checkinItems, currentDate, isLoading, normalizeValue]\n  );\n\n  // 监听文件变更\n  useEffect(() => {\n    app.vault.on(\"components:file-indexed\", loadCheckinStates);\n    return () => {\n      app.vault.off(\"components:file-indexed\", loadCheckinStates);\n    };\n  }, [loadCheckinStates, app]);\n\n  // 初始加载\n  useEffect(() => {\n    loadCheckinStates();\n  }, []);\n\n  if (!checkinItems.length) {\n    return (\n      <div className=\"checkin--EmptyState\">\n        <p>没有配置打卡项目</p>\n        <p>请在设置中添加打卡项目</p>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"checkin--Container\">\n      <div className=\"checkin--ItemsGrid\">\n        {checkinItems.map((item, index) => {\n          const isChecked = checkinStates[item.name] || false;\n\n          return (\n            <button\n              key={`${item.name}-${index}`}\n              className={`checkin--Item ${\n                isChecked ? \"checkin--Item-checked\" : \"checkin--Item-unchecked\"\n              }`}\n              onClick={() => toggleCheckin(item.name)}\n              disabled={isLoading}\n              aria-label={item.name}\n              title={item.name}\n            >\n              <span className=\"checkin--Emoji\">{item.icon}</span>\n            </button>\n          );\n        })}\n      </div>\n    </div>\n  );\n}\n",
      "settingsCode": "function App() {\n  const { getData, saveData } = useDataStorage();\n  const app = useObsidianApp();\n  const data = getData() || {};\n  const settings = data.settings || {};\n\n  const checkinItems = settings.checkinItems || [];\n  const [dailyNoteOptions, setDailyNoteOptions] = useState(null);\n  const [currentDateNote, setCurrentDateNote] = useState(null);\n\n  useEffect(() => {\n    const options = DailyNotes.getDailyNoteOptions(app);\n    setDailyNoteOptions(options);\n\n    const checkTodayNote = async () => {\n      const today = moment().format(\"YYYY-MM-DD\");\n      try {\n        const note = await DailyNotes.getDailyNote(app, today);\n        setCurrentDateNote(note);\n      } catch (error) {\n        console.error(\"Failed to check today note:\", error);\n      }\n    };\n\n    checkTodayNote();\n  }, [app]);\n\n  const updateSettings = useCallback(\n    (newSettings) => {\n      saveData({\n        ...data,\n        settings: {\n          ...settings,\n          ...newSettings,\n        },\n      });\n    },\n    [data, settings, saveData]\n  );\n\n  const addCheckinItem = useCallback(() => {\n    const defaultItem = {\n      name: \"新项目\",\n      icon: \"🙂\",\n      property: \"property\",\n      value: \"value\",\n    };\n\n    const updatedItems = [...checkinItems, defaultItem];\n    updateSettings({ checkinItems: updatedItems });\n    new Obsidian.Notice(\"已添加新的打卡项目\");\n  }, [checkinItems, updateSettings]);\n\n  const removeCheckinItem = useCallback(\n    (index) => {\n      const updatedItems = checkinItems.filter((_, i) => i !== index);\n      updateSettings({ checkinItems: updatedItems });\n      new Obsidian.Notice(\"打卡项目已删除\");\n    },\n    [checkinItems, updateSettings]\n  );\n\n  const updateCheckinItem = useCallback(\n    (index, field, value) => {\n      const updatedItems = [...checkinItems];\n      updatedItems[index] = {\n        ...updatedItems[index],\n        [field]: value,\n      };\n      updateSettings({ checkinItems: updatedItems });\n    },\n    [checkinItems, updateSettings]\n  );\n\n  const moveItem = useCallback(\n    (fromIndex, direction) => {\n      const toIndex = direction === \"up\" ? fromIndex - 1 : fromIndex + 1;\n      if (toIndex < 0 || toIndex >= checkinItems.length) return;\n\n      const updatedItems = [...checkinItems];\n      [updatedItems[fromIndex], updatedItems[toIndex]] = [\n        updatedItems[toIndex],\n        updatedItems[fromIndex],\n      ];\n      updateSettings({ checkinItems: updatedItems });\n    },\n    [checkinItems, updateSettings]\n  );\n\n  return (\n    <Settings>\n      <SettingTitle>日记配置</SettingTitle>\n\n      <SettingDescription>打卡数据将自动保存到日记中。</SettingDescription>\n\n      {dailyNoteOptions ? (\n        <>\n          <SettingItem label=\"日记文件夹\">\n            <span className=\"checkin-form--InfoValue\">\n              {dailyNoteOptions.folder || \"库根目录\"}\n            </span>\n          </SettingItem>\n\n          <SettingItem label=\"日期格式\">\n            <span className=\"checkin-form--InfoValue\">\n              {dailyNoteOptions.format || \"YYYY-MM-DD\"}\n            </span>\n          </SettingItem>\n\n          <SettingItem label=\"模板文件\">\n            <span className=\"checkin-form--InfoValue\">\n              {dailyNoteOptions.template || \"无\"}\n            </span>\n          </SettingItem>\n\n          <SettingItem label=\"今日日记\">\n            <div className=\"checkin-form--TodayNoteStatus\">\n              {currentDateNote ? (\n                <>\n                  <LucideIcon\n                    name=\"CheckCircle\"\n                    size={16}\n                    color=\"var(--text-success)\"\n                  />\n                  <span>已存在: {currentDateNote.name}</span>\n                </>\n              ) : (\n                <>\n                  <LucideIcon name=\"Plus\" size={16} color=\"var(--text-muted)\" />\n                  <span>首次打卡时创建</span>\n                </>\n              )}\n            </div>\n          </SettingItem>\n        </>\n      ) : (\n        <SettingItem label=\"日记状态\">\n          <div className=\"checkin-form--ErrorStatus\">\n            <LucideIcon\n              name=\"AlertTriangle\"\n              size={16}\n              color=\"var(--text-error)\"\n            />\n            <span>日记插件未配置。请在 Obsidian 设置中启用它。</span>\n          </div>\n        </SettingItem>\n      )}\n\n      <SettingDivider />\n\n      <SettingTitle>打卡项目</SettingTitle>\n\n      <SettingDescription style={{ display: \"block\" }}>\n        <p>添加打卡项目，配置图标、属性名和属性值。</p>\n        <p>\n          如果多个打卡项设置为了相同的属性名，那么打卡时会覆盖之前的值（相当于只能点亮一个）{\" \"}\n        </p>\n      </SettingDescription>\n\n      <SettingContent label=\"打卡项目\">\n        <div className=\"checkin-form--TableWrapper\">\n          <div className=\"checkin-form--TableHeader\">\n            <span>名称</span>\n            <span>图标</span>\n            <span>属性名</span>\n            <span>属性值</span>\n            <span className=\"checkin-form--HeaderActions\">操作</span>\n          </div>\n          {checkinItems.length > 0 ? (\n            checkinItems.map((item, index) => (\n              <div key={index} className=\"checkin-form--TableRow\">\n                <SettingInput\n                  label=\"\"\n                  className=\"checkin-form--TableInput\"\n                  type=\"text\"\n                  placeholder=\"名称\"\n                  aria-label=\"打卡项目名称\"\n                  value={item.name}\n                  onChange={(event) =>\n                    updateCheckinItem(index, \"name\", event.target.value)\n                  }\n                />\n                <SettingInput\n                  label=\"\"\n                  className=\"checkin-form--TableInput checkin-form--IconCell\"\n                  type=\"text\"\n                  placeholder=\"🙂\"\n                  aria-label=\"打卡项目图标\"\n                  value={item.icon}\n                  onChange={(event) =>\n                    updateCheckinItem(index, \"icon\", event.target.value)\n                  }\n                />\n                <SettingInput\n                  label=\"\"\n                  className=\"checkin-form--TableInput\"\n                  type=\"text\"\n                  placeholder=\"property\"\n                  aria-label=\"打卡项目属性名\"\n                  value={item.property || \"\"}\n                  onChange={(event) =>\n                    updateCheckinItem(index, \"property\", event.target.value)\n                  }\n                />\n                <SettingInput\n                  label=\"\"\n                  className=\"checkin-form--TableInput\"\n                  type=\"text\"\n                  placeholder=\"value\"\n                  aria-label=\"打卡项目属性值\"\n                  value={item.value || \"\"}\n                  onChange={(event) =>\n                    updateCheckinItem(index, \"value\", event.target.value)\n                  }\n                />\n                <div className=\"checkin-form--TableActions\">\n                  <button\n                    type=\"button\"\n                    onClick={() => moveItem(index, \"up\")}\n                    disabled={index === 0}\n                    className=\"checkin-form--ActionButton\"\n                    aria-label=\"上移\"\n                  >\n                    <LucideIcon name=\"ChevronUp\" size={16} />\n                  </button>\n                  <button\n                    type=\"button\"\n                    onClick={() => moveItem(index, \"down\")}\n                    disabled={index === checkinItems.length - 1}\n                    className=\"checkin-form--ActionButton\"\n                    aria-label=\"下移\"\n                  >\n                    <LucideIcon name=\"ChevronDown\" size={16} />\n                  </button>\n                  <button\n                    type=\"button\"\n                    onClick={() => removeCheckinItem(index)}\n                    className=\"checkin-form--ActionButton checkin-form--RemoveButton\"\n                    aria-label=\"删除项目\"\n                  >\n                    <LucideIcon name=\"Trash2\" size={16} />\n                  </button>\n                </div>\n              </div>\n            ))\n          ) : (\n            <div className=\"checkin-form--EmptyTableRow\">\n              <span>暂无打卡项目，点击下方按钮添加。</span>\n            </div>\n          )}\n        </div>\n      </SettingContent>\n      <button\n        type=\"button\"\n        onClick={addCheckinItem}\n        className=\"checkin-form--TableAddButton\"\n      >\n        <LucideIcon name=\"Plus\" size={16} />\n        添加打卡项目\n      </button>\n    </Settings>\n  );\n}\n",
      "cssCode": "/* 打卡签到组件样式 */\n\n/* 主容器 */\n.checkin--Container {\n  padding: 8px;\n  background-color: transparent;\n  border-radius: var(--radius-m);\n  --checkin-background-opacity: 0.62;\n}\n\n/* 图标网格布局 */\n.checkin--ItemsGrid {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 6px;\n  align-items: center;\n}\n\n/* 打卡项按钮 */\nbutton:not(.clickable-icon).checkin--Item {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 32px;\n  height: 32px;\n  border: 1px solid var(--background-modifier-border);\n  border-radius: var(--radius-m);\n  background-color: var(--background-secondary-alt);\n  cursor: pointer;\n  transition: background-color 0.15s ease, transform 0.15s ease;\n  padding: 0;\n  box-shadow: none;\n}\n\nbutton:not(.clickable-icon).checkin--Item:hover {\n  background-color: var(--background-modifier-hover);\n  transform: translateY(-1px);\n}\n\nbutton:not(.clickable-icon).checkin--Item:active {\n  transform: scale(0.95);\n}\n\nbutton:not(.clickable-icon).checkin--Item:disabled {\n  opacity: 0.45;\n  cursor: not-allowed;\n  transform: none;\n}\n\n/* 已打卡状态 - 循环颜色 */\nbutton:not(.clickable-icon).checkin--Item-checked {\n  background-color: transparent;\n}\n\nbutton:not(.clickable-icon).checkin--Item-checked:nth-child(7n + 1) {\n  background-color: rgba(\n    var(--color-red-rgb),\n    var(--checkin-background-opacity)\n  );\n  color: var(--text-on-accent);\n}\n\nbutton:not(.clickable-icon).checkin--Item-checked:nth-child(7n + 2) {\n  background-color: rgba(\n    var(--color-orange-rgb),\n    var(--checkin-background-opacity)\n  );\n  color: var(--text-on-accent);\n}\n\nbutton:not(.clickable-icon).checkin--Item-checked:nth-child(7n + 3) {\n  background-color: rgba(\n    var(--color-yellow-rgb),\n    var(--checkin-background-opacity)\n  );\n  color: var(--text-normal);\n}\n\nbutton:not(.clickable-icon).checkin--Item-checked:nth-child(7n + 4) {\n  background-color: rgba(\n    var(--color-green-rgb),\n    var(--checkin-background-opacity)\n  );\n  color: var(--text-on-accent);\n}\n\nbutton:not(.clickable-icon).checkin--Item-checked:nth-child(7n + 5) {\n  background-color: rgba(\n    var(--color-cyan-rgb),\n    var(--checkin-background-opacity)\n  );\n  color: var(--text-on-accent);\n}\n\nbutton:not(.clickable-icon).checkin--Item-checked:nth-child(7n + 6) {\n  background-color: rgba(\n    var(--color-blue-rgb),\n    var(--checkin-background-opacity)\n  );\n  color: var(--text-on-accent);\n}\n\nbutton:not(.clickable-icon).checkin--Item-checked:nth-child(7n + 7) {\n  background-color: rgba(\n    var(--color-purple-rgb),\n    var(--checkin-background-opacity)\n  );\n  color: var(--text-on-accent);\n}\n\n/* 未打卡状态 */\nbutton:not(.clickable-icon).checkin--Item-unchecked .checkin--Emoji {\n  color: var(--text-muted);\n  filter: grayscale(100%);\n}\n\nbutton:not(.clickable-icon).checkin--Item-unchecked:hover .checkin--Emoji {\n  filter: grayscale(40%);\n}\n\n/* 图标样式 */\n.checkin--Emoji {\n  font-size: 16px;\n  line-height: 1;\n}\n\n/* 空状态 */\n.checkin--EmptyState {\n  padding: 24px 16px;\n  text-align: center;\n  color: var(--text-muted);\n  background: color-mix(in srgb, var(--background-secondary) 92%, transparent);\n  border-radius: calc(var(--radius-l) + 2px);\n  border: 1px dashed\n    color-mix(in srgb, var(--background-modifier-border) 80%, transparent);\n  box-shadow: inset 0 0 0 1px\n    color-mix(in srgb, var(--background-modifier-border) 35%, transparent);\n}\n\n.checkin--EmptyState p {\n  margin: 6px 0;\n}\n\n/* 设置表单样式 */\n.checkin-form--TableWrapper {\n  width: 100%;\n  border: 1px solid var(--background-modifier-border);\n  border-radius: var(--radius-m);\n  overflow: auto;\n  max-width: 500px;\n  background-color: color-mix(in srgb, var(--background-secondary) 92%, transparent);\n}\n\n.checkin-form--TableHeader,\n.checkin-form--TableRow {\n  display: grid;\n  grid-template-columns: 1.4fr 0.9fr 1.2fr 1.2fr 0.9fr;\n  gap: 8px;\n  align-items: center;\n  padding: 8px 12px;\n}\n\n.checkin-form--TableHeader {\n  background-color: color-mix(in srgb, var(--background-secondary) 80%, transparent);\n  font-size: var(--font-ui-small);\n  color: var(--text-muted);\n  font-weight: 600;\n}\n\n.checkin-form--TableRow {\n  border-top: 1px solid color-mix(in srgb, var(--background-modifier-border) 80%, transparent);\n  background-color: color-mix(in srgb, var(--background-secondary) 70%, transparent);\n}\n\n.checkin-form--TableRow label {\n  display: none;\n}\n\n.checkin-form--TableInput {\n  width: 100%;\n}\n\n.checkin-form--TableInput input {\n  width: 100%;\n  min-width: 0;\n}\n\n.checkin-form--IconCell input {\n  text-align: center;\n  font-size: var(--font-ui-medium);\n}\n\n.checkin-form--TableActions {\n  display: flex;\n  gap: 4px;\n  justify-content: flex-end;\n}\n\n.checkin-form--HeaderActions {\n  text-align: right;\n}\n\n.checkin-form--EmptyTableRow {\n  display: block;\n  padding: 16px 12px;\n  text-align: center;\n  color: var(--text-muted);\n}\n\n.checkin-form--TableAddButton {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  margin-top: 12px;\n  padding: 8px 12px;\n  border-radius: var(--radius-s);\n  border: 1px solid var(--interactive-accent);\n  background-color: var(--interactive-accent);\n  color: var(--text-on-accent);\n  font-size: var(--font-ui-smaller);\n  cursor: pointer;\n  transition: background-color 0.2s ease, transform 0.2s ease;\n}\n\n.checkin-form--TableAddButton:hover {\n  background-color: var(--interactive-accent-hover);\n}\n\n.checkin-form--TableAddButton:active {\n  transform: scale(0.98);\n}\n\nbutton:not(.clickable-icon).checkin-form--ActionButton {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 28px;\n  height: 28px;\n  border: 1px solid var(--background-modifier-border);\n  border-radius: var(--radius-s);\n  background-color: var(--background-secondary);\n  color: var(--text-muted);\n  cursor: pointer;\n  transition: all 0.2s ease;\n  padding: 0;\n}\n\nbutton:not(.clickable-icon).checkin-form--ActionButton:hover {\n  background-color: var(--background-modifier-hover);\n  color: var(--text-normal);\n}\n\nbutton:not(.clickable-icon).checkin-form--ActionButton:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\nbutton:not(.clickable-icon).checkin-form--RemoveButton {\n  color: var(--text-error);\n}\n\nbutton:not(.clickable-icon).checkin-form--RemoveButton:hover {\n  background-color: color-mix(\n    in srgb,\n    var(--text-error) 10%,\n    var(--background-secondary)\n  );\n}\n\n/* 添加新项目区域 */\n.checkin-form--AddItemContainer {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.checkin-form--AddItemInputs {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n}\n\n/* 日记配置信息样式 */\n.checkin-form--InfoValue {\n  color: var(--text-normal);\n  font-family: var(--font-monospace);\n  font-size: var(--font-ui-smaller);\n  padding: 4px 8px;\n  background-color: var(--background-secondary);\n  border-radius: var(--radius-s);\n  border: 1px solid var(--background-modifier-border);\n}\n\n.checkin-form--TodayNoteStatus {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  color: var(--text-normal);\n  font-size: var(--font-ui-smaller);\n}\n\n.checkin-form--ErrorStatus {\n  display: flex;\n  align-items: flex-start;\n  gap: 6px;\n  color: var(--text-error);\n  font-size: var(--font-ui-smaller);\n  line-height: 1.4;\n  max-width: 100%;\n  word-wrap: break-word;\n  overflow-wrap: break-word;\n}\n\n.checkin-form--ErrorStatus span {\n  flex: 1;\n  min-width: 0;\n}\n\n/* 设置描述文本样式优化 */\n.setting-item-description {\n  word-wrap: break-word;\n  overflow-wrap: break-word;\n  max-width: 100%;\n  line-height: 1.4;\n}\n\n/* 响应式设计（表单） */\n@media (max-width: 768px) {\n  .checkin-form--TableHeader,\n  .checkin-form--TableRow {\n    grid-template-columns: 1fr;\n    gap: 6px;\n  }\n\n  .checkin-form--TableRow {\n    padding: 12px;\n  }\n\n  .checkin-form--TableActions {\n    justify-content: flex-start;\n  }\n}\n",
      "viewCompilation": {
        "compiledCode": "function App() {\n  const {\n    getData\n  } = useDataStorage();\n  const app = useObsidianApp();\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const checkinItems = settings.checkinItems || [];\n  const [checkinStates, setCheckinStates] = useState({});\n  const [isLoading, setIsLoading] = useState(false);\n  const [currentDate] = useState(moment().format(\"YYYY-MM-DD\"));\n  const normalizeValue = useCallback(value => {\n    if (value === undefined || value === null) {\n      return \"\";\n    }\n    if (Array.isArray(value)) {\n      return value.map(item => item === undefined || item === null ? \"\" : String(item).trim()).join(\",\");\n    }\n    return String(value).trim();\n  }, []);\n\n  // 读取今日日记的 frontmatter\n  const loadCheckinStates = async () => {\n    try {\n      const dailyNote = await DailyNotes.getDailyNote(app, currentDate);\n      if (!dailyNote) {\n        // 如果今日日记不存在，返回空状态，不创建文件\n        setCheckinStates({});\n        return;\n      }\n      const metadata = app.metadataCache.getFileCache(dailyNote);\n      const frontmatter = metadata?.frontmatter || {};\n      const states = {};\n      checkinItems.forEach(item => {\n        const propertyName = item.property || item.name;\n        const expectedValue = item.value || \"true\";\n        const actualValue = frontmatter[propertyName];\n        states[item.name] = normalizeValue(actualValue) === normalizeValue(expectedValue);\n      });\n      setCheckinStates(states);\n    } catch (error) {\n      console.error(\"Failed to load checkin states:\", error);\n    }\n  };\n\n  // 切换打卡状态\n  const toggleCheckin = useCallback(async itemName => {\n    if (isLoading) return;\n    const item = checkinItems.find(candidate => candidate.name === itemName);\n    if (!item) return;\n    setIsLoading(true);\n    try {\n      const dailyNote = await DailyNotes.createDailyNote(app, currentDate);\n      const propertyName = item.property || item.name;\n      const expectedValue = item.value || \"true\";\n      let updatedFrontmatterSnapshot = null;\n      let nextState = false;\n      await app.fileManager.processFrontMatter(dailyNote, frontmatterDraft => {\n        // 借助 Obsidian 提供的 Frontmatter 编辑 API，避免手动解析 YAML\n        const currentValue = normalizeValue(frontmatterDraft[propertyName]);\n        const expectedNormalized = normalizeValue(expectedValue);\n        if (currentValue === expectedNormalized) {\n          delete frontmatterDraft[propertyName];\n          nextState = false;\n        } else {\n          frontmatterDraft[propertyName] = expectedValue;\n          nextState = true;\n        }\n        const snapshot = {\n          ...frontmatterDraft\n        };\n        delete snapshot.position;\n        updatedFrontmatterSnapshot = snapshot;\n      });\n      if (updatedFrontmatterSnapshot) {\n        const states = {};\n        checkinItems.forEach(checkItem => {\n          const propertyKey = checkItem.property || checkItem.name;\n          const expected = checkItem.value || \"true\";\n          const actual = updatedFrontmatterSnapshot[propertyKey];\n          states[checkItem.name] = normalizeValue(actual) === normalizeValue(expected);\n        });\n        setCheckinStates(states);\n      }\n      new Obsidian.Notice(`${itemName} ${nextState ? \"已打卡\" : \"已取消\"}`);\n    } catch (error) {\n      console.error(\"Failed to toggle checkin:\", error);\n      new Obsidian.Notice(\"更新打卡状态失败：\" + error.message);\n    } finally {\n      setIsLoading(false);\n    }\n  }, [app, checkinItems, currentDate, isLoading, normalizeValue]);\n\n  // 监听文件变更\n  useEffect(() => {\n    app.vault.on(\"components:file-indexed\", loadCheckinStates);\n    return () => {\n      app.vault.off(\"components:file-indexed\", loadCheckinStates);\n    };\n  }, [loadCheckinStates, app]);\n\n  // 初始加载\n  useEffect(() => {\n    loadCheckinStates();\n  }, []);\n  if (!checkinItems.length) {\n    return /*#__PURE__*/React.createElement(\"div\", {\n      className: \"checkin--EmptyState\"\n    }, /*#__PURE__*/React.createElement(\"p\", null, \"\\u6CA1\\u6709\\u914D\\u7F6E\\u6253\\u5361\\u9879\\u76EE\"), /*#__PURE__*/React.createElement(\"p\", null, \"\\u8BF7\\u5728\\u8BBE\\u7F6E\\u4E2D\\u6DFB\\u52A0\\u6253\\u5361\\u9879\\u76EE\"));\n  }\n  return /*#__PURE__*/React.createElement(\"div\", {\n    className: \"checkin--Container\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"checkin--ItemsGrid\"\n  }, checkinItems.map((item, index) => {\n    const isChecked = checkinStates[item.name] || false;\n    return /*#__PURE__*/React.createElement(\"button\", {\n      key: `${item.name}-${index}`,\n      className: `checkin--Item ${isChecked ? \"checkin--Item-checked\" : \"checkin--Item-unchecked\"}`,\n      onClick: () => toggleCheckin(item.name),\n      disabled: isLoading,\n      \"aria-label\": item.name,\n      title: item.name\n    }, /*#__PURE__*/React.createElement(\"span\", {\n      className: \"checkin--Emoji\"\n    }, item.icon));\n  })));\n}",
