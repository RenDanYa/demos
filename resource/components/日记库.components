        "compiledCode": "// recent-files 设置项源码 (现为最近修改文件)\n// 提供：显示条数配置（按修改时间排序）\n\nfunction App() {\n  const {\n    getData,\n    saveData\n  } = useDataStorage();\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const limit = settings.limit ?? '';\n  const update = patch => {\n    saveData({\n      ...data,\n      settings: {\n        ...settings,\n        ...patch\n      }\n    });\n  };\n  return /*#__PURE__*/React.createElement(Settings, null, /*#__PURE__*/React.createElement(SettingTitle, null, \"Recent Modified \\u8BBE\\u7F6E\"), /*#__PURE__*/React.createElement(SettingInput, {\n    label: \"\\u663E\\u793A\\u6761\\u6570 (\\u4FEE\\u6539)\",\n    type: \"number\",\n    min: 1,\n    value: limit,\n    placeholder: \"\\u4F8B\\u5982 50\",\n    onChange: e => {\n      const v = e.target.value;\n      update({\n        limit: v\n      });\n    }\n  }), /*#__PURE__*/React.createElement(SettingDescription, null, \"\\u6309\\u4FEE\\u6539\\u65F6\\u95F4\\u6392\\u5E8F\\u5C55\\u793A\\u6700\\u8FD1\\u4FEE\\u6539\\u7684 Markdown \\u6587\\u4EF6\\u3002\\u9ED8\\u8BA4 50\\uFF0C\\u6700\\u5927 500\\u3002\"), /*#__PURE__*/React.createElement(SettingDivider, null), /*#__PURE__*/React.createElement(SettingDescription, null, \"\\u5206\\u7EC4\\uFF1A\\u4ECA\\u5929 / \\u6628\\u5929 / \\u8FC7\\u53BB 7 \\u5929 / \\u672C\\u6708 / \\u66F4\\u65E9\\u3002\\u70B9\\u51FB\\u6587\\u4EF6\\u540D\\u8DF3\\u8F6C\\uFF0C\\u53F3\\u952E\\u4E0A\\u4E0B\\u6587\\u83DC\\u5355\\u3002\"));\n}",
