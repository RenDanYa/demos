    },
    {
      "id": "6097248c-640a-4ad0-bc32-3c12d520c80c",
      "type": "custom",
      "titleAlign": "center",
      "tabTitle": "自定义",
      "maxWidthRatio": -1,
      "showBorder": true,
      "showTitle": true,
      "showShadow": true,
      "createAt": "2025-10-16T12:27:50.146Z",
      "updateAt": "2025-11-26T10:11:28.227Z",
      "viewCode": "// recent-files 视图源码 (已重构为最近修改文件)\n// 新功能: 展示最近修改的 Markdown 文件，按修改时间排序并分组；不监听事件，直接读取 vault 文件数据\n\nfunction App() {\n  const { getData } = useDataStorage();\n  const app = useObsidianApp();\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const limitRaw = settings.limit ? parseInt(settings.limit, 10) : 50; // 默认 50 条\n  const limit = isNaN(limitRaw) || limitRaw <= 0 ? 50 : Math.min(limitRaw, 500); // 安全上限 500\n  const [refreshKey, setRefreshKey] = React.useState(0); // 修改事件触发重渲染\n  const refreshTimerRef = React.useRef(); // debounce 定时器引用\n  const DEBOUNCE_MS = 300; // 300ms debounce 防止频繁刷新\n\n  const scheduleRefresh = React.useCallback(() => {\n    if (refreshTimerRef.current) {\n      clearTimeout(refreshTimerRef.current);\n    }\n    refreshTimerRef.current = setTimeout(() => {\n      setRefreshKey((k) => k + 1);\n    }, DEBOUNCE_MS);\n  }, []);\n\n  // 读取并排序文件 (仅 markdown 文件以减少噪音; 若需全部文件可移除扩展名判断)\n  const files = React.useMemo(() => {\n    if (!app) return [];\n    return app.vault\n      .getAllLoadedFiles()\n      .filter((f) => f instanceof Obsidian.TFile)\n      .map((f) => ({\n        path: f.path,\n        name: f.name,\n        mtime: f.stat ? f.stat.mtime : 0,\n      }))\n      .sort((a, b) => b.mtime - a.mtime)\n      .slice(0, limit);\n  }, [app, limit, refreshKey]);\n\n  // 分组逻辑：今天 / 昨天 / 过去 7 天 / 本月 / 更早\n  const grouped = React.useMemo(() => {\n    const now = moment();\n    const result = new Map();\n    function push(group, file) {\n      if (!result.has(group)) result.set(group, []);\n      result.get(group).push(file);\n    }\n    files.forEach((f) => {\n      const m = moment(f.mtime);\n      if (!m.isValid()) return;\n      if (m.isSame(now, \"day\")) push(\"今天\", f);\n      else if (m.isSame(now.clone().subtract(1, \"day\"), \"day\")) push(\"昨天\", f);\n      else if (m.isAfter(now.clone().subtract(7, \"day\"), \"day\"))\n        push(\"过去 7 天\", f);\n      else if (m.isSame(now, \"month\")) push(\"本月\", f);\n      else push(\"更早\", f);\n    });\n    const order = [\"今天\", \"昨天\", \"过去 7 天\", \"本月\", \"更早\"];\n    return order\n      .filter((o) => result.has(o))\n      .map((o) => ({ group: o, items: result.get(o) }));\n  }, [files]);\n\n  // 不需要事件监听，文件修改排序依赖 Obsidian 的文件 stat；组件渲染时直接读取\n  React.useEffect(() => {\n    if (!app) return;\n    const vault = app.vault;\n    const onModify = (file) => {\n      if (file instanceof Obsidian.TFile) {\n        scheduleRefresh();\n      }\n    };\n    const onRename = (file) => {\n      if (file instanceof Obsidian.TFile) {\n        scheduleRefresh();\n      }\n    };\n    const onDelete = (file) => {\n      if (file instanceof Obsidian.TFile) {\n        scheduleRefresh();\n      }\n    };\n    vault.on(\"modify\", onModify);\n    vault.on(\"rename\", onRename);\n    vault.on(\"delete\", onDelete);\n    return () => {\n      vault.off(\"modify\", onModify);\n      vault.off(\"rename\", onRename);\n      vault.off(\"delete\", onDelete);\n      if (refreshTimerRef.current) {\n        clearTimeout(refreshTimerRef.current);\n      }\n    };\n  }, [app, scheduleRefresh]);\n\n  const openFile = React.useCallback(\n    (e, rec) => {\n      e.preventDefault();\n      const file = app.vault.getAbstractFileByPath(rec.path);\n      if (file && file instanceof Obsidian.TFile) {\n        const leaf = app.workspace.getLeaf(false);\n        leaf.openFile(file);\n      } else {\n        new Obsidian.Notice(\"文件不存在: \" + rec.name);\n      }\n    },\n    [app]\n  );\n\n  const onContextMenu = React.useCallback(\n    (e, rec) => {\n      e.preventDefault();\n      const file = app.vault.getAbstractFileByPath(rec.path);\n      if (file && file instanceof Obsidian.TFile) {\n        const menu = new Obsidian.Menu();\n        app.workspace.trigger(\"file-menu\", menu, file, \"recent-files\");\n        menu.showAtMouseEvent(e);\n      }\n    },\n    [app]\n  );\n\n  const formatTime = (rec, group) => {\n    const m = moment(rec.mtime);\n    if (!m.isValid()) return \"\";\n    if (group === \"今天\") return m.format(\"HH:mm\");\n    if (group === \"昨天\") return m.format(\"HH:mm\");\n    if (group === \"过去 7 天\") return m.format(\"MM-DD HH:mm\");\n    if (group === \"本月\") return m.format(\"MM-DD\");\n    return m.format(\"YYYY-MM-DD\");\n  };\n\n  return (\n    <div className=\"recent-files--Root\">\n      {grouped.length === 0 && (\n        <div className=\"recent-files--Empty\">暂无记录</div>\n      )}\n      {grouped.map((section) => (\n        <div key={section.group} className=\"recent-files--GroupBlock\">\n          <div className=\"recent-files--GroupTitle\">\n            <span className=\"recent-files--GroupTitleText\">{section.group}</span>\n            <span className=\"recent-files--GroupCount\" aria-label={section.items.length + ' files'}>{section.items.length}</span>\n          </div>\n          <ul className=\"recent-files--List\">\n            {section.items.map((f) => (\n              <li key={f.path} className=\"recent-files--Item\">\n                <a\n                  href={f.path}\n                  className=\"internal-link recent-files--FileLink\"\n                  onClick={(e) => openFile(e, f)}\n                  onContextMenu={(e) => onContextMenu(e, f)}\n                  data-path={f.path}\n                  aria-label={f.name}\n                >\n                  {f.name}\n                </a>\n                <span className=\"recent-files--Time\">\n                  {formatTime(f, section.group)}\n                </span>\n              </li>\n            ))}\n          </ul>\n        </div>\n      ))}\n    </div>\n  );\n}\n",
      "settingsCode": "// recent-files 设置项源码 (现为最近修改文件)\n// 提供：显示条数配置（按修改时间排序）\n\nfunction App() {\n  const { getData, saveData } = useDataStorage();\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const limit = settings.limit ?? '';\n\n  const update = (patch) => {\n    saveData({ ...data, settings: { ...settings, ...patch } });\n  };\n\n  return (\n    <Settings>\n  <SettingTitle>Recent Modified 设置</SettingTitle>\n      <SettingInput\n  label=\"显示条数 (修改)\"\n        type=\"number\"\n        min={1}\n        value={limit}\n  placeholder=\"例如 50\"\n        onChange={(e) => {\n          const v = e.target.value;\n            update({ limit: v });\n        }}\n      />\n      <SettingDescription>\n        按修改时间排序展示最近修改的 Markdown 文件。默认 50，最大 500。\n      </SettingDescription>\n      <SettingDivider />\n      <SettingDescription>\n        分组：今天 / 昨天 / 过去 7 天 / 本月 / 更早。点击文件名跳转，右键上下文菜单。\n      </SettingDescription>\n    </Settings>\n  );\n}\n",
      "cssCode": "/* recent-files 样式 CSS 源码 */\n\n.recent-files--Root {\n  padding: 8px 10px 4px 10px;\n  font-size: 13px;\n  line-height: 1.4;\n  border-radius: var(--radius-s);\n}\n\n.recent-files--Empty {\n  color: var(--text-faint);\n  text-align: center;\n  padding: 12px 4px;\n}\n\n.recent-files--GroupBlock + .recent-files--GroupBlock {\n  margin-top: 6px;\n  padding-top: 4px;\n  border-top: 1px dashed var(--background-modifier-border);\n}\n\n.recent-files--GroupTitle {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  font-weight: 600;\n  font-size: 11px;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n  color: var(--text-muted);\n  margin: 2px 0 4px 0;\n}\n\n.recent-files--GroupCount {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-width: 18px;\n  padding: 0 6px;\n  height: 16px;\n  font-size: 10px;\n  font-weight: 600;\n  border-radius: 8px;\n  background: var(--background-modifier-hover);\n  color: var(--text-muted);\n  line-height: 1;\n  font-variant-numeric: tabular-nums;\n}\n\n.recent-files--GroupTitleText {\n  flex: 0 1 auto;\n}\n\n.recent-files--List {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.recent-files--Item {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 4px 8px;\n  border-radius: var(--radius-s);\n  transition: background 120ms ease;\n}\n\n.recent-files--Item:hover {\n  background: var(--background-modifier-hover);\n}\n\n.recent-files--ItemMissing .recent-files--FileLink {\n  opacity: 0.6;\n}\n\n.recent-files--MissingTag {\n  font-size: 11px;\n  color: var(--text-faint);\n  margin-left: 4px;\n}\n\n.recent-files--FileLink {\n  max-width: 70%;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n  color: var(--text-normal);\n  cursor: pointer;\n}\n\n/* 提高优先级以覆盖默认 internal-link 样式特定场景（不硬编码颜色） */\na.internal-link.recent-files--FileLink:is(:hover, :focus) {\n  text-decoration: underline;\n}\n\n.recent-files--Time {\n  font-variant-numeric: tabular-nums;\n  color: var(--text-muted);\n  font-size: 11px;\n  margin-left: 8px;\n  flex-shrink: 0;\n}\n",
      "viewCompilation": {
        "compiledCode": "// recent-files 视图源码 (已重构为最近修改文件)\n// 新功能: 展示最近修改的 Markdown 文件，按修改时间排序并分组；不监听事件，直接读取 vault 文件数据\n\nfunction App() {\n  const {\n    getData\n  } = useDataStorage();\n  const app = useObsidianApp();\n  const data = getData() || {};\n  const settings = data.settings || {};\n  const limitRaw = settings.limit ? parseInt(settings.limit, 10) : 50; // 默认 50 条\n  const limit = isNaN(limitRaw) || limitRaw <= 0 ? 50 : Math.min(limitRaw, 500); // 安全上限 500\n  const [refreshKey, setRefreshKey] = React.useState(0); // 修改事件触发重渲染\n  const refreshTimerRef = React.useRef(); // debounce 定时器引用\n  const DEBOUNCE_MS = 300; // 300ms debounce 防止频繁刷新\n\n  const scheduleRefresh = React.useCallback(() => {\n    if (refreshTimerRef.current) {\n      clearTimeout(refreshTimerRef.current);\n    }\n    refreshTimerRef.current = setTimeout(() => {\n      setRefreshKey(k => k + 1);\n    }, DEBOUNCE_MS);\n  }, []);\n\n  // 读取并排序文件 (仅 markdown 文件以减少噪音; 若需全部文件可移除扩展名判断)\n  const files = React.useMemo(() => {\n    if (!app) return [];\n    return app.vault.getAllLoadedFiles().filter(f => f instanceof Obsidian.TFile).map(f => ({\n      path: f.path,\n      name: f.name,\n      mtime: f.stat ? f.stat.mtime : 0\n    })).sort((a, b) => b.mtime - a.mtime).slice(0, limit);\n  }, [app, limit, refreshKey]);\n\n  // 分组逻辑：今天 / 昨天 / 过去 7 天 / 本月 / 更早\n  const grouped = React.useMemo(() => {\n    const now = moment();\n    const result = new Map();\n    function push(group, file) {\n      if (!result.has(group)) result.set(group, []);\n      result.get(group).push(file);\n    }\n    files.forEach(f => {\n      const m = moment(f.mtime);\n      if (!m.isValid()) return;\n      if (m.isSame(now, \"day\")) push(\"今天\", f);else if (m.isSame(now.clone().subtract(1, \"day\"), \"day\")) push(\"昨天\", f);else if (m.isAfter(now.clone().subtract(7, \"day\"), \"day\")) push(\"过去 7 天\", f);else if (m.isSame(now, \"month\")) push(\"本月\", f);else push(\"更早\", f);\n    });\n    const order = [\"今天\", \"昨天\"