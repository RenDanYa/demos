      "updateAt": "2025-11-26T10:11:28.226Z",
      "title": "优先处理事务",
      "description": "",
      "coverFit": "cover",
      "coverPosition": "left",
      "clickAction": {
        "type": "None",
        "id": "47ee9b62-252d-47db-9767-8bf2eedd4ce3",
