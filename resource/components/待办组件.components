      "id": "60ab5417-20bf-46f3-9c8e-d4f209b0bd76",
      "type": "dataview",
      "titleAlign": "center",
      "tabTitle": "日记一级标题汇总",
      "maxWidthRatio": -1,
      "showBorder": false,
      "showTitle": true,
      "showShadow": false,
      "createAt": "2026-02-25T01:13:24.905Z",
      "updateAt": "2026-02-26T02:43:32.199Z",
      "query": "\n\n// 文件夹路径（修改为目标文件夹）\nconst folderPath = \"03_待加工_灵感问题\";\n\n// 读取文件夹下所有 Markdown 文件\nconst files = app.vault.getMarkdownFiles().filter(f => \n    f.path.startsWith(folderPath + \"/\") || f.path === folderPath\n);\n\n// 准备数据：每个文件的对象 { name, titles }\nlet filesData = [];\nfor (let file of files) {\n    const content = await app.vault.read(file);\n    const lines = content.split(\"\\n\");\n    const headingRegex = /^\\s*#\\s+(.+)/;\n    const titles = [];\n    for (let line of lines) {\n        const match = line.match(headingRegex);\n        if (match) titles.push(match[1].trim());\n    }\n    filesData.push({\n        name: file.name,\n        titles: titles\n    });\n}\n\n// 渲染函数：根据过滤关键词重新生成界面\nfunction render(filterText = \"\") {\n    // 清空容器，重新构建\n    const container = dv.container;\n    container.innerHTML = \"\";\n\n    // 给容器添加一个类，方便样式限定\n    container.classList.add('my-table-container');\n\n    // 创建输入框\n    const input = document.createElement(\"input\");\n    input.type = \"text\";\n    input.placeholder = \"输入文件名关键词过滤...\";\n    input.value = filterText;\n    input.style.width = \"100%\";\n    input.style.marginBottom = \"10px\";\n    input.style.padding = \"5px\";\n    container.appendChild(input);\n\n    // 根据过滤词筛选数据\n    const filtered = filesData.filter(f => \n        f.name.toLowerCase().includes(filterText.toLowerCase())\n    );\n\n    // 统计信息\n    const totalFiles = filtered.length;\n    const totalTitles = filtered.reduce((sum, f) => sum + f.titles.length, 0);\n    const stats = document.createElement(\"div\");\n    stats.textContent = `📁 文件数：${totalFiles}  |  📄 一级标题总数：${totalTitles}`;\n    stats.style.marginBottom = \"10px\";\n    stats.style.fontWeight = \"bold\";\n    container.appendChild(stats);\n\n    // 添加自定义样式，增大行距，表头不换行\n    const style = document.createElement('style');\n    style.textContent = `\n        .my-table-container table {\n            border-collapse: separate;\n            border-spacing: 0;\n            width: 100%;\n        }\n        .my-table-container th,\n        .my-table-container td {\n            padding: 12px 15px !important;\n            line-height: 1.8 !important;\n            vertical-align: middle;\n        }\n        .my-table-container th {\n            white-space: nowrap !important;\n            font-weight: 600;\n        }\n        .my-table-container td {\n            white-space: normal !important;\n        }\n        .my-table-container td:last-child {\n            min-width: 200px;\n        }\n    `;\n    container.appendChild(style);\n\n    // 准备表格数据\n    let tableData = [];\n    for (let f of filtered) {\n        const titlesStr = f.titles.join(\"、\") || \"（无一级标题）\";\n        tableData.push([f.name, f.titles.length, titlesStr]);\n    }\n\n    // 输出表格\n    dv.table([\"文件名\", \"一级标题数量\", \"一级标题列表\"], tableData);\n\n    // 输入框事件：实时过滤\n    input.addEventListener(\"input\", (e) => {\n        render(e.target.value);\n    });\n}\n\n// 初始渲染\nrender();",
      "queryType": "dataviewjs",
      "maxHeight": 1000,
      "dynamicParamComponents": [],
      "title": "日记一级标题汇总"
    }
  ],
