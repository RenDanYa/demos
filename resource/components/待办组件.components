    {
      "id": "52dc09fd-6e8b-4778-b046-b868487a3f2b",
      "type": "dataview",
      "titleAlign": "center",
      "tabTitle": "",
      "maxWidthRatio": -1,
      "showBorder": false,
      "showTitle": true,
      "showShadow": false,
      "createAt": "2026-02-25T01:13:24.905Z",
      "updateAt": "2026-02-26T02:45:01.766Z",
      "query": "\nconst folderPath = \"待办\";\n\n// 获取容器并添加类名\nconst container = dv.container;\ncontainer.classList.add('my-table-container');\n\n// 插入样式（增大行距，表头不换行）\nconst style = document.createElement('style');\nstyle.textContent = `\n    .my-table-container table {\n        border-collapse: separate;\n        border-spacing: 0;\n        width: 100%;\n    }\n    .my-table-container th,\n    .my-table-container td {\n        padding: 12px 15px !important;\n        line-height: 1.8 !important;\n        vertical-align: middle;\n    }\n    .my-table-container th {\n        white-space: nowrap !important;\n        font-weight: 600;\n    }\n    .my-table-container td {\n        white-space: normal !important;\n    }\n    .my-table-container td:last-child {\n        min-width: 200px;\n    }\n`;\ncontainer.appendChild(style);\n\n// 获取该文件夹下的所有页面\nconst pages = dv.pages(`\"${folderPath}\"`);\n\n// 用于存储每个 Project 对应的子项目集合 (自动去重)\nconst projectMap = new Map(); // Key: project, Value: Set of subProjects\nconst projectSet = new Set();\nconst subProjectSet = new Set();\n\nfor (let page of pages) {\n    let project = page.Project;\n    let subProject = page.sub_Project;\n\n    if (project && subProject) {\n        projectSet.add(project);\n        subProjectSet.add(subProject);\n        \n        if (!projectMap.has(project)) {\n            projectMap.set(project, new Set());\n        }\n        projectMap.get(project).add(subProject);\n    }\n}\n\n// 转换为数组并按项目名排序\nconst projectList = Array.from(projectMap.entries())\n    .map(([project, subSet]) => {\n        // 将子项目排序后连接\n        const subArray = Array.from(subSet).sort((a, b) => a.localeCompare(b));\n        return [project, subArray.join(\"、\")];\n    })\n    .sort((a, b) => a[0].localeCompare(b[0]));\n\n// 统计信息\ndv.paragraph(`📊 **统计**：唯一项目数 = ${projectSet.size}，唯一子项目数 = ${subProjectSet.size}，汇总后行数 = ${projectList.length}`);\n\n// 输出表格\ndv.table([\"Project\", \"Sub Projects\"], projectList);",
      "queryType": "dataviewjs",
      "maxHeight": 1000,
      "dynamicParamComponents": [],
      "title": "待办类型汇总"
    },
