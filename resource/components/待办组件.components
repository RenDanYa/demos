    {
      "id": "062f8c41-ac11-4f49-98b9-10908ab044a5",
      "type": "dataview",
      "titleAlign": "center",
      "tabTitle": "",
      "maxWidthRatio": -1,
      "showBorder": false,
      "showTitle": true,
      "showShadow": false,
      "createAt": "2026-01-17T23:17:56.738Z",
      "updateAt": "2026-01-23T00:18:24.595Z",
      "query": "\n// ========== 配置部分（只需修改此处）==========\nconst folderPath = \"03_待加工_灵感问题\";\nconst startDate = `{{startDate}}`;  // 例如：\"2026-01-01\"\nconst endDate = `{{endDate}}`;    // 例如：\"2026-12-31\"\n// ==========================================\n\n// 获取文件并处理\nconst files = app.vault.getMarkdownFiles().filter(f => f.path.includes(folderPath));\nconst allResults = [];\n\nfor (const file of files) {\n    try {\n        const content = await app.vault.read(file);\n        const lines = content.split(\"\\n\");\n        const fileResults = {};\n        let currentH1 = \"\";\n        \n        for (let i = 0; i < lines.length; i++) {\n            const line = lines[i];\n            \n            if (line.startsWith(\"# \")) {\n                currentH1 = line.replace(\"# \", \"\").trim();\n                if (!fileResults[currentH1]) {\n                    fileResults[currentH1] = [];\n                }\n            }\n            else if ((line.includes(\"- [x]\") || line.includes(\"- [X]\")) && currentH1) {\n                const taskText = line.trim();\n                let completionDate = \"\";\n                \n                const datePatterns = [\n                    /✅\\s*(\\d{4}-\\d{2}-\\d{2})/,\n                    /@done\\((\\d{4}-\\d{2}-\\d{2})\\)/,\n                    /@completed\\((\\d{4}-\\d{2}-\\d{2})\\)/,\n                    /📅\\s*(\\d{4}-\\d{2}-\\d{2})/,\n                    /\\[(\\d{4}-\\d{2}-\\d{2})\\]/,\n                    /\\b(\\d{4}-\\d{2}-\\d{2})\\b/,\n                ];\n                \n                for (const pattern of datePatterns) {\n                    const match = taskText.match(pattern);\n                    if (match) {\n                        completionDate = match[1];\n                        break;\n                    }\n                }\n                \n                if (!completionDate && i + 1 < lines.length) {\n                    const nextLine = lines[i + 1].trim();\n                    const dateMatch = nextLine.match(/\\b(\\d{4}-\\d{2}-\\d{2})\\b/);\n                    if (dateMatch && !nextLine.includes(\"- [\")) {\n                        completionDate = dateMatch[1];\n                    }\n                }\n                \n                let shouldInclude = true;\n                if ((startDate || endDate) && completionDate) {\n                    const taskDate = completionDate;\n                    if (startDate && taskDate < startDate) shouldInclude = false;\n                    if (endDate && taskDate > endDate) shouldInclude = false;\n                }\n                \n                if (shouldInclude) {\n                    fileResults[currentH1].push({\n                        task: taskText,\n                        date: completionDate || \"无日期\",\n                        lineNumber: i + 1,\n                        filePath: file.path\n                    });\n                }\n            }\n        }\n        \n        for (const [title, tasks] of Object.entries(fileResults)) {\n            if (tasks && tasks.length > 0) {\n                allResults.push({\n                    文件: file.name.replace(\".md\", \"\"),\n                    文件路径: file.path,\n                    一级标题: title,\n                    已完成待办: tasks,\n                    任务数量: tasks.length\n                });\n            }\n        }\n    } catch (error) {\n        console.error(`处理文件 ${file.name} 时出错:`, error);\n    }\n}\n\n// ========== 复制功能 ==========\n\n// 创建复制按钮\nconst copyButton = document.createElement('button');\ncopyButton.textContent = '📋 复制为 Markdown';\ncopyButton.style.cssText = 'margin: 10px 0; padding: 8px 16px; background: #4CAF50; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px;';\n\n// 添加点击事件\ncopyButton.onclick = async function() {\n    try {\n        // 生成 Markdown 内容\n        let markdown = `# 已完成待办统计\\n\\n`;\n        markdown += `**生成时间：** ${new Date().toLocaleString('zh-CN')}\\n`;\n        markdown += `**筛选日期：** ${startDate} 至 ${endDate}\\n\\n`;\n        \n        // 按文件分组\n        const groupedByFile = {};\n        allResults.forEach(item => {\n            if (!groupedByFile[item.文件]) groupedByFile[item.文件] = [];\n            groupedByFile[item.文件].push(item);\n        });\n        \n        // 添加文件内容\n        for (const [fileName, items] of Object.entries(groupedByFile)) {\n            markdown += `## 📄 ${fileName}\\n\\n`;\n            \n            items.forEach(item => {\n                markdown += `### ${item.一级标题}\\n`;\n                \n                if (item.已完成待办 && Array.isArray(item.已完成待办)) {\n                    item.已完成待办.forEach(task => {\n                        let taskContent = task.task || \"\";\n                        if (taskContent) {\n                            taskContent = taskContent\n                                .replace(/✅\\s*\\d{4}-\\d{2}-\\d{2}/g, '✅')\n                                .replace(/\\d{4}-\\d{2}-\\d{2}/g, '')\n                                .trim();\n                        }\n                        \n                        const dateStr = task.date !== \"无日期\" ? ` (${task.date})` : \"\";\n                        markdown += `- ${taskContent}${dateStr}\\n`;\n                    });\n                }\n                markdown += \"\\n\";\n            });\n        }\n        \n        // 添加统计信息\n        const totalTasks = allResults.reduce((sum, item) => sum + (item.任务数量 || 0), 0);\n        markdown += `## 📊 统计概览\\n\\n`;\n        markdown += `- 总文件数：${Object.keys(groupedByFile).length} 个\\n`;\n        markdown += `- 总已完成待办数：${totalTasks} 个\\n\\n`;\n        \n        // 添加最近完成的任务\n        markdown += `## ⏱️ 最近完成的任务\\n\\n`;\n        \n        let recentTasks = [];\n        allResults.forEach(item => {\n            if (item.已完成待办 && Array.isArray(item.已完成待办)) {\n                item.已完成待办.forEach(task => {\n                    if (task.date && task.date !== \"无日期\") {\n                        recentTasks.push({\n                            文件: item.文件,\n                            标题: item.一级标题,\n                            任务: task.task,\n                            日期: task.date,\n                            行号: task.lineNumber\n                        });\n                    }\n                });\n            }\n        });\n        \n        recentTasks.sort((a, b) => b.日期.localeCompare(a.日期));\n        recentTasks = recentTasks.slice(0, 30); // 限制为30个\n        \n        if (recentTasks.length > 0) {\n            markdown += `| 完成日期 | 文件 | 标题 | 任务内容 | 行号 |\\n`;\n            markdown += `|----------|------|------|----------|------|\\n`;\n            \n            recentTasks.forEach(task => {\n                let taskContent = task.任务 || \"\";\n                if (taskContent) {\n                    taskContent = taskContent\n                        .replace(/✅\\s*\\d{4}-\\d{2}-\\d{2}/g, '✅')\n                        .replace(/\\d{4}-\\d{2}-\\d{2}/g, '')\n                        .trim();\n                }\n                \n                if (taskContent.length > 50) {\n                    taskContent = taskContent.substring(0, 50) + \"...\";\n                }\n                \n                markdown += `| ${task.日期} | ${task.文件} | ${task.标题 || \"无标题\"} | ${taskContent} | 行 ${task.行号} |\\n`;\n            });\n        } else {\n            markdown += `没有找到有日期的任务\\n`;\n        }\n        \n        markdown += `\\n---\\n`;\n        markdown += `*注：此报告由 DataviewJS 自动生成*\\n`;\n        \n        // 复制到剪贴板\n        await navigator.clipboard.writeText(markdown);\n        \n        // 显示成功消息\n        copyButton.textContent = '✅ 已复制到剪贴板';\n        copyButton.style.background = '#45a049';\n        \n        // 2秒后恢复按钮\n        setTimeout(() => {\n            copyButton.textContent = '📋 复制为 Markdown';\n            copyButton.style.background = '#4CAF50';\n        }, 2000);\n        \n    } catch (error) {\n        console.error('复制失败:', error);\n        copyButton.textContent = '❌ 复制失败';\n        copyButton.style.background = '#f44336';\n        \n        setTimeout(() => {\n            copyButton.textContent = '📋 复制为 Markdown';\n            copyButton.style.background = '#4CAF50';\n        }, 2000);\n    }\n};\n\n// 插入按钮到页面\nconst container = dv.container;\ncontainer.insertBefore(copyButton, container.firstChild);\n\n// ========== 显示结果 ==========\n\n// 按文件分组显示\nconst groupedByFile = {};\nallResults.forEach(item => {\n    if (!groupedByFile[item.文件]) groupedByFile[item.文件] = [];\n    groupedByFile[item.文件].push(item);\n});\n\nfor (const [fileName, items] of Object.entries(groupedByFile)) {\n    dv.header(3, `📄 ${fileName}`);\n    \n    const tableData = [];\n    items.forEach(item => {\n        if (item.已完成待办 && Array.isArray(item.已完成待办)) {\n            item.已完成待办.forEach(taskInfo => {\n                let dateDisplay = taskInfo.date || \"无日期\";\n                if (taskInfo.date && taskInfo.date !== \"无日期\") {\n                    try {\n                        const dateObj = new Date(taskInfo.date);\n                        const formattedDate = dateObj.toLocaleDateString('zh-CN', {\n                            year: 'numeric', month: 'short', day: 'numeric'\n                        });\n                        dateDisplay = `${taskInfo.date}<br><small>(${formattedDate})</small>`;\n                    } catch (e) {\n                        dateDisplay = taskInfo.date;\n                    }\n                }\n                \n                let taskContent = taskInfo.task || \"\";\n                if (taskContent) {\n                    taskContent = taskContent\n                        .replace(/✅\\s*\\d{4}-\\d{2}-\\d{2}/g, '✅')\n                        .replace(/\\d{4}-\\d{2}-\\d{2}/g, '')\n                        .trim();\n                }\n                \n                tableData.push([\n                    item.一级标题 || \"无标题\",\n                    taskContent,\n                    dateDisplay,\n                    `行 ${taskInfo.lineNumber || \"未知\"}`\n                ]);\n            });\n        }\n    });\n    \n    if (tableData.length > 0) {\n        dv.table([\"一级标题\", \"任务内容\", \"完成日期\", \"行号\"], tableData);\n    } else {\n        dv.paragraph(\"没有符合条件的任务\");\n    }\n}\n\n// ========== 统计信息 ==========\ndv.header(2, \"📊 统计概览\");\nconst totalTasks = allResults.reduce((sum, item) => sum + (item.任务数量 || 0), 0);\nconst filesWithTasks = Object.keys(groupedByFile).length;\ndv.paragraph(`**总文件数：** ${filesWithTasks} 个`);\ndv.paragraph(`**总已完成待办数：** ${totalTasks} 个`);\n\n// 日期分布统计\nconst dateStats = {};\nlet tasksWithDate = 0;\nallResults.forEach(item => {\n    if (item.已完成待办 && Array.isArray(item.已完成待办)) {\n        item.已完成待办.forEach(task => {\n            const date = task.date || \"无日期\";\n            if (date !== \"无日期\") tasksWithDate++;\n            dateStats[date] = (dateStats[date] || 0) + 1;\n        });\n    }\n});\nconst tasksWithoutDate = totalTasks - tasksWithDate;\n\nif (totalTasks > 0) {\n    dv.paragraph(`**有日期任务：** ${tasksWithDate} 个`);\n    dv.paragraph(`**无日期任务：** ${tasksWithoutDate} 个`);\n}\n\n// 显示日期分布\nif (Object.keys(dateStats).length > 0) {\n    dv.header(2, \"📅 完成日期分布\");\n    const dateTable = Object.entries(dateStats)\n        .sort((a, b) => {\n            if (a[0] === \"无日期\") return 1;\n            if (b[0] === \"无日期\") return -1;\n            return b[0].localeCompare(a[0]);\n        })\n        .map(([date, count]) => {\n            let dateDisplay = date;\n            if (date !== \"无日期\") {\n                try {\n                    const dateObj = new Date(date);\n                    const weekdays = [\"日\", \"一\", \"二\", \"三\", \"四\", \"五\", \"六\"];\n                    const weekday = weekdays[dateObj.getDay()];\n                    dateDisplay = `${date} (周${weekday})`;\n                } catch (e) {}\n            }\n            return [dateDisplay, count];\n        });\n\n    dv.table([\"完成日期\", \"任务数量\"], dateTable);\n}\n\n// ========== 最近任务 ==========\nif (totalTasks > 0) {\n    dv.header(2, \"⏱️ 最近完成的任务\");\n    \n    let recentTasks = [];\n    allResults.forEach(item => {\n        if (item.已完成待办 && Array.isArray(item.已完成待办)) {\n            item.已完成待办.forEach(task => {\n                if (task.date && task.date !== \"无日期\") {\n                    recentTasks.push({\n                        文件: item.文件,\n                        标题: item.一级标题,\n                        任务: task.task,\n                        日期: task.date,\n                        行号: task.lineNumber\n                    });\n                }\n            });\n        }\n    });\n    \n    recentTasks.sort((a, b) => b.日期.localeCompare(a.日期));\n    recentTasks = recentTasks.slice(0, 30);\n    \n    if (recentTasks.length > 0) {\n        const recentTable = recentTasks.map(task => {\n            let taskContent = task.任务 || \"\";\n            if (taskContent.length > 40) {\n                taskContent = taskContent.substring(0, 40) + \"...\";\n            }\n            \n            return [\n                task.日期,\n                task.文件 || \"未知\",\n                task.标题 || \"无标题\",\n                taskContent,\n                `行 ${task.行号 || \"未知\"}`\n            ];\n        });\n        \n        dv.table([\"完成日期\", \"文件\", \"标题\", \"任务内容\", \"行号\"], recentTable);\n    } else {\n        dv.paragraph(\"没有找到有日期的任务\");\n    }\n}",
