    {
      "id": "7baad6e4-5de1-4c2c-9b98-fc3f82415579",
      "type": "dataview",
      "titleAlign": "center",
      "tabTitle": "Dataview",
      "maxWidthRatio": -1,
      "showBorder": true,
      "showTitle": true,
      "showShadow": true,
      "createAt": "2025-12-02T02:08:08.346Z",
      "updateAt": "2025-12-07T00:39:00.184Z",
      "query": "// 按时间段分组，只显示带有休息标签的时间记录\ntry {\n    const targetFileName = `{{name}}`;\n    const folderPath = \"03_输出_每日日记\";\n    const fullPath = `${folderPath}/${targetFileName}`;\n    \n    const content = await dv.io.load(fullPath);\n    if (!content) {\n        dv.paragraph(`文件不存在或为空`);\n        return;\n    }\n    \n    // 查找时间记录部分\n    const lines = content.split(\"\\n\");\n    const startIdx = lines.findIndex(l => l.includes(\"## 📝 时间记录\"));\n    if (startIdx === -1) {\n        dv.paragraph(\"未找到时间记录部分\");\n        return;\n    }\n    \n    // 提取记录 - 现在只提取包含休息标签的记录\n    const records = [];\n    for (let i = startIdx + 1; i < lines.length; i++) {\n        const line = lines[i].trim();\n        if (line.startsWith(\"## \")) break;\n        \n        // 只包含休息标签的记录\n        if (line.includes(\"#时间记录/运动\")||line.includes(\"#时间记录/阅读\")||line.includes(\"#时间记录/播客\")||line.includes(\"#时间记录/放松模式\")) {\n            records.push(line);\n        }\n    }\n    \n    if (records.length === 0) {\n        dv.paragraph(\"没有找到带有休息标签的时间记录\");\n        return;\n    }\n    \n    // 时间解析函数\n    function parseTime(timeStr) {\n        if (!timeStr) return null;\n        timeStr = timeStr.trim().replace(/^-\\s*/, '');\n        const match = timeStr.match(/(\\d{1,2})[:.](\\d{2})/);\n        if (match) {\n            const hours = parseInt(match[1]);\n            const minutes = parseInt(match[2]);\n            if (hours >= 0 && hours <= 23 && minutes >= 0 && minutes <= 59) {\n                return hours + minutes / 60;\n            }\n        }\n        return null;\n    }\n    \n    // 计算持续时间\n    function calculateDuration(record) {\n        const cleanRecord = record.replace(/^-\\s*/, '');\n        const timeMatch = cleanRecord.match(/(\\d{1,2}[:.]\\d{2})-(\\d{1,2}[:.]\\d{2})/);\n        if (!timeMatch) return 0;\n        \n        const startTime = parseTime(timeMatch[1]);\n        const endTime = parseTime(timeMatch[2]);\n        \n        if (startTime === null || endTime === null) return 0;\n        \n        let duration = endTime - startTime;\n        if (duration < 0) duration += 24;\n        return Math.max(0, duration);\n    }\n    \n    // 分组\n    const groups = {\n        morning: { records: [], duration: 0 },\n        afternoon: { records: [], duration: 0 },\n        evening: { records: [], duration: 0 },\n        night: { records: [], duration: 0 },\n        other: { records: [], duration: 0 }\n    };\n    \n    records.forEach(record => {\n        const cleanRecord = record.replace(/^-\\s*/, '');\n        const timeMatch = cleanRecord.match(/(\\d{1,2})[:.]?(\\d{2})?/);\n        \n        if (timeMatch) {\n            let hours = parseInt(timeMatch[1]);\n            if (timeMatch[2]) {\n                const minutes = parseInt(timeMatch[2]);\n                hours += minutes / 60;\n            }\n            \n            const duration = calculateDuration(record);\n            \n            if (hours >= 21 || hours < 6) {\n                groups.night.records.push(record);\n                groups.night.duration += duration;\n            } else if (hours >= 6 && hours < 14) {\n                groups.morning.records.push(record);\n                groups.morning.duration += duration;\n            } else if (hours >= 14 && hours < 17) {\n                groups.afternoon.records.push(record);\n                groups.afternoon.duration += duration;\n            } else if (hours >= 17 && hours < 21) {\n                groups.evening.records.push(record);\n                groups.evening.duration += duration;\n            } else {\n                groups.other.records.push(record);\n                groups.other.duration += duration;\n            }\n        } else {\n            groups.other.records.push(record);\n            groups.other.duration += calculateDuration(record);\n        }\n    });\n    \n    // 构建输出\n    let markdown = `## ${targetFileName.replace('.md', '')} 休息时间记录\\n`;\n    markdown += `共 ${records.length} 条休息记录\\n\\n`;\n    \n    const groupNames = {\n        morning: \"🌅 早上 (6:00-14:00)\",\n        afternoon: \"🌞 下午 (14:00-17:00)\",\n        evening: \"🌆 晚上 (17:00-21:00)\",\n        night: \"🌙 深夜 (21:00以后及6:00前)\",\n        other: \"⏰ 其他时间段\"\n    };\n    \n    const groupOrder = [\"morning\", \"afternoon\", \"evening\", \"night\", \"other\"];\n    \n    // 输出每个分组\n    groupOrder.forEach(key => {\n        if (groups[key].records.length > 0) {\n            const duration = groups[key].duration.toFixed(2);\n            markdown += `${groupNames[key]} (${groups[key].records.length}条，${duration}小时):\\n`;\n            \n            // 输出该分组的记录列表\n            groups[key].records.forEach(record => {\n                const cleanRecord = record.replace(/^-\\s*/, '');\n                markdown += `- ${cleanRecord}\\n`;\n            });\n            \n            markdown += \"\\n\";\n        }\n    });\n    \n    // 添加简单的统计\n    let totalDuration = 0;\n    groupOrder.forEach(key => {\n        totalDuration += groups[key].duration;\n    });\n    \n    markdown += `**总计: ${totalDuration.toFixed(2)}小时**`;\n    \n    // 输出\n    dv.paragraph(markdown);\n    \n} catch (error) {\n    dv.paragraph(`错误: ${error.message}`);\n}",
      "queryType": "dataviewjs",
      "maxHeight": 700,
      "dynamicParamComponents": [
        {
          "id": "e4f5a84d-bdd5-4433-889c-fa376778af22",
          "type": "propertyValueSuggestions",
          "name": "name",
          "defaultValue": "",
          "placeholder": "",
          "fromProperty": "file_name",
          "label": "文件名"
        }
      ],
      "fontColor": "#4d5356",
      "components": []
    },
